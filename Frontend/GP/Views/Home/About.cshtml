
@{
    ViewData["Title"] = "About";
}


<style>
    /* ── Hero ── */
    .ab-hero {
        background: #e8f4fd;
        padding: 3.5rem 0 2.5rem;
        text-align: center;
    }

    .ab-badge {
        background: #c9c6ff;
        color: #3C3489;
        font-size: 12px;
        font-weight: 600;
        padding: 5px 16px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 1rem;
    }

    /* ── Mission ── */
    .mission-illus {
        background: #f0efff;
        border-radius: 20px;
        padding: 2.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .mission-illus-circle {
        width: 130px;
        height: 130px;
        background: #c9c6ff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* ── Value cards ── */
    .val-card {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 14px;
        padding: 1.4rem;
        height: 100%;
    }

    .val-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0.85rem;
    }

        .val-icon.blue {
            background: #e8f4fd;
        }

        .val-icon.purple {
            background: #f0efff;
        }

        .val-icon.teal {
            background: #e1f5ee;
        }

        .val-icon.amber {
            background: #fdf3dc;
        }

        .val-icon.coral {
            background: #faece7;
        }

        .val-icon.green {
            background: #eaf3de;
        }

    /* ── Who cards ── */
    .who-card {
        border-radius: 14px;
        padding: 1.5rem;
    }

        .who-card.teacher {
            background: #e8f4fd;
        }

        .who-card.parent {
            background: #f0efff;
        }

    /* ── Stats bar ── */
    .stats-bar {
        background: #0dcaf0;
        padding: 2.5rem 0;
    }

    .stat-num {
        font-size: 2.2rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 4px;
    }

    .stat-label {
        font-size: 13px;
        color: rgba(255,255,255,.85);
        margin: 0;
    }
</style>

<!-- ═══════════════ HERO ═══════════════ -->
<div class="ab-hero">
    <div class="container">
        <span class="ab-badge">About Bridge</span>

        <h1 class="fw-bold lh-sm mb-3">
            Built to Help Every<br>Student Succeed
        </h1>

        <p class="text-secondary lh-lg mx-auto" style="max-width:580px;">
            Bridge is an educational platform designed to give teachers the insights they need
            to support every student — not just the ones keeping up.
        </p>
    </div>
</div>

<!-- ═══════════════ MISSION ═══════════════ -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5">

            <div class="col-12 col-lg-6">
                <h2 class="fw-bold mb-3">Our Mission</h2>
                <p class="text-secondary lh-lg mb-3">
                    Teaching has never been easy, and understanding where each student struggles
                    is even harder. Bridge was created to change that — giving teachers a clear,
                    data-driven view of their classroom so no student falls through the cracks.
                </p>
                <p class="text-secondary lh-lg mb-0">
                    We believe every student learns differently, and every teacher deserves tools
                    that reflect that reality. Our platform turns raw results into actionable
                    learning plans, tailored for the whole class and for those who need extra support.
                </p>
            </div>

            <div class="col-12 col-lg-6">
                <div class="mission-illus">
                    <div class="mission-illus-circle">
                        <svg width="64" height="64" viewBox="0 0 56 56" fill="none">
                            <path d="M28 8 L48 20 L48 36 C48 44 38 50 28 53 C18 50 8 44 8 36 L8 20 Z"
                                  fill="#534AB7" opacity="0.15" />
                            <path d="M28 12 L44 22 L44 36 C44 43 36 48 28 51 C20 48 12 43 12 36 L12 22 Z"
                                  fill="#534AB7" opacity="0.3" />
                            <path d="M22 28 L26 32 L34 24"
                                  stroke="#534AB7" stroke-width="3"
                                  stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ═══════════════ VALUES ═══════════════ -->
<section class="py-5 bg-warning bg-opacity-10">
    <div class="container">

        <h2 class="fw-bold text-center mb-5">What We Stand For</h2>

        <div class="row g-3">

            <div class="col-12 col-md-6 col-lg-4">
                <div class="val-card">
                    <div class="val-icon blue">
                        <i class="bi bi-clock-history fs-5 text-primary"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Early Intervention</h5>
                    <p class="text-secondary mb-0" style="font-size:14px;">
                        Spot learning gaps before they become barriers — not after the term ends.
                    </p>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="val-card">
                    <div class="val-icon purple">
                        <i class="bi bi-people fs-5" style="color:#534AB7;"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Teacher Empowerment</h5>
                    <p class="text-secondary mb-0" style="font-size:14px;">
                        Give teachers the clarity and tools to make every lesson count.
                    </p>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="val-card">
                    <div class="val-icon teal">
                        <i class="bi bi-graph-up-arrow fs-5" style="color:#0F6E56;"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Data-Driven Progress</h5>
                    <p class="text-secondary mb-0" style="font-size:14px;">
                        Track growth over time with clear, visual reports for the whole class.
                    </p>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="val-card">
                    <div class="val-icon amber">
                        <i class="bi bi-layers fs-5" style="color:#BA7517;"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Personalised Plans</h5>
                    <p class="text-secondary mb-0" style="font-size:14px;">
                        Each student's needs are unique — our plans reflect that.
                    </p>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="val-card">
                    <div class="val-icon coral">
                        <i class="bi bi-heart fs-5" style="color:#993C1D;"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Student Well-being</h5>
                    <p class="text-secondary mb-0" style="font-size:14px;">
                        We care about the whole student — academic progress and confidence.
                    </p>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <div class="val-card">
                    <div class="val-icon green">
                        <i class="bi bi-shield-check fs-5" style="color:#3B6D11;"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Privacy First</h5>
                    <p class="text-secondary mb-0" style="font-size:14px;">
                        Student data is secure, private, and used only to support learning.
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ═══════════════ WHO IT'S FOR ═══════════════ -->
<section class="py-5">
    <div class="container">

        <h2 class="fw-bold mb-4">Who Is Bridge For?</h2>

        <div class="row g-4">

            <div class="col-12 col-md-6">
                <div class="who-card teacher h-100">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-display fs-4 text-primary"></i>
                        <h4 class="fw-bold mb-0 text-primary">Teachers</h4>
                    </div>
                    <p class="text-secondary mb-0 lh-lg" style="font-size:14px;">
                        Upload class results, get instant analysis, and receive ready-to-use
                        learning plans tailored to your students' actual needs — saving hours
                        of manual work each term.
                    </p>
                </div>
            </div>

            <div class="col-12 col-md-6">
                <div class="who-card parent h-100">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-people-fill fs-4" style="color:#534AB7;"></i>
                        <h4 class="fw-bold mb-0" style="color:#534AB7;">Parents</h4>
                    </div>
                    <p class="text-secondary mb-0 lh-lg" style="font-size:14px;">
                        Stay informed about your child's progress, see where they excel and
                        where they need support — so you can be part of the learning journey
                        at home too.
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ═══════════════ STATS ═══════════════ -->
<section class="stats-bar">
    <div class="container">
        <div class="row g-4 text-center">

            <div class="col-12 col-md-4">
                <p class="stat-num">500+</p>
                <p class="stat-label">Students supported</p>
            </div>

            <div class="col-12 col-md-4">
                <p class="stat-num">3</p>
                <p class="stat-label">Steps to your learning plan</p>
            </div>

            <div class="col-12 col-md-4">
                <p class="stat-num">100%</p>
                <p class="stat-label">Focused on student growth</p>
            </div>

        </div>
    </div>
</section>

<!-- ═══════════════ CTA ═══════════════ -->
<section class="py-5 text-center">
    <div class="container">

        <h2 class="fw-bold mb-2">Ready to support your students?</h2>
        <p class="text-secondary mb-4">
            Join Bridge today and give every student the attention they deserve.
        </p>

        <a asp-controller="Home" asp-action="SignUp"
           class="btn btn-info rounded-pill px-4 py-2 fw-semibold shadow-sm">
            Get Started →
        </a>

    </div>
</section>

