@{
    ViewData["Title"] = "Quiz Reviews";
}

<style>
    .review-list-page { max-width: 1120px; margin: 0 auto; padding: 28px; }
    .review-list-card { background:#fff; border:1px solid #e5e7eb; border-radius:24px; box-shadow:0 10px 28px rgba(17,30,39,.06); padding:24px; }
    .review-list-title { font-size:34px; font-weight:800; color:#111E27; margin-bottom:8px; }
    .review-list-subtitle { color:#6b7280; margin-bottom:18px; }
    .review-list-nav { display:flex; gap:12px; margin-bottom:20px; flex-wrap:wrap; }
    .review-list-tab { display:inline-flex; align-items:center; justify-content:center; padding:10px 16px; border-radius:999px; border:1px solid #dbe3f0; background:#fff; color:#374151; text-decoration:none; font-weight:700; }
    .review-list-tab.active { background:linear-gradient(135deg,#82CBFF,#6DC2FF); border-color:transparent; color:#fff; }
    .review-list-grid { display:grid; gap:12px; }
    .review-list-row { display:grid; grid-template-columns:1.4fr 1.1fr .8fr .8fr auto; gap:14px; align-items:center; border:1px solid #eef2f7; border-radius:18px; padding:16px; }
    .review-list-head { background:#f8fafc; font-weight:800; color:#374151; }
    .review-list-badge { display:inline-flex; align-items:center; justify-content:center; border-radius:999px; padding:8px 12px; font-size:12px; font-weight:700; background:#fff7db; color:#a16207; width:fit-content; }
    .review-list-btn { border:1px solid #d1d5db; border-radius:999px; padding:9px 14px; font-size:13px; font-weight:700; text-decoration:none; color:#46A3E5; background:#fff; white-space:nowrap; }
    .review-list-empty { color:#6b7280; text-align:center; padding:28px; }
    @@media (max-width:960px){ .review-list-row { grid-template-columns:1fr; } .review-list-head { display:none; } }
</style>

<div class="teacher-shell">
    <partial name="_TeacherSidebar" />
    <div class="teacher-shell-content">
        <div class="review-list-page">
            <div class="review-list-card">
                <div class="review-list-title">Quiz Reviews</div>
                <div class="review-list-subtitle">Essay-based submissions waiting for teacher review.</div>
                <div class="review-list-nav">
                    <a class="review-list-tab active" href="@Url.Action("TeacherQuizReviews", "Home")">Pending Reviews</a>
                    <a class="review-list-tab" href="@Url.Action("TeacherQuizReviewed", "Home")">Reviewed History</a>
                </div>
                <div id="teacherReviewList" class="review-list-grid"></div>
            </div>
        </div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const token = sessionStorage.getItem("bridgeAccessToken");
    const role = sessionStorage.getItem("bridgeUserRole");
    const teacherReviewList = document.getElementById("teacherReviewList");

    function renderReviewList(items) {
        if (!items.length) {
            teacherReviewList.innerHTML = `<div class="review-list-empty">No pending quiz reviews.</div>`;
            return;
        }

        teacherReviewList.innerHTML = `
            <div class="review-list-row review-list-head">
                <div>Quiz</div>
                <div>Student</div>
                <div>Submitted</div>
                <div>Essay questions</div>
                <div>Action</div>
            </div>
            ${items.map((item) => `
                <div class="review-list-row">
                    <div><strong>${item.title}</strong></div>
                    <div>${item.studentName}</div>
                    <div>${new Date(item.submittedAt).toLocaleDateString()}</div>
                    <div><span class="review-list-badge">${item.pendingEssayCount} pending</span></div>
                    <div><a class="review-list-btn" href="@Url.Action("TeacherQuizReviewDetail", "Home")?quizResultId=${encodeURIComponent(item.quizResultId)}">Review</a></div>
                </div>
            `).join("")}
        `;
    }

    async function loadTeacherReviews() {
        if (!token) { window.location.replace('@Url.Action("Login", "Home")'); return; }
        if (role && role !== "Teacher") { window.location.replace('@Url.Action("ParentDashboard", "Home")'); return; }

        const response = await fetch(`${backendBaseUrl}/quizzes/review/pending`, {
            headers: { Authorization: `Bearer ${token}` }
        });
        const data = await response.json().catch(() => []);
        if (!response.ok) throw new Error(data?.message || "Unable to load quiz reviews.");
        renderReviewList(Array.isArray(data) ? data : []);
    }

    loadTeacherReviews().catch((error) => {
        teacherReviewList.innerHTML = `<div class="review-list-empty">${error.message || "Unable to load quiz reviews."}</div>`;
    });
</script>
