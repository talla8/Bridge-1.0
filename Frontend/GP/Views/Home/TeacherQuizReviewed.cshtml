@{
    ViewData["Title"] = "Reviewed Quizzes";
}

<style>
    .reviewed-list-page { max-width: 1180px; margin: 0 auto; padding: 28px; }
    .reviewed-list-card { background:#fff; border:1px solid #e5e7eb; border-radius:24px; box-shadow:0 10px 28px rgba(17,30,39,.06); padding:24px; }
    .reviewed-list-title { font-size:34px; font-weight:800; color:#111E27; margin-bottom:8px; }
    .reviewed-list-subtitle { color:#6b7280; margin-bottom:18px; }
    .reviewed-list-nav { display:flex; gap:12px; margin-bottom:20px; flex-wrap:wrap; }
    .reviewed-list-tab { display:inline-flex; align-items:center; justify-content:center; padding:10px 16px; border-radius:999px; border:1px solid #dbe3f0; background:#fff; color:#374151; text-decoration:none; font-weight:700; }
    .reviewed-list-tab.active { background:linear-gradient(135deg,#82CBFF,#6DC2FF); border-color:transparent; color:#fff; }
    .reviewed-list-grid { display:grid; gap:12px; }
    .reviewed-list-row { display:grid; grid-template-columns:1.4fr 1fr .8fr .8fr .9fr 1fr auto; gap:14px; align-items:center; border:1px solid #eef2f7; border-radius:18px; padding:16px; }
    .reviewed-list-head { background:#f8fafc; font-weight:800; color:#374151; }
    .reviewed-list-badge { display:inline-flex; align-items:center; justify-content:center; border-radius:999px; padding:8px 12px; font-size:12px; font-weight:700; background:#eef2ff; color:#46A3E5; width:fit-content; }
    .reviewed-list-btn { border:1px solid #d1d5db; border-radius:999px; padding:9px 14px; font-size:13px; font-weight:700; text-decoration:none; color:#46A3E5; background:#fff; white-space:nowrap; }
    .reviewed-list-empty { color:#6b7280; text-align:center; padding:28px; }
    @@media (max-width:1100px){ .reviewed-list-row { grid-template-columns:1fr; } .reviewed-list-head { display:none; } }
</style>

<div class="teacher-shell">
    <partial name="_TeacherSidebar" />
    <div class="teacher-shell-content">
        <div class="reviewed-list-page">
            <div class="reviewed-list-card">
                <div class="reviewed-list-title">Reviewed Quizzes</div>
                <div class="reviewed-list-subtitle">Historical list of completed quiz submissions, including auto-graded results and teacher-reviewed essays.</div>
                <div class="reviewed-list-nav">
                    <a class="reviewed-list-tab" href="@Url.Action("TeacherQuizReviews", "Home")">Pending Reviews</a>
                    <a class="reviewed-list-tab active" href="@Url.Action("TeacherQuizReviewed", "Home")">Reviewed History</a>
                </div>
                <div id="teacherReviewedList" class="reviewed-list-grid"></div>
            </div>
        </div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const token = sessionStorage.getItem("bridgeAccessToken");
    const role = sessionStorage.getItem("bridgeUserRole");
    const teacherReviewedList = document.getElementById("teacherReviewedList");

    function renderReviewedList(items) {
        if (!items.length) {
            teacherReviewedList.innerHTML = `<div class="reviewed-list-empty">No completed quiz submissions yet.</div>`;
            return;
        }

        teacherReviewedList.innerHTML = `
            <div class="reviewed-list-row reviewed-list-head">
                <div>Quiz</div>
                <div>Student</div>
                <div>Submitted</div>
                <div>Reviewed</div>
                <div>Status</div>
                <div>Score</div>
                <div>Action</div>
            </div>
            ${items.map((item) => `
                <div class="reviewed-list-row">
                    <div><strong>${item.title}</strong></div>
                    <div>${item.studentName}</div>
                    <div>${new Date(item.submittedAt).toLocaleDateString()}</div>
                    <div>${item.reviewedAt ? new Date(item.reviewedAt).toLocaleDateString() : "-"}</div>
                    <div><span class="reviewed-list-badge">${item.status === "AUTO_GRADED" ? "Auto graded" : "Reviewed"}</span></div>
                    <div><span class="reviewed-list-badge">${Number(item.score ?? 0)}%</span></div>
                    <div><a class="reviewed-list-btn" href="@Url.Action("TeacherQuizReviewDetail", "Home")?quizResultId=${encodeURIComponent(item.quizResultId)}">Open</a></div>
                </div>
            `).join("")}
        `;
    }

    async function loadReviewedHistory() {
        if (!token) { window.location.replace('@Url.Action("Login", "Home")'); return; }
        if (role && role !== "Teacher") { window.location.replace('@Url.Action("ParentDashboard", "Home")'); return; }

        const response = await fetch(`${backendBaseUrl}/quizzes/review/reviewed`, {
            headers: { Authorization: `Bearer ${token}` }
        });
        const data = await response.json().catch(() => []);
        if (!response.ok) throw new Error(data?.message || "Unable to load reviewed quizzes.");
        renderReviewedList(Array.isArray(data) ? data : []);
    }

    loadReviewedHistory().catch((error) => {
        teacherReviewedList.innerHTML = `<div class="reviewed-list-empty">${error.message || "Unable to load reviewed quizzes."}</div>`;
    });
</script>
