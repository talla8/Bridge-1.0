@{
    ViewData["Title"] = "Quiz Results";
}

<style>
    .parent-results-page {
        max-width: 1120px;
        margin: 0 auto;
        padding: 28px;
    }

    .parent-results-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        box-shadow: 0 10px 28px rgba(17,30,39,.06);
        padding: 24px;
    }

    .parent-results-title {
        font-size: 34px;
        font-weight: 800;
        color: #111E27;
        margin-bottom: 8px;
    }

    .parent-results-topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 8px;
        flex-wrap: wrap;
    }

    .parent-results-back {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 10px 16px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        color: #6c8cff;
        background: #fff;
        border: 1px solid #dbe3f0;
    }

    .parent-results-subtitle {
        color: #6b7280;
        margin-bottom: 18px;
    }

    .parent-results-toolbar {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .parent-results-filter,
    .parent-results-sort {
        min-width: 220px;
        border: 1px solid #dbe3f0;
        border-radius: 14px;
        padding: 10px 12px;
        font-size: 14px;
        background: #fff;
        color: #374151;
    }

    .parent-results-grid {
        display: grid;
        gap: 12px;
    }

    .parent-results-row {
        display: grid;
        grid-template-columns: 1.2fr .9fr 1fr .9fr .7fr .8fr auto;
        gap: 14px;
        align-items: center;
        border: 1px solid #eef2f7;
        border-radius: 18px;
        padding: 16px;
    }

    .parent-results-head {
        background: #f8fafc;
        font-weight: 800;
        color: #374151;
    }

    .parent-results-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 8px 12px;
        font-size: 12px;
        font-weight: 700;
        background: #eef2ff;
        color: #46A3E5;
        width: fit-content;
    }

    .parent-results-score {
        font-weight: 800;
        color: #111E27;
    }

    .parent-results-empty {
        color: #6b7280;
        text-align: center;
        padding: 28px;
    }

    @@media (max-width: 960px) {
        .parent-results-row {
            grid-template-columns: 1fr;
        }

        .parent-results-head {
            display: none;
        }
    }
</style>

<div class="parent-results-page">
    <div class="parent-results-card">
        <div class="parent-results-topbar">
            <a class="parent-results-back" href="@Url.Action("ParentDashboard", "Home")">Back to dashboard</a>
        </div>
        <div class="parent-results-title">Quiz Results</div>
        <div class="parent-results-subtitle">Submitted quizzes and their current grading status.</div>
        <div class="parent-results-toolbar">
            <select id="parentQuizResultsSubjectFilter" class="parent-results-filter">
                <option value="all">All subjects</option>
            </select>
            <select id="parentQuizResultsSort" class="parent-results-sort">
                <option value="submitted_desc">Submitted: newest first</option>
                <option value="submitted_asc">Submitted: oldest first</option>
                <option value="score_desc">Score: highest first</option>
                <option value="score_asc">Score: lowest first</option>
                <option value="student_asc">Student name: A to Z</option>
                <option value="student_desc">Student name: Z to A</option>
                <option value="title_asc">Quiz title: A to Z</option>
                <option value="title_desc">Quiz title: Z to A</option>
            </select>
        </div>

        <div id="parentQuizResultsList" class="parent-results-grid"></div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const token = sessionStorage.getItem("bridgeAccessToken");
    const role = sessionStorage.getItem("bridgeUserRole");
    const parentQuizResultsList = document.getElementById("parentQuizResultsList");
    const parentQuizResultsSort = document.getElementById("parentQuizResultsSort");
    const parentQuizResultsSubjectFilter = document.getElementById("parentQuizResultsSubjectFilter");
    let parentQuizResultsState = [];

    function compareResultsText(left, right) {
        return String(left || "").localeCompare(String(right || ""));
    }

    function sortParentQuizResults(items) {
        const sortMode = parentQuizResultsSort?.value || "submitted_desc";
        const sorted = [...items];

        sorted.sort((left, right) => {
            switch (sortMode) {
                case "submitted_asc":
                    return new Date(left.submittedAt).getTime() - new Date(right.submittedAt).getTime();
                case "score_desc":
                    return Number(right.score ?? 0) - Number(left.score ?? 0);
                case "score_asc":
                    return Number(left.score ?? 0) - Number(right.score ?? 0);
                case "student_asc":
                    return compareResultsText(left.studentName, right.studentName);
                case "student_desc":
                    return compareResultsText(right.studentName, left.studentName);
                case "title_asc":
                    return compareResultsText(left.title, right.title);
                case "title_desc":
                    return compareResultsText(right.title, left.title);
                case "submitted_desc":
                default:
                    return new Date(right.submittedAt).getTime() - new Date(left.submittedAt).getTime();
            }
        });

        return sorted;
    }

    function filterParentQuizResults(items) {
        const selectedSubject = parentQuizResultsSubjectFilter?.value || "all";
        if (selectedSubject === "all") {
            return [...items];
        }

        return items.filter((item) => String(item.subjectId || "") === selectedSubject);
    }

    function renderParentQuizResultsSubjectFilter(items) {
        if (!parentQuizResultsSubjectFilter) return;

        const options = Array.from(
            new Map(
                items
                    .filter((item) => item.subjectId && item.subjectName)
                    .map((item) => [String(item.subjectId), item.subjectName])
            ).entries()
        );

        const currentValue = parentQuizResultsSubjectFilter.value || "all";
        parentQuizResultsSubjectFilter.innerHTML = `
            <option value="all">All subjects</option>
            ${options.map(([subjectId, subjectName]) => `<option value="${subjectId}">${subjectName}</option>`).join("")}
        `;

        if ([...parentQuizResultsSubjectFilter.options].some((option) => option.value === currentValue)) {
            parentQuizResultsSubjectFilter.value = currentValue;
        }
    }

    function renderParentQuizResults(items) {
        if (!items.length) {
            parentQuizResultsList.innerHTML = `<div class="parent-results-empty">No quiz results yet.</div>`;
            return;
        }

        parentQuizResultsList.innerHTML = `
            <div class="parent-results-row parent-results-head">
                <div>Quiz</div>
                <div>Subject</div>
                <div>Student</div>
                <div>Submitted</div>
                <div>Score</div>
                <div>Status</div>
                <div>Action</div>
            </div>
            ${items.map((item) => `
                <div class="parent-results-row">
                    <div><strong>${item.title}</strong></div>
                    <div>${item.subjectName || "-"}</div>
                    <div>${item.studentName}</div>
                    <div>${new Date(item.submittedAt).toLocaleDateString()}</div>
                    <div class="parent-results-score">${item.score}%</div>
                    <div><span class="parent-results-badge">${item.status}</span></div>
                    <div><a class="parent-list-btn" href="@Url.Action("ParentQuizResultDetail", "Home")?quizResultId=${encodeURIComponent(item.quizResultId)}">View detail</a></div>
                </div>
            `).join("")}
        `;
    }

    async function loadParentQuizResults() {
        if (!token) {
            window.location.replace('@Url.Action("Login", "Home")');
            return;
        }

        if (role && role !== "Parent") {
            window.location.replace('@Url.Action("Teacher", "Home")');
            return;
        }

        const response = await fetch(`${backendBaseUrl}/parents/me/quiz-results`, {
            headers: {
                Authorization: `Bearer ${token}`
            }
        });
        const data = await response.json().catch(() => []);

        if (!response.ok) {
            throw new Error(data?.message || "Unable to load quiz results.");
        }

        parentQuizResultsState = Array.isArray(data) ? data : [];
        renderParentQuizResultsSubjectFilter(parentQuizResultsState);
        renderParentQuizResults(sortParentQuizResults(filterParentQuizResults(parentQuizResultsState)));
    }

    loadParentQuizResults().catch((error) => {
        parentQuizResultsList.innerHTML = `<div class="parent-results-empty">${error.message || "Unable to load quiz results."}</div>`;
    });

    parentQuizResultsSort?.addEventListener("change", () => {
        renderParentQuizResults(sortParentQuizResults(filterParentQuizResults(parentQuizResultsState)));
    });

    parentQuizResultsSubjectFilter?.addEventListener("change", () => {
        renderParentQuizResults(sortParentQuizResults(filterParentQuizResults(parentQuizResultsState)));
    });
</script>
