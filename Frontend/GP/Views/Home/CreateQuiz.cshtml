@{
    ViewData["Title"] = "Create Quiz";
}

<style>
    .quiz-builder {
        max-width: 1100px;
        margin: 0 auto;
        padding: 28px;
    }

    .quiz-builder-card,
    .quiz-question-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 22px;
        box-shadow: 0 10px 28px rgba(17,30,39,.05);
    }

    .quiz-builder-card {
        padding: 26px;
        margin-bottom: 18px;
    }

    .quiz-question-card {
        padding: 22px;
        margin-bottom: 16px;
    }

    .quiz-page-title {
        font-size: 34px;
        font-weight: 800;
        margin-bottom: 8px;
        color: #111E27;
    }

    .quiz-page-subtitle {
        color: #6b7280;
        margin-bottom: 22px;
    }

    .quiz-grid {
        display: grid;
        gap: 14px;
    }

    .quiz-label {
        display: block;
        font-size: 13px;
        font-weight: 700;
        color: #4b5563;
        margin-bottom: 8px;
    }

    .quiz-input,
    .quiz-select,
    .quiz-textarea {
        width: 100%;
        border: 1px solid #dbe3f0;
        border-radius: 14px;
        padding: 12px 14px;
        font-size: 14px;
        outline: none;
        background: #fff;
    }

    .quiz-textarea {
        min-height: 96px;
        resize: vertical;
    }

    .quiz-option-row {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 10px;
        align-items: center;
        margin-bottom: 10px;
    }

    .quiz-radio {
        width: 18px;
        height: 18px;
    }

    .quiz-btn-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 22px;
    }

    .quiz-btn {
        border: none;
        border-radius: 14px;
        padding: 12px 18px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .quiz-btn-primary {
        background: linear-gradient(135deg,#82CBFF,#6DC2FF);
        color: #fff;
    }

    .quiz-btn-soft {
        background: #eef2ff;
        color: #46A3E5;
    }

    .quiz-btn-outline {
        border: 1px solid #dbe3f0;
        color: #374151;
        background: #fff;
    }

    .quiz-question-head {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
        margin-bottom: 14px;
    }

    .quiz-question-title {
        font-size: 20px;
        font-weight: 800;
        color: #111E27;
    }

    .quiz-helper {
        color: #6b7280;
        font-size: 13px;
    }

    .quiz-counter {
        margin-top: 8px;
        color: #6b7280;
        font-size: 12px;
        text-align: right;
    }

    .quiz-file-input {
        width: 100%;
        border: 1px solid #dbe3f0;
        border-radius: 14px;
        padding: 10px 12px;
        background: #fff;
    }

    .quiz-source-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .quiz-source-btn {
        border: 1px solid #dbe3f0;
        border-radius: 14px;
        padding: 12px 16px;
        background: #fff;
        color: #374151;
        font-weight: 700;
        cursor: pointer;
    }

    .quiz-source-btn.active {
        background: #eef2ff;
        color: #46A3E5;
        border-color: #c7d2fe;
    }

    .quiz-library-panel {
        margin-top: 18px;
        border-top: 1px solid #eef2f7;
        padding-top: 18px;
    }

    .quiz-library-grid {
        display: grid;
        gap: 12px;
    }

    .quiz-library-card {
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 16px;
        background: #fff;
    }

    .quiz-library-card h4 {
        font-size: 18px;
        font-weight: 800;
        color: #111E27;
        margin-bottom: 6px;
    }

    .quiz-library-meta {
        color: #6b7280;
        font-size: 13px;
        margin-bottom: 10px;
    }

    .quiz-library-card p {
        color: #4b5563;
        margin-bottom: 14px;
    }

    .quiz-error {
        margin-top: 14px;
        color: #dc2626;
        font-weight: 600;
    }
</style>

<div class="teacher-shell">
    <partial name="_TeacherSidebar" />
    <div class="teacher-shell-content">
        <div class="quiz-builder">
            <div class="quiz-builder-card">
                <div class="quiz-page-title">Create Quiz</div>
                <div class="quiz-page-subtitle">Build the quiz and save it.</div>

                <div class="quiz-source-row">
                    <button id="manualSourceBtn" class="quiz-source-btn active" type="button">Build manually</button>
                    <button id="librarySourceBtn" class="quiz-source-btn" type="button">Choose from our library</button>
                </div>

                <div class="quiz-grid">
                    <div>
                        <label class="quiz-label" for="quizSubjectSelect">Subject</label>
                        <select id="quizSubjectSelect" class="quiz-select">
                            <option value="2">Arabic</option>
                            <option value="1">Mathematics</option>
                        </select>
                    </div>

                    <div>
                        <label class="quiz-label" for="quizTitleInput">Quiz title</label>
                        <input id="quizTitleInput" class="quiz-input" type="text" maxlength="120" placeholder="Example: Writing support quiz" />
                        <div class="quiz-counter" data-counter-for="quizTitleInput">0 / 120</div>
                    </div>

                    <div>
                        <label class="quiz-label" for="quizSkillInput">Skill focus</label>
                        <input id="quizSkillInput" class="quiz-input" type="text" maxlength="120" placeholder="Example: Writing" />
                        <div class="quiz-counter" data-counter-for="quizSkillInput">0 / 120</div>
                    </div>
                </div>

                <div id="libraryPanel" class="quiz-library-panel d-none">
                    <div class="quiz-label">Quiz library</div>
                    <div class="quiz-helper" style="margin-bottom:12px;">Library templates load as editable drafts. Add multiple-choice options if you want auto-grading.</div>
                    <div id="libraryState" class="quiz-helper">Loading templates...</div>
                    <div id="libraryTemplates" class="quiz-library-grid"></div>
                </div>
            </div>

            <div id="questionsContainer"></div>

            <div class="quiz-builder-card">
                <button id="addQuestionBtn" class="quiz-btn quiz-btn-soft" type="button">Add question</button>
                <div id="quizError" class="quiz-error d-none"></div>
                <div class="quiz-btn-row">
                    <a class="quiz-btn quiz-btn-outline" href="@Url.Action("WeakStudents", "Home")">Back</a>
                    <button id="nextToPublishBtn" class="quiz-btn quiz-btn-primary" type="button">Next: Publish quiz</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    window.bridgeBackendBaseUrl = window.bridgeBackendBaseUrl || "http://localhost:3000";
    const backendBaseUrl = window.bridgeBackendBaseUrl;
    const questionsContainer = document.getElementById("questionsContainer");
    const addQuestionBtn = document.getElementById("addQuestionBtn");
    const nextToPublishBtn = document.getElementById("nextToPublishBtn");
    const quizError = document.getElementById("quizError");
    const quizSubjectSelect = document.getElementById("quizSubjectSelect");
    const quizTitleInput = document.getElementById("quizTitleInput");
    const quizSkillInput = document.getElementById("quizSkillInput");
    const manualSourceBtn = document.getElementById("manualSourceBtn");
    const librarySourceBtn = document.getElementById("librarySourceBtn");
    const libraryPanel = document.getElementById("libraryPanel");
    const libraryState = document.getElementById("libraryState");
    const libraryTemplates = document.getElementById("libraryTemplates");
    const token = sessionStorage.getItem("bridgeAccessToken");
    let questionIndex = 0;
    let libraryLoaded = false;
    let libraryTemplatesState = [];

    function getSelectedSubjectId() {
        return quizSubjectSelect?.value || localStorage.getItem("teacherSelectedSubject") || "2";
    }

    function getSelectedSubjectLabel() {
        return getSelectedSubjectId() === "1" ? "Mathematics" : "Arabic";
    }

    function getSkillFromQuery() {
        const params = new URLSearchParams(window.location.search);
        return params.get("skill") || "";
    }

    function getTargetTypeFromQuery() {
        const params = new URLSearchParams(window.location.search);
        return params.get("targetType") || "";
    }

    function getSelectedStudentIdsFromQuery() {
        const params = new URLSearchParams(window.location.search);
        return params.getAll("studentId").filter(Boolean);
    }

    function showQuizError(message) {
        quizError.textContent = message;
        quizError.classList.remove("d-none");
    }

    function hideQuizError() {
        quizError.classList.add("d-none");
    }

    function attachInlineCounter(input, counter) {
        if (!input || !counter) {
            return;
        }

        const maxLength = Number(input.getAttribute("maxlength") || "0");
        const sync = () => {
            counter.textContent = `${input.value.length} / ${maxLength}`;
        };

        input.addEventListener("input", sync);
        sync();
    }

    function attachCounter(inputId) {
        const input = document.getElementById(inputId);
        const counter = document.querySelector(`[data-counter-for="${inputId}"]`);
        attachInlineCounter(input, counter);
    }

    function setSourceMode(mode) {
        const isLibrary = mode === "library";
        manualSourceBtn.classList.toggle("active", !isLibrary);
        librarySourceBtn.classList.toggle("active", isLibrary);
        libraryPanel.classList.toggle("d-none", !isLibrary);

        if (isLibrary && !libraryLoaded) {
            loadLibraryTemplates();
        }
    }

    function createOptionRow(questionId, optionIndex, optionText = "", isCorrect = false) {
        const row = document.createElement("div");
        row.className = "quiz-option-row";
        row.innerHTML = `
            <input class="quiz-radio" type="radio" name="correct-${questionId}" ${isCorrect ? "checked" : ""} />
            <div>
                <input class="quiz-input js-option-input" type="text" maxlength="200" placeholder="Option ${optionIndex + 1}" value="${optionText.replace(/"/g, "&quot;")}" />
                <div class="quiz-counter js-option-counter">0 / 200</div>
            </div>
            <button class="quiz-btn quiz-btn-outline" type="button">Remove</button>
        `;

        row.querySelector("button").addEventListener("click", () => {
            row.remove();
        });

        attachInlineCounter(
            row.querySelector(".js-option-input"),
            row.querySelector(".js-option-counter"),
        );

        return row;
    }

    function addQuestionCard(initialData) {
        questionIndex += 1;
        const questionId = `question-${questionIndex}`;
        const type = initialData?.type || "MULTIPLE_CHOICE";
        const card = document.createElement("div");
        card.className = "quiz-question-card";
        card.dataset.questionId = questionId;
        card.innerHTML = `
            <div class="quiz-question-head">
                <div>
                    <div class="quiz-question-title">Question ${questionIndex}</div>
                    <div class="quiz-helper">Multiple choice questions support auto-grading. Essay questions are stored for manual review.</div>
                </div>
                <button class="quiz-btn quiz-btn-outline" type="button">Remove question</button>
            </div>
            <div class="quiz-grid">
                <div>
                    <label class="quiz-label">Question prompt</label>
                    <textarea class="quiz-textarea question-prompt" maxlength="1000" placeholder="Write the question here...">${initialData?.prompt || ""}</textarea>
                    <div class="quiz-counter">0 / 1000</div>
                </div>
                <div>
                    <label class="quiz-label">Question type</label>
                    <select class="quiz-select question-type">
                        <option value="MULTIPLE_CHOICE" ${type === "MULTIPLE_CHOICE" ? "selected" : ""}>Multiple choice</option>
                        <option value="ESSAY" ${type === "ESSAY" ? "selected" : ""}>Essay</option>
                    </select>
                </div>
                <div class="essay-settings-block">
                    <label class="quiz-label">Teacher question attachments</label>
                    <input class="quiz-file-input essay-question-attachments" type="file" multiple />
                    <div class="quiz-helper" style="margin-top:8px;">Attach files for the teacher question itself. Essay answers are limited to 500 characters.</div>
                </div>
                <div class="options-block">
                    <label class="quiz-label">Options</label>
                    <div class="options-list"></div>
                    <button class="quiz-btn quiz-btn-soft add-option-btn" type="button">Add option</button>
                </div>
            </div>
        `;

        const removeQuestionBtn = card.querySelector(".quiz-question-head button");
        const typeSelect = card.querySelector(".question-type");
        const optionsBlock = card.querySelector(".options-block");
        const essaySettingsBlock = card.querySelector(".essay-settings-block");
        const optionsList = card.querySelector(".options-list");
        const addOptionButton = card.querySelector(".add-option-btn");
        const promptField = card.querySelector(".question-prompt");
        const promptCounter = card.querySelector(".quiz-counter");

        function syncOptionsVisibility() {
            const isMcq = typeSelect.value === "MULTIPLE_CHOICE";
            optionsBlock.style.display = isMcq ? "block" : "none";
            essaySettingsBlock.style.display = isMcq ? "none" : "block";
            if (isMcq && !optionsList.children.length) {
                optionsList.appendChild(createOptionRow(questionId, 0, "", true));
                optionsList.appendChild(createOptionRow(questionId, 1));
            }
        }

        addOptionButton.addEventListener("click", () => {
            optionsList.appendChild(
                createOptionRow(questionId, optionsList.children.length)
            );
        });

        removeQuestionBtn.addEventListener("click", () => {
            card.remove();
        });

        typeSelect.addEventListener("change", syncOptionsVisibility);
        attachInlineCounter(promptField, promptCounter);

        if (Array.isArray(initialData?.options) && initialData.options.length) {
            initialData.options.forEach((option, optionIndex) => {
                optionsList.appendChild(
                    createOptionRow(questionId, optionIndex, option.text, option.isCorrect)
                );
            });
        }

        syncOptionsVisibility();
        questionsContainer.appendChild(card);
    }

    function resetQuestions() {
        questionsContainer.innerHTML = "";
        questionIndex = 0;
    }

    function loadTemplateIntoBuilder(template) {
        if (!template) return;

        quizTitleInput.value = template.title;
        quizSkillInput.value = template.skillName;
        resetQuestions();

        (template.questions || []).forEach((question) => {
            addQuestionCard({
                prompt: question.prompt,
                type: question.type,
                options: question.options || []
            });
        });

        if (!template.questions?.length) {
            addQuestionCard();
        }

        hideQuizError();
        setSourceMode("manual");
        window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function renderLibraryTemplates() {
        if (!libraryTemplatesState.length) {
            libraryState.textContent = "No library templates match the current skill.";
            libraryTemplates.innerHTML = "";
            return;
        }

        libraryState.textContent = `${libraryTemplatesState.length} template(s) available.`;
        libraryTemplates.innerHTML = libraryTemplatesState.map((template) => `
            <article class="quiz-library-card">
                <h4>${template.title}</h4>
                <div class="quiz-library-meta">
                    ${template.subjectId === "1" ? "Mathematics" : "Arabic"} •
                    ${template.skillName} •
                    ${template.questionCount} questions •
                    Difficulty ${Number(template.difficulty ?? 0) || "-"}
                </div>
                <p>${template.description || "Prepared support-program template."}</p>
                <div class="quiz-helper" style="margin-bottom:10px;">
                    <strong>Supports:</strong> ${(template.supportedSkills || [template.skillName]).join(", ")}
                </div>
                ${Array.isArray(template.exercises) && template.exercises.length ? `
                    <div class="quiz-helper" style="margin-bottom:12px;">
                        <strong>Exercises:</strong>
                        <ul style="margin:8px 0 0 18px; padding:0;">
                            ${template.exercises.slice(0, 5).map((exercise) => `
                                <li>
                                    ${exercise.title}
                                    <span class="text-secondary">(${(exercise.supportedSkills || []).join(", ") || "General"} • Difficulty ${Number(exercise.difficulty ?? 0) || "-"} • ${exercise.estimatedTime ?? "TBD"})</span>
                                </li>
                            `).join("")}
                        </ul>
                    </div>
                ` : ""}
                <button class="quiz-btn quiz-btn-soft js-use-template" type="button" data-template-id="${template.templateId}">Use this template</button>
            </article>
        `).join("");

        libraryTemplates.querySelectorAll(".js-use-template").forEach((button) => {
            button.addEventListener("click", () => {
                const template = libraryTemplatesState.find((entry) => entry.templateId === button.dataset.templateId);
                loadTemplateIntoBuilder(template);
            });
        });
    }

    async function loadLibraryTemplates() {
        if (!token) {
            libraryState.textContent = "You need to be logged in to load the quiz library.";
            return;
        }

        libraryState.textContent = "Loading templates...";
        libraryTemplates.innerHTML = "";

        try {
            const params = new URLSearchParams({ subjectId: getSelectedSubjectId() });
            const skill = getSkillFromQuery();
            if (skill) {
                params.set("skillId", skill);
            }

            const response = await fetch(`${backendBaseUrl}/quizzes/library?${params.toString()}`, {
                headers: {
                    Authorization: `Bearer ${token}`
                }
            });
            const data = await response.json().catch(() => []);

            if (!response.ok) {
                throw new Error(data?.message || "Unable to load quiz library.");
            }

            libraryTemplatesState = Array.isArray(data) ? data : [];
            libraryLoaded = true;
            renderLibraryTemplates();
        } catch (error) {
            libraryState.textContent = error.message || "Unable to load quiz library.";
            libraryTemplates.innerHTML = "";
        }
    }

    function collectDraft() {
        const title = quizTitleInput.value.trim();
        const skill = quizSkillInput.value.trim();
        const questionCards = [...questionsContainer.querySelectorAll(".quiz-question-card")];

        if (!title) {
            throw new Error("Quiz title is required.");
        }

        if (!questionCards.length) {
            throw new Error("Add at least one question.");
        }

        const questions = questionCards.map((card, index) => {
            const prompt = card.querySelector(".question-prompt").value.trim();
            const type = card.querySelector(".question-type").value;
            const questionId = card.dataset.questionId;

            if (!prompt) {
                throw new Error(`Question ${index + 1} needs a prompt.`);
            }

            if (type === "ESSAY") {
                return {
                    prompt,
                    type,
                    options: [],
                    attachmentFieldKey: `questionAttachment_${questionId}`
                };
            }

            const optionRows = [...card.querySelectorAll(".options-list .quiz-option-row")];
            const options = optionRows.map((row) => ({
                text: row.querySelector(".js-option-input").value.trim(),
                isCorrect: row.querySelector(".quiz-radio").checked
            })).filter((option) => option.text);

            if (options.length < 2) {
                throw new Error(`Question ${index + 1} needs at least two options.`);
            }

            const correctCount = options.filter((option) => option.isCorrect).length;
            if (correctCount !== 1) {
                throw new Error(`Question ${index + 1} must have exactly one correct answer.`);
            }

            return {
                prompt,
                type,
                options
            };
        });

        return {
            title,
            skill,
            subjectId: getSelectedSubjectId(),
            recommendedTargetType: getTargetTypeFromQuery() || undefined,
            recommendedTargetStudentIds: getSelectedStudentIdsFromQuery(),
            questions
        };
    }

    addQuestionBtn.addEventListener("click", () => addQuestionCard());
    manualSourceBtn.addEventListener("click", () => setSourceMode("manual"));
    librarySourceBtn.addEventListener("click", () => setSourceMode("library"));
    quizSubjectSelect?.addEventListener("change", () => {
        localStorage.setItem("teacherSelectedSubject", getSelectedSubjectId());
        libraryLoaded = false;
        libraryTemplatesState = [];
        libraryTemplates.innerHTML = "";
        libraryState.textContent = "Loading templates...";
        if (librarySourceBtn.classList.contains("active")) {
            loadLibraryTemplates();
        }
    });

    nextToPublishBtn.addEventListener("click", async () => {
        hideQuizError();

        try {
            const draft = collectDraft();

            if (!token) {
                throw new Error("You need to be signed in to create a quiz.");
            }

            nextToPublishBtn.disabled = true;
            nextToPublishBtn.textContent = "Creating...";

            const response = await fetch(`${backendBaseUrl}/quizzes`, {
                method: "POST",
                headers: {
                    Authorization: `Bearer ${token}`
                },
                body: (() => {
                    const formData = new FormData();
                    formData.append("draft", JSON.stringify({
                        title: draft.title,
                        subjectId: draft.subjectId,
                        skillFocus: draft.skill,
                        questions: draft.questions
                    }));

                    [...questionsContainer.querySelectorAll(".quiz-question-card")].forEach((card) => {
                        const type = card.querySelector(".question-type")?.value;
                        if (type !== "ESSAY") {
                            return;
                        }

                        const questionId = card.dataset.questionId;
                        const attachmentsInput = card.querySelector(".essay-question-attachments");
                        Array.from(attachmentsInput?.files || []).forEach((file) => {
                            formData.append(`questionAttachment_${questionId}`, file);
                        });
                    });

                    return formData;
                })()
            });

            const data = await response.json().catch(() => null);
            if (!response.ok) {
                throw new Error(data?.message || "Unable to create quiz.");
            }

            sessionStorage.setItem("bridgeQuizDraft", JSON.stringify({
                ...draft,
                quizId: data?.quizId || null
            }));
            window.location.href = '@Url.Action("PublishQuiz", "Home")';
        } catch (error) {
            showQuizError(error.message || "Unable to continue.");
        } finally {
            nextToPublishBtn.disabled = false;
            nextToPublishBtn.textContent = "Next: Publish quiz";
        }
    });

    const initialSkill = getSkillFromQuery();
    const initialSubjectId = localStorage.getItem("teacherSelectedSubject") || "2";
    if (quizSubjectSelect) {
        quizSubjectSelect.value = initialSubjectId;
    }
    if (initialSkill) {
        quizSkillInput.value = initialSkill;
        quizTitleInput.value = `${initialSkill} ${getSelectedSubjectLabel()} quiz`;
    }

    ["quizTitleInput", "quizSkillInput"].forEach(attachCounter);
    addQuestionCard();
</script>
