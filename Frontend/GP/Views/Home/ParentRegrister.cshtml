@{
    ViewData["Title"] = "ParentRegrister";
}

<style>
    .auth-password-wrap {
        position: relative;
        display: block;
        width: 100%;
    }

    .auth-password-wrap .form-control {
        padding-right: 3rem;
        width: 100%;
    }

    .auth-password-toggle {
        position: absolute !important;
        top: 50%;
        right: 0.85rem;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        color: #6b7280;
        padding: 0;
        width: 1.5rem;
        height: 1.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
        margin: 0;
        z-index: 3;
    }

    .auth-password-toggle svg {
        width: 1.1rem;
        height: 1.1rem;
        stroke: currentColor;
        fill: none;
        stroke-width: 1.8;
    }

    .auth-password-toggle.is-visible svg {
        opacity: 0.65;
    }

    .auth-password-rules {
        margin: 0.6rem 0 0;
        padding-left: 1rem;
        color: #6b7280;
        font-size: 0.85rem;
    }

    .auth-password-rules li + li {
        margin-top: 0.2rem;
    }

    .auth-password-rules li.is-valid {
        color: #166534;
        font-weight: 700;
    }
</style>

<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-lg-6">
            <h1 class="fw-bold mb-1">Create parent account</h1>
            <p class="text-secondary mb-4">Link yourself to your child using the parent student code.</p>

            <div id="parentErrorBox" class="alert alert-danger d-none"></div>

            <form id="parentRegisterForm">
                <div class="row ms-1 me-1 pt-3">
                    <div class="mb-3 col-12">
                        <input type="text" id="parentNameInput" class="form-control p-3" placeholder="Full Name">
                    </div>

                    <div class="mb-3 col-6">
                        <input type="email" id="parentEmailInput" class="form-control p-3" placeholder="Email Address">
                    </div>
                    <div class="mb-3 col-6">
                        <input type="tel" id="parentPhoneInput" class="form-control p-3" placeholder="Phone Number">
                    </div>
                    <div class="mb-3 col-6">
                        <select id="parentTypeInput" class="form-select p-3">
                            <option value="">Choose relation</option>
                            <option value="Father">Father</option>
                            <option value="Mother">Mother</option>
                            <option value="Guardian">Guardian</option>
                        </select>
                    </div>
                    <div class="mb-3 col-6">
                        <input type="text" id="parentStudentCodeInput" class="form-control p-3" placeholder="Parent Student Code">
                    </div>
                    <div class="mb-3 col-6">
                        <div class="auth-password-wrap">
                            <input type="password" id="parentPasswordInput" class="form-control p-3" placeholder="Password">
                            <button type="button" class="auth-password-toggle" id="parentPasswordToggle" aria-label="Show password" title="Show password">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                            </button>
                        </div>
                        <ul class="auth-password-rules">
                            <li id="parentRuleLength">At least 8 characters</li>
                            <li id="parentRuleUpper">At least 1 uppercase letter</li>
                            <li id="parentRuleLower">At least 1 lowercase letter</li>
                            <li id="parentRuleNumber">At least 1 number</li>
                        </ul>
                        <small id="parentPasswordStrength" class="fw-semibold"></small>
                    </div>
                    <div class="mb-3 col-6">
                        <div class="auth-password-wrap">
                            <input type="password" id="parentConfirmPasswordInput" class="form-control p-3" placeholder="Confirm Password">
                            <button type="button" class="auth-password-toggle" id="parentConfirmPasswordToggle" aria-label="Show password" title="Show password">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                            </button>
                        </div>
                        <small id="parentMatchText" class="fw-semibold"></small>
                    </div>

                    <div class="d-flex gap-3 mb-4">
                        <button type="submit"
                                class="btn px-4 text-white"
                                id="parentRegisterBtn"
                                style="background:#c9c6ff">
                            Next →
                        </button>

                        <a class="btn px-4"
                           style="border:1px solid #c9c6ff;color:#c9c6ff"
                           asp-action="Index"
                           asp-controller="Home">
                            Back
                        </a>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-lg-6 text-center">
            <img src="~/img/illustration.png" class="img-fluid" style="max-height:420px">
        </div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const parentRegisterForm = document.getElementById("parentRegisterForm");
    const parentRegisterBtn = document.getElementById("parentRegisterBtn");
    const parentErrorBox = document.getElementById("parentErrorBox");
    const parentPasswordInput = document.getElementById("parentPasswordInput");
    const parentConfirmPasswordInput = document.getElementById("parentConfirmPasswordInput");
    const parentPasswordStrength = document.getElementById("parentPasswordStrength");
    const parentMatchText = document.getElementById("parentMatchText");
    const parentPasswordToggle = document.getElementById("parentPasswordToggle");
    const parentConfirmPasswordToggle = document.getElementById("parentConfirmPasswordToggle");
    const parentRuleLength = document.getElementById("parentRuleLength");
    const parentRuleUpper = document.getElementById("parentRuleUpper");
    const parentRuleLower = document.getElementById("parentRuleLower");
    const parentRuleNumber = document.getElementById("parentRuleNumber");

    function showParentError(message) {
        parentErrorBox.textContent = message;
        parentErrorBox.classList.remove("d-none");
    }

    function hideParentError() {
        parentErrorBox.classList.add("d-none");
    }

    function togglePasswordVisibility(input, button) {
        const shouldShow = input.type === "password";
        input.type = shouldShow ? "text" : "password";
        button.classList.toggle("is-visible", shouldShow);
        button.setAttribute("aria-label", shouldShow ? "Hide password" : "Show password");
        button.setAttribute("title", shouldShow ? "Hide password" : "Show password");
    }

    function validateParentPassword(value) {
        return {
            length: value.length >= 8,
            upper: /[A-Z]/.test(value),
            lower: /[a-z]/.test(value),
            number: /[0-9]/.test(value)
        };
    }

    function updateParentPasswordState() {
        const value = parentPasswordInput.value;
        const rules = validateParentPassword(value);
        const strength = Object.values(rules).filter(Boolean).length;

        parentRuleLength.classList.toggle("is-valid", rules.length);
        parentRuleUpper.classList.toggle("is-valid", rules.upper);
        parentRuleLower.classList.toggle("is-valid", rules.lower);
        parentRuleNumber.classList.toggle("is-valid", rules.number);

        if (!value.length) {
            parentPasswordStrength.textContent = "";
        } else if (strength <= 2) {
            parentPasswordStrength.textContent = "Weak password";
            parentPasswordStrength.style.color = "red";
        } else if (strength === 3) {
            parentPasswordStrength.textContent = "Medium password";
            parentPasswordStrength.style.color = "orange";
        } else {
            parentPasswordStrength.textContent = "Strong password";
            parentPasswordStrength.style.color = "green";
        }

        if (!parentConfirmPasswordInput.value.length) {
            parentMatchText.textContent = "";
            return;
        }

        if (parentPasswordInput.value === parentConfirmPasswordInput.value) {
            parentMatchText.textContent = "Passwords match";
            parentMatchText.style.color = "green";
        } else {
            parentMatchText.textContent = "Passwords do not match";
            parentMatchText.style.color = "red";
        }
    }

    parentPasswordInput.addEventListener("input", updateParentPasswordState);
    parentConfirmPasswordInput.addEventListener("input", updateParentPasswordState);
    parentPasswordToggle?.addEventListener("click", () => togglePasswordVisibility(parentPasswordInput, parentPasswordToggle));
    parentConfirmPasswordToggle?.addEventListener("click", () => togglePasswordVisibility(parentConfirmPasswordInput, parentConfirmPasswordToggle));

    parentRegisterForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        hideParentError();

        const payload = {
            userFullName: document.getElementById("parentNameInput").value.trim(),
            email: document.getElementById("parentEmailInput").value.trim(),
            phoneNumber: document.getElementById("parentPhoneInput").value.trim() || undefined,
            parentType: document.getElementById("parentTypeInput").value,
            parentStudentCode: document.getElementById("parentStudentCodeInput").value.trim(),
            password: parentPasswordInput.value
        };

        if (!payload.userFullName || !payload.email || !payload.parentType || !payload.parentStudentCode || !payload.password) {
            showParentError("Please complete all required parent registration fields.");
            return;
        }

        if (payload.password !== parentConfirmPasswordInput.value) {
            showParentError("Passwords do not match.");
            return;
        }

        const passwordRules = validateParentPassword(payload.password);
        if (!Object.values(passwordRules).every(Boolean)) {
            showParentError("Password must be at least 8 characters and include uppercase, lowercase, and a number.");
            return;
        }

        parentRegisterBtn.disabled = true;

        try {
            const response = await fetch(`${backendBaseUrl}/auth/signup/parent`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(payload)
            });

            const data = await response.json().catch(() => null);
            if (!response.ok) {
                const message = Array.isArray(data?.message) ? data.message.join(", ") : data?.message;
                throw new Error(message || "Unable to create parent account.");
            }

            if (data?.access_token) {
                sessionStorage.setItem("bridgeAccessToken", data.access_token);
            }
            sessionStorage.setItem("bridgeUserRole", "Parent");
            sessionStorage.setItem("bridgeUserName", payload.userFullName);
            sessionStorage.removeItem("bridgePendingTeacherSetup");
            sessionStorage.removeItem("bridgeTeacherSetupComplete");
            sessionStorage.setItem("bridgeVerificationRole", "parent");
            window.location.href = '@Url.Action("Verification", "Home")';
        } catch (error) {
            showParentError(error.message || "Unable to connect to the server.");
        } finally {
            parentRegisterBtn.disabled = false;
        }
    });
</script>
