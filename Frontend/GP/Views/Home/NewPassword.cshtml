@{
    ViewData["Title"] = "New Password";
}

<style>
    .reset-password-shell {
        min-height: calc(100vh - 9rem);
        display: flex;
        align-items: center;
        padding: 2rem 0 3rem;
    }

    .reset-password-card {
        width: 100%;
        max-width: 42rem;
        padding: 2.25rem;
        border: 1px solid rgba(168, 164, 217, 0.26);
        border-radius: 1.75rem;
        background: rgba(255, 255, 255, 0.84);
        box-shadow: 0 24px 48px rgba(86, 97, 122, 0.12);
        backdrop-filter: blur(10px);
    }

    .reset-password-kicker {
        margin-bottom: 0.5rem;
        color: #7b6ee6;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .reset-password-title {
        margin-bottom: 0.65rem;
        color: #20202b;
        font-size: clamp(2rem, 3vw, 2.65rem);
        font-weight: 800;
        line-height: 1.05;
    }

    .reset-password-copy {
        margin-bottom: 1.5rem;
        color: #6b7280;
        font-size: 1rem;
        line-height: 1.7;
    }

    .reset-password-card .form-control {
        min-height: 3.6rem;
        border-radius: 1rem;
        border-color: rgba(168, 164, 217, 0.4);
        padding: 1rem 1.1rem;
    }

    .reset-password-card .form-label {
        margin-bottom: 0.55rem;
        color: #3b4151;
        font-weight: 700;
    }

    .reset-password-status {
        border-radius: 1rem;
        padding: 0.95rem 1rem;
        font-weight: 600;
    }

    .reset-password-form {
        padding: 0 !important;
        border: 0 !important;
        border-radius: 0 !important;
        background: transparent !important;
        box-shadow: none !important;
        backdrop-filter: none !important;
    }

    .reset-password-actions {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
    }

    .reset-password-primary,
    .reset-password-secondary {
        min-height: 3rem;
        padding: 0.8rem 1.3rem;
        border-radius: 999px;
        font-weight: 700;
        text-decoration: none;
    }

    .reset-password-primary {
        border: none;
        background: linear-gradient(135deg, #c8c5ff 0%, #8f6de5 100%);
        color: #fff;
        box-shadow: 0 18px 30px rgba(143, 109, 229, 0.2);
    }

    .reset-password-primary:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .reset-password-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #c9c6ff;
        background: #fff;
        color: #8f6de5;
    }

    .reset-password-hint {
        min-height: 1.5rem;
        margin-top: 0.55rem;
        font-weight: 600;
    }

    @@media (max-width: 767.98px) {
        .reset-password-shell {
            min-height: auto;
            padding-top: 1rem;
        }

        .reset-password-card {
            padding: 1.4rem;
            border-radius: 1.25rem;
        }

        .reset-password-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .reset-password-primary,
        .reset-password-secondary {
            width: 100%;
        }
    }
</style>

<div class="container reset-password-shell">
    <div class="row justify-content-center w-100">
        <div class="col-xl-6 col-lg-7 col-md-9">
            <div class="reset-password-card">
                <div class="reset-password-kicker">Account Recovery</div>
                <h1 class="reset-password-title">Set a new password</h1>
                <p class="reset-password-copy">
                    Enter the reset code from your email, then choose a new password for your account.
                </p>

                <div id="resetErrorBox" class="alert alert-danger reset-password-status d-none"></div>
                <div id="resetSuccessBox" class="alert alert-success reset-password-status d-none"></div>

                <form id="resetPasswordForm" class="reset-password-form">
                    <div class="mb-3">
                        <label class="form-label" for="resetCodeInput">Reset code</label>
                        <input type="text"
                               id="resetCodeInput"
                               class="form-control"
                               placeholder="Enter the 6-digit code">
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="newPasswordInput">Password</label>
                            <input type="password"
                                   id="newPasswordInput"
                                   class="form-control"
                                   placeholder="Enter your new password">
                            <small id="passwordStrength" class="reset-password-hint d-block"></small>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="confirmPasswordInput">Confirm Password</label>
                            <input type="password"
                                   id="confirmPasswordInput"
                                   class="form-control"
                                   placeholder="Re-enter your new password">
                            <small id="matchText" class="reset-password-hint d-block"></small>
                        </div>
                    </div>

                    <div class="reset-password-actions">
                        <button type="submit"
                                class="reset-password-primary"
                                id="resetPasswordBtn">
                            Save Password
                        </button>
                        <a asp-action="Login" asp-controller="Home" class="reset-password-secondary">Back to Login</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const resetPasswordForm = document.getElementById("resetPasswordForm");
    const resetPasswordBtn = document.getElementById("resetPasswordBtn");
    const resetCodeInput = document.getElementById("resetCodeInput");
    const newPasswordInput = document.getElementById("newPasswordInput");
    const confirmPasswordInput = document.getElementById("confirmPasswordInput");
    const passwordStrength = document.getElementById("passwordStrength");
    const matchText = document.getElementById("matchText");
    const resetErrorBox = document.getElementById("resetErrorBox");
    const resetSuccessBox = document.getElementById("resetSuccessBox");

    function showResetError(message) {
        resetSuccessBox.classList.add("d-none");
        resetErrorBox.textContent = message;
        resetErrorBox.classList.remove("d-none");
    }

    function showResetSuccess(message) {
        resetErrorBox.classList.add("d-none");
        resetSuccessBox.textContent = message;
        resetSuccessBox.classList.remove("d-none");
    }

    function updatePasswordHints() {
        const value = newPasswordInput.value;
        let strength = 0;

        if (value.length >= 8) strength++;
        if (/[A-Z]/.test(value)) strength++;
        if (/[a-z]/.test(value)) strength++;
        if (/[0-9]/.test(value)) strength++;

        if (!value.length) {
            passwordStrength.textContent = "";
        } else if (strength <= 2) {
            passwordStrength.textContent = "Weak password";
            passwordStrength.style.color = "red";
        } else if (strength === 3) {
            passwordStrength.textContent = "Medium password";
            passwordStrength.style.color = "orange";
        } else {
            passwordStrength.textContent = "Strong password";
            passwordStrength.style.color = "green";
        }

        if (!confirmPasswordInput.value.length) {
            matchText.textContent = "";
            return;
        }

        if (newPasswordInput.value === confirmPasswordInput.value) {
            matchText.textContent = "Passwords match";
            matchText.style.color = "green";
        } else {
            matchText.textContent = "Passwords do not match";
            matchText.style.color = "red";
        }
    }

    newPasswordInput.addEventListener("input", updatePasswordHints);
    confirmPasswordInput.addEventListener("input", updatePasswordHints);

    resetPasswordForm.addEventListener("submit", async (event) => {
        event.preventDefault();

        const token = resetCodeInput.value.trim();
        const newPassword = newPasswordInput.value;

        if (!token || !newPassword || !confirmPasswordInput.value) {
            showResetError("Please complete the reset code and both password fields.");
            return;
        }

        if (newPassword !== confirmPasswordInput.value) {
            showResetError("Passwords do not match.");
            return;
        }

        resetPasswordBtn.disabled = true;
        resetPasswordBtn.textContent = "Saving...";

        try {
            const response = await fetch(`${backendBaseUrl}/auth/reset-password`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    token,
                    newPassword
                })
            });

            const data = await response.json().catch(() => null);
            if (!response.ok) {
                const message = Array.isArray(data?.message) ? data.message.join(", ") : data?.message;
                throw new Error(message || "Unable to reset password.");
            }

            showResetSuccess(data?.message || "Password has been reset successfully.");
            setTimeout(() => {
                window.location.href = '@Url.Action("Login", "Home")';
            }, 1200);
        } catch (error) {
            showResetError(error.message || "Unable to connect to the server.");
        } finally {
            resetPasswordBtn.disabled = false;
            resetPasswordBtn.textContent = "Save Password";
        }
    });
</script>
