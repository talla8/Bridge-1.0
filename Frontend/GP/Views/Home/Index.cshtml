@{
    ViewData["Title"] = "Home Page";
}

<style>
    /* ===== Animated study scene (pen + notebooks) ===== */
    .study-scene { position: relative; width: 100%; max-width: 460px; margin: 0 auto; }
    .study-scene svg { width: 100%; height: auto; overflow: visible; }
    .bridge-home-hero-title {
        font-size: clamp(2.4rem, 5vw, 4.25rem);
        letter-spacing: -0.04em;
    }
    .bridge-home-hero-copy {
        max-width: 38rem;
        font-size: 1.08rem;
    }
    .bridge-home-role-list {
        flex-wrap: wrap;
    }
    .bridge-home-role-list .role-box {
        min-width: 10rem;
        justify-content: center;
    }
    .bridge-home-start-btn {
        min-width: 12rem;
    }
    .ss-float { animation: ssFloat 4.5s ease-in-out infinite; transform-box: fill-box; transform-origin: center; }
    .ss-float.d1 { animation-delay: .8s; }
    .ss-float.d2 { animation-delay: 1.6s; }
    .ss-float.d3 { animation-delay: 2.2s; }
    @@keyframes ssFloat { 0%,100% { transform: translateY(0) rotate(var(--r,0deg)); } 50% { transform: translateY(-10px) rotate(var(--r,0deg)); } }
    .ss-pen { animation: ssWrite 3.6s ease-in-out infinite; transform-box: fill-box; transform-origin: 80% 90%; }
    @@keyframes ssWrite {
        0%   { transform: translate(0,0) rotate(-8deg); }
        25%  { transform: translate(44px,3px) rotate(-8deg); }
        50%  { transform: translate(88px,0) rotate(-8deg); }
        62%  { transform: translate(92px,-2px) rotate(-8deg); }
        100% { transform: translate(0,0) rotate(-8deg); }
    }
    .ss-ink { stroke-dasharray: 240; stroke-dashoffset: 240; animation: ssInk 3.6s ease-in-out infinite; }
    @@keyframes ssInk {
        0%   { stroke-dashoffset: 240; }
        55%  { stroke-dashoffset: 0; }
        78%  { stroke-dashoffset: 0; opacity: 1; }
        86%  { opacity: 0; }
        87%  { stroke-dashoffset: 240; opacity: 0; }
        100% { stroke-dashoffset: 240; opacity: 1; }
    }
    .ss-sparkle { animation: ssSpark 2.8s ease-in-out infinite; transform-box: fill-box; transform-origin: center; }
    .ss-sparkle.s2 { animation-delay: 1.1s; }
    @@keyframes ssSpark { 0%,100% { transform: scale(.4); opacity:.3; } 50% { transform: scale(1); opacity:1; } }

    @@media (max-width: 991.98px) {
        .bridge-home-hero-copy {
            max-width: none;
        }

        .study-scene {
            max-width: 360px;
            margin-top: 0.5rem;
        }
    }

    @@media (max-width: 767.98px) {
        .bridge-home-hero {
            padding-top: 2rem !important;
            padding-bottom: 2rem !important;
        }

        .bridge-home-hero .container {
            padding-top: 0 !important;
            padding-bottom: 0 !important;
        }

        .bridge-home-hero-row {
            gap: 2rem !important;
        }

        .bridge-home-hero-title {
            font-size: clamp(2rem, 10vw, 2.8rem);
            line-height: 1.08;
            margin-bottom: 1rem !important;
        }

        .bridge-home-hero-copy {
            font-size: 1rem;
            line-height: 1.75;
            margin-bottom: 1.5rem !important;
        }

        .bridge-home-role-list {
            display: grid !important;
            grid-template-columns: 1fr;
            gap: 0.75rem !important;
            margin-bottom: 1.5rem !important;
        }

        .bridge-home-role-list .role-box {
            width: 100%;
            min-width: 0;
            justify-content: flex-start;
        }

        .bridge-home-start-btn {
            width: 100%;
            justify-content: center;
        }

        .bridge-home-visual-col {
            order: -1;
        }

        .study-scene {
            max-width: 230px;
            margin: 0 auto 0.5rem;
        }
    }
</style>

<div class="">
    <section class="py-5 bridge-home-hero">
        <div class="container py-4">
            <div class="row align-items-center g-5 bridge-home-hero-row">

                <div class="col-12 col-lg-6">

                    <h1 class="fw-bold lh-sm mb-3 bridge-home-hero-title">
                        Supporting Teachers,<br>
                        Because Every Student<br>
                        Learns Differently.
                    </h1>

                    <p class="text-secondary lh-lg mb-4 bridge-home-hero-copy">
                        Teaching is more than grades and exams. Our system helps teachers understand
                        where students struggle and how to support them with dedicated learning plans.
                        By tracking progress over time, teachers can focus on what truly matters:
                        helping every student grow.
                    </p>

                    @* <div class="d-flex gap-3 mb-4">
                        <div class="d-flex align-items-center gap-2 px-3 py-2 rounded-3 shadow-sm bg-primary bg-opacity-10">
                            <i class="bi bi-person-video3 fs-4"></i>
                            <span class="fw-semibold">Teacher</span>
                        </div>

                        <div class="d-flex align-items-center gap-2 px-3 py-2 rounded-3 shadow-sm bg-primary bg-opacity-10">
                            <i class="bi bi-people fs-4"></i>
                            <span class="fw-semibold">Parent</span>
                        </div>
                    </div>

                    <a class="btn btn-info rounded-pill px-4 py-2 fw-semibold" asp-controller="Home" asp-action="login">
                        Get Started →
                    </a> *@
                    <div class="d-flex gap-3 mb-4 bridge-home-role-list">

                        <!-- Teacher -->
                        <div onclick="selectRole('Teacher')" id="teacherBox"
                             class="role-box d-flex align-items-center gap-2 px-3 py-2 rounded-3 shadow-sm bg-primary bg-opacity-10">
                            <i class="bi bi-person-video3 fs-4"></i>
                            <span class="fw-semibold">Teacher</span>
                        </div>

                        <!-- Parent -->
                        <div onclick="selectRole('Parent')" id="parentBox"
                             class="role-box d-flex align-items-center gap-2 px-3 py-2 rounded-3 shadow-sm bg-primary bg-opacity-10">
                            <i class="bi bi-people fs-4"></i>
                            <span class="fw-semibold">Parent</span>
                        </div>

                        <div onclick="selectRole('Institution')" id="institutionBox"
                             class="role-box d-flex align-items-center gap-2 px-3 py-2 rounded-3 shadow-sm bg-primary bg-opacity-10">
                            <i class="bi bi-buildings fs-4"></i>
                            <span class="fw-semibold">Institution</span>
                        </div>

                    </div>

                    <!-- زر -->
                    <a id="startBtn" class="btn btn-info rounded-pill px-4 py-2 fw-semibold d-inline-flex align-items-center bridge-home-start-btn">
                        Get Started →
                    </a>
                </div>
                <div class="col-12 col-lg-6 text-center text-lg-end bridge-home-visual-col">
                    <div class="study-scene">
                        <svg viewBox="0 0 460 360" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Animated notebook and pen">
                            <!-- soft backdrop -->
                            <ellipse cx="230" cy="318" rx="180" ry="22" fill="#C3EAFB" opacity=".55"/>

                            <!-- floating mini notebook (lavender) -->
                            <g class="ss-float d1" style="--r:-6deg">
                                <rect x="40" y="70" width="78" height="58" rx="9" fill="#D0CEFF"/>
                                <rect x="40" y="70" width="16" height="58" rx="8" fill="#148AE4"/>
                                <line x1="66" y1="88" x2="106" y2="88" stroke="#148AE4" stroke-width="3" stroke-linecap="round" opacity=".5"/>
                                <line x1="66" y1="100" x2="106" y2="100" stroke="#148AE4" stroke-width="3" stroke-linecap="round" opacity=".5"/>
                                <line x1="66" y1="112" x2="92" y2="112" stroke="#148AE4" stroke-width="3" stroke-linecap="round" opacity=".5"/>
                            </g>

                            <!-- floating mini notebook (yellow) -->
                            <g class="ss-float d2" style="--r:8deg">
                                <rect x="346" y="58" width="74" height="56" rx="9" fill="#FAE37D"/>
                                <rect x="346" y="58" width="15" height="56" rx="8" fill="#E6C24B"/>
                                <line x1="370" y1="76" x2="408" y2="76" stroke="#B98900" stroke-width="3" stroke-linecap="round" opacity=".45"/>
                                <line x1="370" y1="88" x2="408" y2="88" stroke="#B98900" stroke-width="3" stroke-linecap="round" opacity=".45"/>
                                <line x1="370" y1="100" x2="394" y2="100" stroke="#B98900" stroke-width="3" stroke-linecap="round" opacity=".45"/>
                            </g>

                            <!-- sparkles -->
                            <path class="ss-sparkle" d="M150 56 l4 9 9 4 -9 4 -4 9 -4-9 -9-4 9-4z" fill="#148AE4"/>
                            <path class="ss-sparkle s2" d="M396 150 l3 7 7 3 -7 3 -3 7 -3-7 -7-3 7-3z" fill="#FAE37D"/>

                            <!-- main open notebook -->
                            <g class="ss-float d3" style="--r:0deg">
                                <rect x="96" y="150" width="268" height="168" rx="16" fill="#C3EAFB"/>
                                <rect x="108" y="138" width="244" height="158" rx="14" fill="#ffffff" stroke="#D0CEFF" stroke-width="3"/>
                                <!-- spiral binding -->
                                <line x1="108" y1="138" x2="108" y2="296" stroke="#148AE4" stroke-width="4"/>
                                <circle cx="108" cy="160" r="5" fill="#148AE4"/>
                                <circle cx="108" cy="190" r="5" fill="#148AE4"/>
                                <circle cx="108" cy="220" r="5" fill="#148AE4"/>
                                <circle cx="108" cy="250" r="5" fill="#148AE4"/>
                                <circle cx="108" cy="280" r="5" fill="#148AE4"/>
                                <!-- ruled lines -->
                                <line x1="136" y1="176" x2="330" y2="176" stroke="#D0CEFF" stroke-width="2.5"/>
                                <line x1="136" y1="206" x2="330" y2="206" stroke="#D0CEFF" stroke-width="2.5"/>
                                <line x1="136" y1="236" x2="330" y2="236" stroke="#D0CEFF" stroke-width="2.5"/>
                                <line x1="136" y1="266" x2="330" y2="266" stroke="#D0CEFF" stroke-width="2.5"/>
                                <!-- handwriting being drawn -->
                                <path class="ss-ink" d="M138 196 q14 -16 28 0 t28 0 t28 0 t28 0 t28 0"
                                      fill="none" stroke="#148AE4" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                            </g>

                            <!-- pen -->
                            <g class="ss-pen">
                                <g transform="translate(120 150) rotate(38)">
                                    <rect x="0" y="0" width="20" height="120" rx="9" fill="#148AE4"/>
                                    <rect x="0" y="0" width="20" height="28" rx="9" fill="#0E6FBF"/>
                                    <rect x="6" y="30" width="8" height="70" rx="4" fill="#C3EAFB" opacity=".6"/>
                                    <polygon points="0,120 20,120 10,150" fill="#FAE37D"/>
                                    <polygon points="6,138 14,138 10,150" fill="#1F2937"/>
                                </g>
                            </g>
                        </svg>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <script>
        let selectedRole = "";

        function selectRole(role) {
            selectedRole = role;

            document.getElementById("teacherBox").classList.remove("role-selected");
            document.getElementById("parentBox").classList.remove("role-selected");
            document.getElementById("institutionBox").classList.remove("role-selected");

            if (role === "Teacher") {
                document.getElementById("teacherBox").classList.add("role-selected");
            } else if (role === "Parent") {
                document.getElementById("parentBox").classList.add("role-selected");
            } else {
                document.getElementById("institutionBox").classList.add("role-selected");
            }
        }

        document.getElementById("startBtn").addEventListener("click", function () {
            if (selectedRole === "") {
                alert("Pleas Select");
                return;
            }

            if (selectedRole === "Teacher") {
                window.location.href = "/Home/TeacheRegrister";
            } else if (selectedRole === "Institution") {
                window.location.href = "/Home/InstitutionRegrister";
            } else {
                window.location.href = "/Home/ParentRegrister";
            }
        });
    </script>

    <section class="py-5 bg-warning bg-opacity-10">
        <div class="container py-3">

            <div class="row g-4 justify-content-center">

                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4 text-center">
                            <div class="d-flex justify-content-center mb-3">
                                <img src="~/img/student.png" alt="Understand Student Needs" class="img-fluid" style="max-height:70px;">
                            </div>
                            <h5 class="fw-bold mb-3">Understand Student<br>Needs</h5>
                            <p class="text-secondary mb-0">
                                Easily see where students struggle and which skills need more attention
                            </p>
                        </div>
                    </div>
                </div>
                <!-- Card 2 -->
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4 text-center">
                            <div class="d-flex justify-content-center mb-3">
                                <img src="~/img/class1.png" alt="Class Learning Plans" class="img-fluid" style="max-height:70px;">
                            </div>
                            <h5 class="fw-bold mb-3">Class<br>Learning<br>Plans</h5>
                            <p class="text-secondary mb-0">
                                Build a clear learning plan for the whole class based on baseline results,
                                so lessons focus on the skills students need most.
                            </p>
                        </div>
                    </div>
                </div>
                <!-- Card 3 -->
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body p-4 text-center">
                            <div class="d-flex justify-content-center mb-3">
                                <img src="~/img/class2.png" alt="Extra Support" class="img-fluid" style="max-height:70px;">
                            </div>
                            <h5 class="fw-bold mb-3">Extra Support<br>for Struggling<br>Students</h5>
                            <p class="text-secondary mb-0">
                                Provide an alternative support plan for below-average students, with
                                targeted activities to help them catch up without slowing the class down.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Button -->
            <div class="d-flex justify-content-center mt-4">
                <a id="generatePlanNowButton" href="@Url.Action("login", "Home")" class="btn btn-info rounded-pill px-4 py-2 shadow-sm fw-semibold">
                    Generate Plan Now <i class="bi bi-arrow-right ms-2"></i>
                </a>
            </div>

        </div>
    </section>
    <section class="py-5">
        <div class="container">

            <!-- Title -->
            <h2 class="text-center fw-bold mb-5">Work Flow</h2>

            <!-- STEP 1 -->
            <div class="row align-items-center g-4 mb-5">
                <div class="col-12 col-lg-6">
                    <span class="badge rounded-pill bg-info bg-opacity-25 text-dark px-3 py-2 mb-3">
                        Step 1
                    </span>

                    <h5 class="fw-bold mb-2">
                        Upload Your Students’<br>Results
                    </h5>

                    <p class="text-secondary mb-0">
                        simply upload or drag and drop the Excel file containing your students results,
                        following the required format.
                    </p>
                </div>

                <div class="col-12 col-lg-6 text-center text-lg-end">
                    <img src="~/img/wf1.png" class="img-fluid" alt="Step 1">
                </div>
            </div>
            <!-- STEP 2 -->
            <div class="row align-items-center g-4 mb-5 mt-4">
                <div class="col-12 col-lg-6 order-2 order-lg-1 text-center text-lg-start">
                    <img src="~/img/wf2.png" class="img-fluid" alt="Step 2">
                </div>

                <div class="col-12 col-lg-6 order-1 order-lg-2">
                    <span class="badge rounded-pill bg-info bg-opacity-25 text-dark px-3 py-2 mb-3">
                        Step 2
                    </span>

                    <h5 class="fw-bold mb-2">
                        Understand Your Students’<br>Skills
                    </h5>

                    <p class="text-secondary mb-0">
                        The system reviews the results to highlight skill strengths, learning gaps,
                        and students who may need additional support, giving you a clearer picture
                        of your class.
                    </p>
                </div>
            </div>

            <!-- STEP 3 -->
            <div class="row align-items-center g-4 mt-4">
                <div class="col-12 col-lg-6">
                    <span class="badge rounded-pill bg-info bg-opacity-25 text-dark px-3 py-2 mb-3">
                        Step 3
                    </span>

                    <h5 class="fw-bold mb-2">
                        Your Learning Plan Is<br>Ready!
                    </h5>

                    <p class="text-secondary mb-0">
                        A learning plan is generated for your class, along with an additional support
                        plan for struggling students. You can follow the plan and adjust it as your
                        students’ progress over time.
                    </p>
                </div>
                <div class="col-12 col-lg-6 text-center text-lg-end">
                    <img src="~/img/wf3.png" class="img-fluid" alt="Step 3">
                </div>
            </div>

        </div>
    </section>
</div>

<script>
    (() => {
        const generatePlanNowButton = document.getElementById("generatePlanNowButton");
        if (!generatePlanNowButton) {
            return;
        }

        generatePlanNowButton.addEventListener("click", (event) => {
            const token = sessionStorage.getItem("bridgeAccessToken");
            const role = sessionStorage.getItem("bridgeUserRole");

            if (!token) {
                generatePlanNowButton.href = '@Url.Action("login", "Home")';
                return;
            }

            event.preventDefault();

            const targetUrl = role === "Parent"
                ? '@Url.Action("ParentDashboard", "Home")'
                : role === "Institution"
                    ? '@Url.Action("InstitutionDashboard", "Home")'
                    : '@Url.Action("Teacher", "Home")';

            window.location.href = targetUrl;
        });
    })();
</script>
