@{
    ViewData["Title"] = "Teacher";
}

<div class="teacher-shell">
    <partial name="_TeacherSidebar" />
    <div class="teacher-shell-content">
<div class="container py-4">

    <div class="row g-4 align-items-stretch">

        <div class="col-12 col-lg-6">
            <div class="p-4 rounded-4 bg-info bg-opacity-25 h-100 d-flex align-items-center gap-4">
                <img src="~/img/UserLogo.png"
                     class="rounded-circle img-fluid"
                     style="width:130px;height:130px;object-fit:cover"
                     alt="Profile">

                <div>
                    <h6 class="fw-bold mb-1 text-uppercase" id="teacherWelcomeText">
                        Welcome, Teacher!
                    </h6>

                    <p class="mb-3 text-secondary">
                        Everything you need to support your students is right here.
                    </p>

                    <div class="d-flex flex-wrap gap-3 text-secondary">
                        <span id="teacherDashboardGrade">
                            <i class="bi bi-book me-1"></i> Grade
                        </span>
                        <span id="teacherDashboardSection">
                            <i class="bi bi-diagram-3 me-1"></i> Section -
                        </span>
                        <span id="teacherDashboardStudentCount">
                            <i class="bi bi-people me-1"></i> Total of 0 Students
                        </span>
                    </div>
                </div>

            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="row g-4">

                <div class="col-6">
                    <div class="p-3 border rounded-4 h-100">
                        <i class="bi bi-people fs-4"></i>
                        <h5 class="fw-bold mt-2 mb-1">--</h5>
                        <p class="text-secondary mb-0">attendance</p>
                    </div>
                </div>

                <div class="col-6">
                    <div class="p-3 border rounded-4 h-100">
                        <i class="bi bi-mortarboard fs-4"></i>
                        <h5 class="fw-bold mt-2 mb-1">0%</h5>
                        <p class="text-secondary mb-0">overall progress</p>
                    </div>
                </div>

                <div class="col-6">
                    <div class="p-3 border rounded-4 h-100">
                        <i class="bi bi-journal-check fs-4"></i>
                        <h5 class="fw-bold mt-2 mb-1">100</h5>
                        <p class="text-secondary mb-0">classes remaining</p>
                    </div>
                </div>

                <div class="col-6">
                    <div class="p-3 border rounded-4 h-100">
                        <i class="bi bi-exclamation-triangle fs-4"></i>
                        <h5 class="fw-bold mt-2 mb-1">--</h5>
                        <p class="text-secondary mb-0">at risk students</p>
                    </div>
                </div>

            </div>
        </div>

    </div>

</div>
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            <h4 class="text-center fw-semibold mb-4">Upload</h4>

            <div id="dropArea"
                 class="border border-2 border-primary border-opacity-25 rounded-4 p-5 text-center bg-primary bg-opacity-10">

                <i class="bi bi-cloud-arrow-up fs-1 text-primary mb-3 d-block"></i>

                <div class="fw-semibold mb-1">
                    Drag &amp; drop files or
                    <label for="fileInput" class="text-primary text-decoration-underline ms-1" role="button">
                        Browse
                    </label>
                </div>

                <div class="small text-secondary mb-3">
                    Supported formats: JPEG, PNG, GIF, MP4, PDF, PSD, AI, Word, PPT
                </div>

                <input id="fileInput" type="file" class="d-none" multiple>

                <ul id="fileList" class="list-group list-group-flush text-start d-none"></ul>
            </div>

        </div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    sessionStorage.removeItem("bridgeGeneratedPlan");
    sessionStorage.removeItem("bridgeBaselineReady");
    const dropArea = document.getElementById("dropArea");
    const fileInput = document.getElementById("fileInput");
    const fileList = document.getElementById("fileList");
    let selectedBaselineFiles = [];

    const teacherWelcomeText = document.getElementById("teacherWelcomeText");
    const teacherDashboardGrade = document.getElementById("teacherDashboardGrade");
    const teacherDashboardSection = document.getElementById("teacherDashboardSection");
    const teacherDashboardStudentCount = document.getElementById("teacherDashboardStudentCount");

    function setTeacherDashboardHeader(profile, studentCount) {
      const fullName = profile?.fullName || sessionStorage.getItem("bridgeUserName") || "Teacher";
      const grade = profile?.grade || sessionStorage.getItem("bridgeTeacherGrade") || "";
      const section = sessionStorage.getItem("bridgeTeacherSection") || "";

      if (teacherWelcomeText) {
        teacherWelcomeText.textContent = `Welcome, ${fullName}!`;
      }

      if (teacherDashboardGrade) {
        teacherDashboardGrade.innerHTML = `<i class="bi bi-book me-1"></i> ${grade || "Grade -"}`;
      }

      if (teacherDashboardSection) {
        teacherDashboardSection.innerHTML = `<i class="bi bi-diagram-3 me-1"></i> ${section ? `Section ${section}` : "Section -"}`;
      }

      if (teacherDashboardStudentCount) {
        teacherDashboardStudentCount.innerHTML = `<i class="bi bi-people me-1"></i> Total of ${studentCount} Students`;
      }
    }

    async function hydrateTeacherDashboardHeader() {
      const token = sessionStorage.getItem("bridgeAccessToken");

      if (!token) {
        setTeacherDashboardHeader(null, 0);
        return;
      }

      try {
        const [profileResponse, studentsResponse] = await Promise.all([
          fetch(`${backendBaseUrl}/auth/profile`, {
            headers: {
              Authorization: `Bearer ${token}`
            }
          }),
          fetch(`${backendBaseUrl}/students/myStudents`, {
            headers: {
              Authorization: `Bearer ${token}`
            }
          })
        ]);

        const profile = profileResponse.ok ? await profileResponse.json() : null;
        const students = studentsResponse.ok ? await studentsResponse.json() : [];

        if (profile?.fullName) {
          sessionStorage.setItem("bridgeUserName", profile.fullName);
        }

        if (profile?.grade) {
          sessionStorage.setItem("bridgeTeacherGrade", profile.grade);
        }

        setTeacherDashboardHeader(profile, Array.isArray(students) ? students.length : 0);
      } catch {
        setTeacherDashboardHeader(null, 0);
      }
    }

    hydrateTeacherDashboardHeader();

    ["dragenter","dragover","dragleave","drop"].forEach(eventName => {
      dropArea.addEventListener(eventName, e => e.preventDefault());
    });

    
    dropArea.addEventListener("drop", e => {
      handleFiles(e.dataTransfer.files);
    });

   
    fileInput.addEventListener("change", e => {
      handleFiles(e.target.files);
    });

    function handleFiles(files) {
      selectedBaselineFiles = Array.from(files);
      fileList.innerHTML = "";
      fileList.classList.remove("d-none");

      selectedBaselineFiles.forEach(file => {
        const li = document.createElement("li");
        li.className = "list-group-item d-flex justify-content-between align-items-center";
        li.innerHTML = `
          <span>${file.name}</span>
          <span class="badge bg-secondary">${(file.size / 1024).toFixed(1)} KB</span>
        `;
        fileList.appendChild(li);
      });
    }

    async function generatePlanFromBaseline() {
      const token = sessionStorage.getItem("bridgeAccessToken");
      const selectedFile = selectedBaselineFiles[0];
      const subjectId = localStorage.getItem("teacherSelectedSubject");
      const semester = Number(localStorage.getItem("teacherSelectedSemester") || "1");

      if (!token) {
        alert("You need to sign in again before generating a plan.");
        return;
      }

      if (!selectedFile) {
        alert("Please upload the baseline Excel file first.");
        return;
      }

      if (!subjectId) {
        alert("Weekly slots are missing a selected subject. Go back to setup and save them again.");
        return;
      }

      const generateButton = document.getElementById("generatePlanButton");
      generateButton.classList.add("disabled");
      generateButton.textContent = "Generating...";
      generateButton.style.pointerEvents = "none";

      try {
        const formData = new FormData();
        formData.append("file", selectedFile);

        const normalizationResponse = await fetch(`${backendBaseUrl}/baseline/normalization`, {
          method: "POST",
          headers: {
            Authorization: `Bearer ${token}`
          },
          body: formData
        });
        const normalizedRows = await normalizationResponse.json().catch(() => null);
        if (!normalizationResponse.ok || !Array.isArray(normalizedRows)) {
          throw new Error(normalizedRows?.message || "Unable to normalize baseline rows.");
        }

        const matchResponse = await fetch(`${backendBaseUrl}/baseline/matchStudents`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`
          },
          body: JSON.stringify(normalizedRows)
        });
        const matchedRows = await matchResponse.json().catch(() => null);
        if (!matchResponse.ok || !Array.isArray(matchedRows)) {
          throw new Error(matchedRows?.message || "Unable to match baseline rows to students.");
        }

        const saveResponse = await fetch(`${backendBaseUrl}/baseline/save`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`
          },
          body: JSON.stringify(matchedRows)
        });
        const saveData = await saveResponse.json().catch(() => null);
        if (!saveResponse.ok) {
          throw new Error(saveData?.message || "Unable to save baseline results.");
        }

        sessionStorage.setItem("bridgeBaselineReady", "true");

        const planResponse = await fetch(`${backendBaseUrl}/plans/generate`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`
          },
          body: JSON.stringify({
            subjectId,
            semester
          })
        });
        const generatedPlan = await planResponse.json().catch(() => null);
        if (!planResponse.ok || !generatedPlan?.planId) {
          throw new Error(generatedPlan?.message || "Unable to generate plan.");
        }

        sessionStorage.setItem("bridgeGeneratedPlan", JSON.stringify(generatedPlan));
        window.location.href = '@Url.Action("Analysis", "Home")';
      } catch (error) {
        alert(error.message || "Unable to generate the learning plan.");
      } finally {
        generateButton.classList.remove("disabled");
        generateButton.textContent = "Generate";
        generateButton.style.pointerEvents = "";
      }
    }
</script>
<!-- Generate Button -->
<div class="text-center mt-4">

    <a class="rounded-pill px-5 fw-semibold btn btn-info rounded-pill px-4 py-2 fw-semibold"
       href="#"
       id="generatePlanButton">
        Generate
    </a>
 
</div>
</div>
</div>

<script>
    document.getElementById("generatePlanButton")?.addEventListener("click", (event) => {
      event.preventDefault();
      generatePlanFromBaseline();
    });
</script>

