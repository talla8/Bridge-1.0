@{
    ViewData["Title"] = "Teacher";
}

<div class="teacher-shell">
    <partial name="_TeacherSidebar" />
    <div class="teacher-shell-content">
<div class="container py-4">

    <div class="row g-4 align-items-stretch">

        <div class="col-12 col-lg-6">
            <div class="p-4 rounded-4 bg-info bg-opacity-25 h-100 d-flex align-items-center gap-4">
                <img src="~/img/UserLogo.png"
                     class="rounded-circle img-fluid"
                     style="width:130px;height:130px;object-fit:cover"
                     alt="Profile">

                <div>
                    <h6 class="fw-bold mb-1 text-uppercase" id="teacherWelcomeText">
                        Welcome, Teacher!
                    </h6>

                    <p class="mb-3 text-secondary">
                        Everything you need to support your students is right here.
                    </p>

                    <div class="d-flex flex-wrap gap-3 text-secondary">
                        <span id="teacherDashboardGrade">
                            <i class="bi bi-book me-1"></i> Grade
                        </span>
                        <span id="teacherDashboardSection">
                            <i class="bi bi-diagram-3 me-1"></i> Section -
                        </span>
                        <span id="teacherDashboardStudentCount">
                            <i class="bi bi-people me-1"></i> Total of 0 Students
                        </span>
                    </div>
                </div>

            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="row g-4">

                <div class="col-6">
                    <div class="p-3 border rounded-4 h-100">
                        <i class="bi bi-people fs-4"></i>
                        <h5 class="fw-bold mt-2 mb-1">--</h5>
                        <p class="text-secondary mb-0">attendance</p>
                    </div>
                </div>

                <div class="col-6">
                    <div class="p-3 border rounded-4 h-100">
                        <i class="bi bi-mortarboard fs-4"></i>
                        <h5 class="fw-bold mt-2 mb-1">0%</h5>
                        <p class="text-secondary mb-0">overall progress</p>
                    </div>
                </div>

                <div class="col-6">
                    <div class="p-3 border rounded-4 h-100">
                        <i class="bi bi-journal-check fs-4"></i>
                        <h5 class="fw-bold mt-2 mb-1">100</h5>
                        <p class="text-secondary mb-0">classes remaining</p>
                    </div>
                </div>

                <div class="col-6">
                    <div class="p-3 border rounded-4 h-100">
                        <i class="bi bi-exclamation-triangle fs-4"></i>
                        <h5 class="fw-bold mt-2 mb-1">--</h5>
                        <p class="text-secondary mb-0">at risk students</p>
                    </div>
                </div>

            </div>
        </div>

    </div>

</div>
<div class="container py-5 d-none" id="planProgressSection">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="border rounded-4 shadow-sm p-4 bg-white">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h4 class="fw-bold mb-1">Current Plan Progress</h4>
                        <p class="text-secondary mb-0" id="dashboardPlanSummaryText">
                            Track how the generated plan is moving and jump back into it.
                        </p>
                    </div>
                    <div class="d-flex gap-2">
                        <a class="btn btn-outline-secondary rounded-pill px-4" asp-controller="Home" asp-action="History">Plan History</a>
                        <a class="btn btn-info rounded-pill px-4 fw-semibold" asp-controller="Home" asp-action="Analysis">Open Plan</a>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold text-dark" id="dashboardPlanLabel">No generated plan</span>
                        <span class="fw-bold text-success" id="dashboardPlanProgressValue">0%</span>
                    </div>
                    <div class="progress rounded-pill" style="height:18px;">
                        <div class="progress-bar bg-success rounded-pill" id="dashboardPlanProgressBar" style="width:0%"></div>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-12 col-md-3">
                        <div class="border rounded-4 p-3 h-100">
                            <div class="small text-secondary mb-1">Completed items</div>
                            <div class="fw-bold fs-4" id="dashboardCompletedItems">0</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <div class="border rounded-4 p-3 h-100">
                            <div class="small text-secondary mb-1">Remaining items</div>
                            <div class="fw-bold fs-4" id="dashboardRemainingItems">0</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <div class="border rounded-4 p-3 h-100">
                            <div class="small text-secondary mb-1">Class speed</div>
                            <div class="fw-bold fs-4 text-primary" id="dashboardClassSpeed">100%</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <div class="border rounded-4 p-3 h-100">
                            <div class="small text-secondary mb-1">Reorder status</div>
                            <div class="fw-bold fs-6" id="dashboardReorderStatus">On track</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5" id="uploadAssessmentSection">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            <h4 class="text-center fw-semibold mb-4">Upload</h4>

            <div id="dropArea"
                 class="border border-2 border-primary border-opacity-25 rounded-4 p-5 text-center bg-primary bg-opacity-10">

                <i class="bi bi-cloud-arrow-up fs-1 text-primary mb-3 d-block"></i>

                <div class="fw-semibold mb-1">
                    Drag &amp; drop files or
                    <label for="fileInput" class="text-primary text-decoration-underline ms-1" role="button">
                        Browse
                    </label>
                </div>

                <div class="small text-secondary mb-3">
                    Supported formats: JPEG, PNG, GIF, MP4, PDF, PSD, AI, Word, PPT
                </div>

                <input id="fileInput" type="file" class="d-none" multiple>

                <ul id="fileList" class="list-group list-group-flush text-start d-none"></ul>
            </div>

        </div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const dropArea = document.getElementById("dropArea");
    const fileInput = document.getElementById("fileInput");
    const fileList = document.getElementById("fileList");
    const uploadAssessmentSection = document.getElementById("uploadAssessmentSection");
    const planProgressSection = document.getElementById("planProgressSection");
    const dashboardPlanSummaryText = document.getElementById("dashboardPlanSummaryText");
    const dashboardPlanLabel = document.getElementById("dashboardPlanLabel");
    const dashboardPlanProgressValue = document.getElementById("dashboardPlanProgressValue");
    const dashboardPlanProgressBar = document.getElementById("dashboardPlanProgressBar");
    const dashboardCompletedItems = document.getElementById("dashboardCompletedItems");
    const dashboardRemainingItems = document.getElementById("dashboardRemainingItems");
    const dashboardClassSpeed = document.getElementById("dashboardClassSpeed");
    const dashboardReorderStatus = document.getElementById("dashboardReorderStatus");
    const teacherDashboardSubjectButton = document.getElementById("teacherDashboardSubjectButton");
    const teacherDashboardSkillFilterButton = document.getElementById("teacherDashboardSkillFilterButton");
    const teacherDashboardSkillsList = document.getElementById("teacherDashboardSkillsList");
    const teacherDashboardSkillsEmpty = document.getElementById("teacherDashboardSkillsEmpty");
    const teacherDashboardTasksBody = document.getElementById("teacherDashboardTasksBody");
    const teacherDashboardTasksEmptyRow = document.getElementById("teacherDashboardTasksEmptyRow");
    const teacherDashboardTasksPrevious = document.getElementById("teacherDashboardTasksPrevious");
    const teacherDashboardTasksNext = document.getElementById("teacherDashboardTasksNext");
    const teacherDashboardTasksPageText = document.getElementById("teacherDashboardTasksPageText");
    let selectedBaselineFiles = [];
    let teacherDashboardSkillRows = [];
    let teacherDashboardSkillSort = "lowest";
    let teacherDashboardTasks = [];
    let teacherDashboardTaskPage = 1;
    const teacherDashboardTasksPageSize = 5;

    const teacherWelcomeText = document.getElementById("teacherWelcomeText");
    const teacherDashboardGrade = document.getElementById("teacherDashboardGrade");
    const teacherDashboardSection = document.getElementById("teacherDashboardSection");
    const teacherDashboardStudentCount = document.getElementById("teacherDashboardStudentCount");

    function setTeacherDashboardHeader(profile, studentCount) {
      const fullName = profile?.fullName || sessionStorage.getItem("bridgeUserName") || "Teacher";
      const grade = profile?.grade || sessionStorage.getItem("bridgeTeacherGrade") || "";
      const section = sessionStorage.getItem("bridgeTeacherSection") || "";

      if (teacherWelcomeText) {
        teacherWelcomeText.textContent = `Welcome, ${fullName}!`;
      }

      if (teacherDashboardGrade) {
        teacherDashboardGrade.innerHTML = `<i class="bi bi-book me-1"></i> ${grade || "Grade -"}`;
      }

      if (teacherDashboardSection) {
        teacherDashboardSection.innerHTML = `<i class="bi bi-diagram-3 me-1"></i> ${section ? `Section ${section}` : "Section -"}`;
      }

      if (teacherDashboardStudentCount) {
        teacherDashboardStudentCount.innerHTML = `<i class="bi bi-people me-1"></i> Total of ${studentCount} Students`;
      }
    }

    async function hydrateTeacherDashboardHeader() {
      const token = sessionStorage.getItem("bridgeAccessToken");

      if (!token) {
        setTeacherDashboardHeader(null, 0);
        return;
      }

      try {
        const [profileResponse, studentsResponse] = await Promise.all([
          fetch(`${backendBaseUrl}/auth/profile`, {
            headers: {
              Authorization: `Bearer ${token}`
            }
          }),
          fetch(`${backendBaseUrl}/students/myStudents`, {
            headers: {
              Authorization: `Bearer ${token}`
            }
          })
        ]);

        const profile = profileResponse.ok ? await profileResponse.json() : null;
        const students = studentsResponse.ok ? await studentsResponse.json() : [];

        if (profile?.fullName) {
          sessionStorage.setItem("bridgeUserName", profile.fullName);
        }

        if (profile?.grade) {
          sessionStorage.setItem("bridgeTeacherGrade", profile.grade);
        }

        setTeacherDashboardHeader(profile, Array.isArray(students) ? students.length : 0);
      } catch {
        setTeacherDashboardHeader(null, 0);
      }
    }

    hydrateTeacherDashboardHeader();

    function setDashboardMode(hasPlan) {
      uploadAssessmentSection?.classList.toggle("d-none", hasPlan);
      planProgressSection?.classList.toggle("d-none", !hasPlan);
    }

    function formatSkillTitle(skillId) {
      switch (String(skillId)) {
        case "skill_vocal":
          return "Vocal Awareness";
        case "skill_sounds_of_letters":
          return "Sounds of Letters";
        case "skill_writing":
          return "Writing";
        default:
          return String(skillId || "Skill");
      }
    }

    function renderDashboardSkills() {
      if (!teacherDashboardSkillsList || !teacherDashboardSkillsEmpty) {
        return;
      }

      const rows = teacherDashboardSkillRows.slice().sort((left, right) =>
        teacherDashboardSkillSort === "highest"
          ? Number(right.avg ?? 0) - Number(left.avg ?? 0)
          : Number(left.avg ?? 0) - Number(right.avg ?? 0)
      );

      teacherDashboardSkillsList.innerHTML = "";
      if (!rows.length) {
        teacherDashboardSkillsEmpty.classList.remove("d-none");
        return;
      }

      teacherDashboardSkillsEmpty.classList.add("d-none");
      rows.forEach((row) => {
        const wrapper = document.createElement("div");
        wrapper.className = "mb-4";
        const pct = Math.max(0, Math.min(100, Number(row.avg ?? 0)));
        wrapper.innerHTML = `
          <div class="fw-semibold mb-2">${formatSkillTitle(row.skillId)}</div>
          <div class="progress rounded-pill" style="height:16px">
            <div class="progress-bar bg-primary bg-opacity-25 rounded-pill" style="width:${pct}%"></div>
          </div>
        `;
        teacherDashboardSkillsList.appendChild(wrapper);
      });
    }

    function formatTaskStatus(status) {
      return String(status || "OPEN")
        .replaceAll("_", " ")
        .replace(/\b\w/g, (char) => char.toUpperCase());
    }

    function formatTaskDate(value) {
      if (!value) return "-";
      const date = new Date(value);
      return Number.isNaN(date.getTime()) ? "-" : date.toLocaleDateString();
    }

    function renderDashboardTasks() {
      if (!teacherDashboardTasksBody || !teacherDashboardTasksEmptyRow) {
        return;
      }

      const totalPages = Math.max(1, Math.ceil(teacherDashboardTasks.length / teacherDashboardTasksPageSize));
      teacherDashboardTaskPage = Math.min(Math.max(1, teacherDashboardTaskPage), totalPages);
      const startIndex = (teacherDashboardTaskPage - 1) * teacherDashboardTasksPageSize;
      const visibleRows = teacherDashboardTasks.slice(startIndex, startIndex + teacherDashboardTasksPageSize);

      teacherDashboardTasksBody.innerHTML = "";
      teacherDashboardTasksEmptyRow.classList.toggle("d-none", visibleRows.length > 0);

      visibleRows.forEach((task, index) => {
        const row = document.createElement("tr");
        row.innerHTML = `
          <td class="small">${String(startIndex + index + 1).padStart(2, "0")}</td>
          <td class="small">${task.title || "-"}</td>
          <td class="small">Institution task</td>
          <td class="small">${formatTaskDate(task.dueDate)}</td>
          <td class="small">
            <span class="badge rounded-pill bg-warning bg-opacity-25 text-dark px-3 py-2">
              ${formatTaskStatus(task.status)}
            </span>
          </td>
          <td class="text-center">
            <a class="btn btn-link text-dark p-1" href="@Url.Action("TeacherInbox", "Home")" title="Open inbox">
              <i class="bi bi-arrow-right-circle"></i>
            </a>
          </td>
        `;
        teacherDashboardTasksBody.appendChild(row);
      });

      if (teacherDashboardTasksPageText) {
        teacherDashboardTasksPageText.textContent = `Page ${teacherDashboardTaskPage} of ${totalPages}`;
      }

      if (teacherDashboardTasksPrevious) {
        teacherDashboardTasksPrevious.disabled = teacherDashboardTaskPage <= 1;
      }

      if (teacherDashboardTasksNext) {
        teacherDashboardTasksNext.disabled = teacherDashboardTaskPage >= totalPages;
      }
    }

    function getReorderStatusLabel(summary) {
      if (summary?.compressionApplied) {
        return "Compression active";
      }

      if (summary?.bufferUsed) {
        return "Using buffer";
      }

      if (summary?.planNeedsReordering) {
        return "Needs reorder";
      }

      return "On track";
    }

    function applyDashboardPlanSummary(plan, summary) {
      setDashboardMode(true);
      dashboardPlanSummaryText.textContent = `${String(plan.subjectId) === "2" ? "Arabic" : "Subject"} plan with ${Array.isArray(plan.sessions) ? plan.sessions.length : 0} generated sessions.`;
      dashboardPlanLabel.textContent = plan.planName || "Generated plan";
      dashboardPlanProgressValue.textContent = `${Number(summary?.progressPercentage ?? 0)}%`;
      dashboardPlanProgressBar.style.width = `${Number(summary?.progressPercentage ?? 0)}%`;
      dashboardCompletedItems.textContent = String(Number(summary?.completedItems ?? 0));
      dashboardRemainingItems.textContent = String(Number(summary?.remainingItems ?? 0));
      dashboardClassSpeed.textContent = `${Number(summary?.classSpeedPercentage ?? 100)}%`;
      dashboardReorderStatus.textContent = getReorderStatusLabel(summary);
    }

    async function hydrateTeacherPlanState() {
      const token = sessionStorage.getItem("bridgeAccessToken");
      if (!token) {
        setDashboardMode(false);
        return;
      }

      let plan = null;
      const storedPlan = sessionStorage.getItem("bridgeGeneratedPlan");

      if (storedPlan) {
        try {
          plan = JSON.parse(storedPlan);
        } catch {
          plan = null;
        }
      }

      try {
        async function fetchLatestPlan() {
          const latestPlanResponse = await fetch(`${backendBaseUrl}/plans/mine/latest`, {
            headers: {
              Authorization: `Bearer ${token}`
            }
          });

          if (!latestPlanResponse.ok) {
            return null;
          }

          const latestPlan = await latestPlanResponse.json().catch(() => null);
          if (latestPlan?.planId) {
            sessionStorage.setItem("bridgeGeneratedPlan", JSON.stringify(latestPlan));
            return latestPlan;
          }

          return null;
        }

        if (!plan?.planId) {
          plan = await fetchLatestPlan();
        }

        if (!plan?.planId) {
          setDashboardMode(false);
          return;
        }

        async function fetchPlanProgress(activePlan) {
          const progressResponse = await fetch(`${backendBaseUrl}/plans/${activePlan.planId}/progress`, {
            headers: {
              Authorization: `Bearer ${token}`
            }
          });

          if (!progressResponse.ok) {
            return null;
          }

          return progressResponse.json().catch(() => null);
        }

        let progress = await fetchPlanProgress(plan);

        if (!progress) {
          const latestPlan = await fetchLatestPlan();

          if (!latestPlan?.planId || latestPlan.planId === plan.planId) {
            sessionStorage.removeItem("bridgeGeneratedPlan");
            setDashboardMode(false);
            return;
          }

          plan = latestPlan;
          progress = await fetchPlanProgress(plan);
        }

        if (!progress) {
          sessionStorage.removeItem("bridgeGeneratedPlan");
          setDashboardMode(false);
          return;
        }

        applyDashboardPlanSummary(plan, progress);
      } catch {
        setDashboardMode(false);
      }
    }

    hydrateTeacherPlanState();

    async function hydrateTeacherDashboardSkillsAndTasks() {
      const token = sessionStorage.getItem("bridgeAccessToken");
      if (!token) {
        teacherDashboardSkillRows = [];
        teacherDashboardTasks = [];
        renderDashboardSkills();
        renderDashboardTasks();
        return;
      }

      try {
        const headers = {
          Authorization: `Bearer ${token}`
        };

        const [skillsResponse, tasksResponse] = await Promise.all([
          fetch(`${backendBaseUrl}/statistics/class/skills`, { headers }),
          fetch(`${backendBaseUrl}/teacher-inbox/tasks`, { headers })
        ]);

        teacherDashboardSkillRows = skillsResponse.ok
          ? await skillsResponse.json().catch(() => [])
          : [];

        teacherDashboardTasks = tasksResponse.ok
          ? await tasksResponse.json().catch(() => [])
          : [];

        renderDashboardSkills();
        renderDashboardTasks();
      } catch {
        teacherDashboardSkillRows = [];
        teacherDashboardTasks = [];
        renderDashboardSkills();
        renderDashboardTasks();
      }
    }

    hydrateTeacherDashboardSkillsAndTasks();

    teacherDashboardTasksPrevious?.addEventListener("click", () => {
      teacherDashboardTaskPage = Math.max(1, teacherDashboardTaskPage - 1);
      renderDashboardTasks();
    });

    teacherDashboardTasksNext?.addEventListener("click", () => {
      const totalPages = Math.max(1, Math.ceil(teacherDashboardTasks.length / teacherDashboardTasksPageSize));
      teacherDashboardTaskPage = Math.min(totalPages, teacherDashboardTaskPage + 1);
      renderDashboardTasks();
    });

    document.querySelectorAll("[data-skill-sort]").forEach((button) => {
      button.addEventListener("click", () => {
        teacherDashboardSkillSort = button.getAttribute("data-skill-sort") || "lowest";
        if (teacherDashboardSkillFilterButton) {
          teacherDashboardSkillFilterButton.textContent =
            teacherDashboardSkillSort === "highest" ? "Highest first" : "Lowest first";
        }
        renderDashboardSkills();
      });
    });

    document.querySelectorAll("[data-subject-dashboard]").forEach((button) => {
      button.addEventListener("click", () => {
        if (teacherDashboardSubjectButton) {
          teacherDashboardSubjectButton.textContent = button.getAttribute("data-subject-dashboard") || "Subject";
        }
      });
    });

    if (teacherDashboardSubjectButton) {
      teacherDashboardSubjectButton.textContent =
        localStorage.getItem("teacherSelectedSubject") === "2" ? "Arabic" : "Subject";
    }

    ["dragenter","dragover","dragleave","drop"].forEach(eventName => {
      dropArea.addEventListener(eventName, e => e.preventDefault());
    });

    
    dropArea.addEventListener("drop", e => {
      handleFiles(e.dataTransfer.files);
    });

   
    fileInput.addEventListener("change", e => {
      handleFiles(e.target.files);
    });

    function handleFiles(files) {
      selectedBaselineFiles = Array.from(files);
      fileList.innerHTML = "";
      fileList.classList.remove("d-none");

      selectedBaselineFiles.forEach(file => {
        const li = document.createElement("li");
        li.className = "list-group-item d-flex justify-content-between align-items-center";
        li.innerHTML = `
          <span>${file.name}</span>
          <span class="badge bg-secondary">${(file.size / 1024).toFixed(1)} KB</span>
        `;
        fileList.appendChild(li);
      });
    }

    async function generatePlanFromBaseline() {
      const token = sessionStorage.getItem("bridgeAccessToken");
      const selectedFile = selectedBaselineFiles[0];
      const subjectId = localStorage.getItem("teacherSelectedSubject");
      const semester = Number(localStorage.getItem("teacherSelectedSemester") || "1");

      if (!token) {
        alert("You need to sign in again before generating a plan.");
        return;
      }

      if (!selectedFile) {
        alert("Please upload the baseline Excel file first.");
        return;
      }

      if (!subjectId) {
        alert("Weekly slots are missing a selected subject. Go back to setup and save them again.");
        return;
      }

      const generateButton = document.getElementById("generatePlanButton");
      generateButton.classList.add("disabled");
      generateButton.textContent = "Generating...";
      generateButton.style.pointerEvents = "none";

      try {
        const formData = new FormData();
        formData.append("file", selectedFile);

        const normalizationResponse = await fetch(`${backendBaseUrl}/baseline/normalization`, {
          method: "POST",
          headers: {
            Authorization: `Bearer ${token}`
          },
          body: formData
        });
        const normalizedRows = await normalizationResponse.json().catch(() => null);
        if (!normalizationResponse.ok || !Array.isArray(normalizedRows)) {
          throw new Error(normalizedRows?.message || "Unable to normalize baseline rows.");
        }

        const matchResponse = await fetch(`${backendBaseUrl}/baseline/matchStudents`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`
          },
          body: JSON.stringify(normalizedRows)
        });
        const matchedRows = await matchResponse.json().catch(() => null);
        if (!matchResponse.ok || !Array.isArray(matchedRows)) {
          throw new Error(matchedRows?.message || "Unable to match baseline rows to students.");
        }

        const saveResponse = await fetch(`${backendBaseUrl}/baseline/save`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`
          },
          body: JSON.stringify(matchedRows)
        });
        const saveData = await saveResponse.json().catch(() => null);
        if (!saveResponse.ok) {
          throw new Error(saveData?.message || "Unable to save baseline results.");
        }

        sessionStorage.setItem("bridgeBaselineReady", "true");

        const planResponse = await fetch(`${backendBaseUrl}/plans/generate`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`
          },
          body: JSON.stringify({
            subjectId,
            semester
          })
        });
        const generatedPlan = await planResponse.json().catch(() => null);
        if (!planResponse.ok || !generatedPlan?.planId) {
          throw new Error(generatedPlan?.message || "Unable to generate plan.");
        }

        sessionStorage.setItem("bridgeGeneratedPlan", JSON.stringify(generatedPlan));
        window.location.href = '@Url.Action("Analysis", "Home")';
      } catch (error) {
        alert(error.message || "Unable to generate the learning plan.");
      } finally {
        generateButton.classList.remove("disabled");
        generateButton.textContent = "Generate";
        generateButton.style.pointerEvents = "";
      }
    }
</script>
<!-- Generate Button -->
<div class="text-center mt-4">

    <a class="rounded-pill px-5 fw-semibold btn btn-info rounded-pill px-4 py-2 fw-semibold"
       href="#"
       id="generatePlanButton">
        Generate
    </a>
 
</div>
</div>
</div>

<script>
    document.getElementById("generatePlanButton")?.addEventListener("click", (event) => {
      event.preventDefault();
      generatePlanFromBaseline();
    });
</script>

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-primary text-opacity-75 mb-0">Skills list</h4>

        <div class="d-flex gap-3">
            <div class="dropdown">
                <button class="btn btn-light border dropdown-toggle fw-semibold"
                        data-bs-toggle="dropdown"
                        id="teacherDashboardSubjectButton">
                    Subject
                </button>
                <ul class="dropdown-menu">
                    <li><button type="button" class="dropdown-item" data-subject-dashboard="Arabic">Arabic</button></li>
                </ul>
            </div>

            <div class="dropdown">
                <button class="btn btn-light border dropdown-toggle fw-semibold"
                        data-bs-toggle="dropdown"
