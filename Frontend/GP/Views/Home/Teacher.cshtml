@{
    ViewData["Title"] = "Teacher";
}

<style>
    .teacher-setup-card {
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        background: #fff;
        box-shadow: 0 10px 28px rgba(17,30,39,.04);
        padding: 24px;
    }

    .teacher-setup-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 18px;
    }

    .teacher-setup-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15,31,42, .45);
        z-index: 1050;
    }

    .teacher-setup-modal {
        position: fixed;
        inset: 50% auto auto 50%;
        transform: translate(-50%, -50%);
        width: min(92vw, 760px);
        max-height: calc(100vh - 72px);
        overflow: auto;
        background: #fff;
        border-radius: 24px;
        box-shadow: 0 22px 50px rgba(15,31,42,.25);
        z-index: 1051;
        padding: 24px;
    }

    .teacher-setup-modal h3 {
        font-size: 28px;
        font-weight: 800;
        color: #111E27;
        margin-bottom: 8px;
    }

    .teacher-setup-modal p {
        color: #6b7280;
        margin-bottom: 16px;
    }

    .teacher-setup-section {
        padding: 18px;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        background: #fff;
        margin-top: 16px;
        overflow: hidden;
    }

    .teacher-setup-section.is-disabled {
        opacity: .5;
        background: #f8fafc;
    }

    .teacher-setup-section.is-disabled .teacher-setup-dropzone,
    .teacher-setup-section.is-disabled .teacher-setup-modal-actions,
    .teacher-setup-section.is-disabled .teacher-setup-grid,
    .teacher-setup-section.is-disabled .teacher-slots-grid,
    .teacher-setup-section.is-disabled .teacher-setup-total {
        pointer-events: none;
    }

    .teacher-setup-flow-note {
        margin: 0;
        padding: 14px 16px;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        background: #f8fafc;
        color: #4b5563;
        line-height: 1.7;
    }

    .teacher-setup-flow-note strong {
        color: #111E27;
    }

    .teacher-setup-step-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
    }

    .teacher-setup-step-title {
        margin: 0;
        font-size: 20px;
        font-weight: 800;
        color: #111E27;
    }

    .teacher-setup-step-copy {
        margin: 6px 0 0;
        color: #6b7280;
        line-height: 1.6;
    }

    .teacher-setup-step-badge {
        flex-shrink: 0;
        min-width: 38px;
        height: 38px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f1efff;
        color: #5f46d8;
        font-weight: 800;
    }

    .teacher-setup-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .teacher-setup-label {
        display: block;
        font-weight: 700;
        color: #111E27;
        margin-bottom: 8px;
    }

    .teacher-setup-select {
        width: 100%;
        padding: 12px 14px;
        border: 1px solid #d1d5db;
        border-radius: 14px;
        background: #fff;
        color: #111E27;
        font-weight: 600;
    }

    .teacher-slots-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 12px;
        margin-top: 16px;
    }

    .teacher-slot-card {
        padding: 14px;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        background: #faf9ff;
    }

    .teacher-slot-card h4 {
        margin: 0 0 6px;
        font-size: 18px;
        font-weight: 800;
        color: #111E27;
    }

    .teacher-slot-card p {
        margin: 0 0 12px;
        font-size: 13px;
        color: #6b7280;
    }

    .teacher-slot-counter {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .teacher-slot-counter button {
        width: 36px;
        height: 36px;
        border: 1px solid #d1d5db;
        border-radius: 999px;
        background: #fff;
        font-weight: 800;
        color: #111E27;
    }

    .teacher-slot-counter span {
        min-width: 28px;
        text-align: center;
        font-size: 18px;
        font-weight: 800;
        color: #111E27;
    }

    .teacher-setup-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-top: 16px;
        padding: 14px 16px;
        border-radius: 16px;
        background: #f8fafc;
    }

    .teacher-setup-total-badge {
        padding: 8px 14px;
        border-radius: 999px;
        background: #f1efff;
        color: #5f46d8;
        font-weight: 800;
    }

    .teacher-setup-dropzone {
        border: 2px dashed #cec8ff;
        border-radius: 20px;
        background: #faf9ff;
        padding: 32px;
        text-align: center;
    }

    .teacher-setup-file-summary {
        margin-top: 14px;
        padding: 12px 14px;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        background: #fff;
        color: #374151;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        text-align: left;
        word-break: break-word;
    }

    .teacher-setup-file-summary strong {
        flex: 1 1 260px;
        min-width: 0;
    }

    .teacher-setup-file-summary .text-secondary {
        flex-shrink: 0;
        white-space: nowrap;
    }

    .teacher-setup-inline-error {
        display: none;
        margin-top: 14px;
        padding: 12px 14px;
        border: 1px solid #fecaca;
        border-radius: 16px;
        background: #fef2f2;
        color: #b91c1c;
        text-align: left;
        line-height: 1.6;
    }

    .teacher-setup-inline-error.show {
        display: block;
    }

    .teacher-setup-modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .teacher-setup-status {
        margin-top: 14px;
        padding: 12px 14px;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        background: #f8fafc;
        color: #374151;
        line-height: 1.6;
    }

    .teacher-setup-status strong {
        color: #111E27;
    }

    .teacher-setup-progress {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin: 18px 0;
    }

    .teacher-setup-progress-step {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        background: #fff;
        color: #6b7280;
    }

    .teacher-setup-progress-step.is-active {
        border-color: #c7bfff;
        background: #faf9ff;
        color: #111E27;
    }

    .teacher-setup-progress-step.is-complete {
        border-color: #bbf7d0;
        background: #f0fdf4;
        color: #166534;
    }

    .teacher-setup-progress-badge {
        flex-shrink: 0;
        width: 34px;
        height: 34px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f1efff;
        color: #5f46d8;
        font-weight: 800;
    }

    .teacher-setup-progress-step.is-complete .teacher-setup-progress-badge {
        background: #dcfce7;
        color: #166534;
    }

    .teacher-setup-progress-text strong {
        display: block;
        font-size: 15px;
        font-weight: 800;
        color: inherit;
    }

    .teacher-setup-progress-text span {
        display: block;
        font-size: 12px;
        line-height: 1.5;
        color: inherit;
        opacity: .9;
    }

    .teacher-setup-page {
        display: none;
    }

    .teacher-setup-page.is-active {
        display: block;
    }

    .teacher-setup-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-top: 18px;
    }

    .teacher-setup-footer-copy {
        margin: 0;
        color: #6b7280;
        font-size: 14px;
        line-height: 1.6;
    }

    .teacher-setup-card-badge-ready {
        background: #f0fdf4;
        color: #166534;
        border-color: #bbf7d0 !important;
    }

    @@media (max-width: 991.98px) {
        .teacher-setup-grid,
        .teacher-slots-grid,
        .teacher-setup-progress {
            grid-template-columns: 1fr;
        }

        .teacher-setup-footer {
            flex-direction: column;
            align-items: stretch;
        }

        .teacher-setup-modal {
            width: min(96vw, 760px);
            max-height: calc(100vh - 32px);
            padding: 18px;
        }

        .teacher-setup-dropzone {
            padding: 24px 18px;
        }
    }
</style>

<div class="teacher-shell">
    <partial name="_TeacherSidebar" />
    <div class="teacher-shell-content">
<div class="container py-4">

    <div class="row g-4 align-items-stretch">

        <div class="col-12 col-lg-6">
            <div class="p-4 rounded-4 bg-info bg-opacity-25 h-100 d-flex align-items-center gap-4">
                <img src="~/img/UserLogo.png"
                     class="rounded-circle img-fluid"
                     style="width:130px;height:130px;object-fit:cover"
                     alt="Profile">

                <div>
                    <h6 class="fw-bold mb-1 text-uppercase" id="teacherWelcomeText">
                        Welcome, Teacher!
                    </h6>

                    <p class="mb-3 text-secondary">
                        Everything you need to support your students is right here.
                    </p>

                    <div class="d-flex flex-wrap gap-3 text-secondary">
                        <span id="teacherDashboardGrade">
                            <i class="bi bi-book me-1"></i> Grade
                        </span>
                        <span id="teacherDashboardSection">
                            <i class="bi bi-diagram-3 me-1"></i> Section -
                        </span>
                        <span id="teacherDashboardStudentCount">
                            <i class="bi bi-people me-1"></i> Total of 0 Students
                        </span>
                    </div>
                </div>

            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="row g-4">

                <div class="col-6">
                    <div class="p-3 border rounded-4 h-100">
                        <i class="bi bi-mortarboard fs-4"></i>
                        <h5 class="fw-bold mt-2 mb-1" id="teacherDashboardOverallProgressValue">0%</h5>
                        <p class="text-secondary mb-0">overall progress</p>
                    </div>
                </div>

                <div class="col-6">
                    <div class="p-3 border rounded-4 h-100">
                        <i class="bi bi-journal-check fs-4"></i>
                        <h5 class="fw-bold mt-2 mb-1" id="teacherDashboardClassesRemainingValue">0</h5>
                        <p class="text-secondary mb-0">classes remaining</p>
                    </div>
                </div>

                <div class="col-6">
                    <div class="p-3 border rounded-4 h-100">
                        <i class="bi bi-exclamation-triangle fs-4"></i>
                        <h5 class="fw-bold mt-2 mb-1" id="teacherDashboardAtRiskValue">0</h5>
                        <p class="text-secondary mb-0">at risk students</p>
                    </div>
                </div>

            </div>
        </div>

    </div>

</div>
<div class="container pb-2">
    <div class="d-flex justify-content-end">
        <div class="dropdown">
            <button class="btn btn-light border dropdown-toggle fw-semibold"
                    data-bs-toggle="dropdown"
                    data-dashboard-subject-label>
                Subject
            </button>
            <ul class="dropdown-menu" data-dashboard-subject-menu>
            </ul>
        </div>
    </div>
</div>
<div class="container py-5 d-none" id="planProgressSection">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="border rounded-4 shadow-sm p-4 bg-white">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <h4 class="fw-bold mb-1">Current Plan Progress</h4>
                        <p class="text-secondary mb-0" id="dashboardPlanSummaryText">
                            Track how the generated plan is moving and jump back into it.
                        </p>
                    </div>
                    <div class="d-flex gap-2">
                        <a class="btn btn-outline-secondary rounded-pill px-4" asp-controller="Home" asp-action="History">Plan History</a>
                        <a class="btn btn-info rounded-pill px-4 fw-semibold" asp-controller="Home" asp-action="Analysis">Open Plan</a>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold text-dark" id="dashboardPlanLabel">No generated plan</span>
                        <span class="fw-bold text-success" id="dashboardPlanProgressValue">0%</span>
                    </div>
                    <div class="progress rounded-pill" style="height:18px;">
                        <div class="progress-bar bg-success rounded-pill" id="dashboardPlanProgressBar" style="width:0%"></div>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-12 col-md-3">
                        <div class="border rounded-4 p-3 h-100">
                            <div class="small text-secondary mb-1">Completed items</div>
                            <div class="fw-bold fs-4" id="dashboardCompletedItems">0</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <div class="border rounded-4 p-3 h-100">
                            <div class="small text-secondary mb-1">Remaining items</div>
                            <div class="fw-bold fs-4" id="dashboardRemainingItems">0</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <div class="border rounded-4 p-3 h-100">
                            <div class="small text-secondary mb-1">Class speed</div>
                            <div class="fw-bold fs-4 text-primary" id="dashboardClassSpeed">100%</div>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <div class="border rounded-4 p-3 h-100">
                            <div class="small text-secondary mb-1">Reorder status</div>
                            <div class="fw-bold fs-6" id="dashboardReorderStatus">On track</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5" id="uploadAssessmentSection">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="teacher-setup-card">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                    <div>
                        <h4 class="fw-bold mb-2" id="dashboardSetupTitle">Set up Arabic</h4>
                        <p class="text-secondary mb-0" id="dashboardGenerateSubjectText">
                            Start with the students file, then save the semester and weekly slots, then upload the baseline and generate the plan.
                        </p>
                    </div>
                    <span id="dashboardSetupStatusBadge" class="badge rounded-pill text-bg-light border px-3 py-2">Setup needed</span>
                </div>

                <div class="teacher-setup-actions">
                    <button type="button"
                            class="btn btn-info rounded-pill px-4 fw-semibold"
                            id="openSetupModalButton">
                        Set up subject
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="teacherSetupModalBackdrop" class="teacher-setup-modal-backdrop d-none"></div>
<div id="teacherSetupModal" class="teacher-setup-modal d-none" aria-label="Set up subject plan">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h3 id="teacherSetupModalTitle">Set up Arabic</h3>
            <p id="teacherSetupModalCopy">Complete the setup in order: students first, then weekly slots, then baseline upload and plan generation.</p>
        </div>
        <button type="button" class="btn btn-light border rounded-pill px-3" id="closeSetupModalButton">Close</button>
    </div>

    <div class="teacher-setup-flow-note">
        <strong>Setup order:</strong> upload students first, then save semester and weekly slots, then upload the baseline and generate the plan.
    </div>

    <div class="teacher-setup-progress">
        <div class="teacher-setup-progress-step" data-setup-progress-step="1">
            <span class="teacher-setup-progress-badge">1</span>
            <div class="teacher-setup-progress-text">
                <strong>Students</strong>
                <span>Set up the class student list.</span>
            </div>
        </div>
        <div class="teacher-setup-progress-step" data-setup-progress-step="2">
            <span class="teacher-setup-progress-badge">2</span>
            <div class="teacher-setup-progress-text">
                <strong>Weekly slots</strong>
                <span>Choose semester and weekly teaching slots.</span>
            </div>
        </div>
        <div class="teacher-setup-progress-step" data-setup-progress-step="3">
            <span class="teacher-setup-progress-badge">3</span>
            <div class="teacher-setup-progress-text">
                <strong>Baseline</strong>
                <span>Upload the baseline and generate the plan.</span>
            </div>
        </div>
    </div>

    <div id="studentsSetupPage" class="teacher-setup-page">
        <div class="teacher-setup-section mt-0">
            <div class="teacher-setup-step-head">
                <div>
                    <h4 class="teacher-setup-step-title">Upload students</h4>
                    <p class="teacher-setup-step-copy">
                        Start with the student file for this class. Once it is uploaded, the setup continues to weekly slots.
                    </p>
                </div>
                <span class="teacher-setup-step-badge">1</span>
            </div>

            <div class="teacher-setup-dropzone">
                <i class="bi bi-people fs-1 text-primary mb-3 d-block"></i>
                <div class="fw-semibold mb-2">Upload students Excel</div>
                <div class="text-secondary mb-3">Choose the class student file first. The saved students are used later when matching the baseline.</div>
                <label for="studentsSetupFileInput" class="btn btn-light border rounded-pill px-4 fw-semibold">Choose file</label>
                <input id="studentsSetupFileInput" type="file" class="d-none" accept=".xlsx">
                <div class="small text-secondary mt-3">Only `.xlsx` files are accepted for student setup.</div>
                <div id="studentsSetupFileError" class="teacher-setup-inline-error"></div>
                <div id="studentsSetupFileSummary" class="teacher-setup-file-summary d-none"></div>
            </div>

            <div class="teacher-setup-modal-actions">
                <button type="button" class="btn btn-info rounded-pill px-4 fw-semibold" id="uploadStudentsSetupButton">
                    Upload students and continue
                </button>
            </div>

            <div id="studentsSetupStatus" class="teacher-setup-status">
                <strong>Students are required before plan setup.</strong>
                <div class="small text-secondary mt-1" id="studentsSetupStatusText">No students are set up for this teacher yet.</div>
            </div>
        </div>
    </div>

    <div id="weeklySlotsPage" class="teacher-setup-page">
        <div id="weeklySlotsSection" class="teacher-setup-section mt-0">
            <div class="teacher-setup-step-head">
                <div>
                    <h4 class="teacher-setup-step-title">Set semester and weekly slots</h4>
                    <p class="teacher-setup-step-copy">
                        Choose the semester and define the weekly teaching slots for this subject before baseline upload.
                    </p>
                </div>
                <span class="teacher-setup-step-badge">2</span>
            </div>

            <div class="teacher-setup-grid">
                <div>
                    <label class="teacher-setup-label">Subject</label>
                    <input id="setupSubjectDisplay" type="text" class="teacher-setup-select" readonly />
                </div>
                <div>
                    <label for="setupSemesterSelect" class="teacher-setup-label">Semester</label>
                    <select id="setupSemesterSelect" class="teacher-setup-select">
                        <option value="">Select semester</option>
                        <option value="1">1st semester</option>
                        <option value="2">2nd semester</option>
                    </select>
                </div>
            </div>

            <div id="setupSlotsGrid" class="teacher-slots-grid"></div>

            <div class="teacher-setup-total">
                <div>
                    <strong>Total weekly slots</strong>
                    <div class="text-secondary small" id="setupWeeklySlotsHint">Save weekly slots before uploading the baseline.</div>
                </div>
                <span id="setupTotalSlotsBadge" class="teacher-setup-total-badge">0</span>
            </div>

            <div class="teacher-setup-modal-actions">
                <button type="button" class="btn btn-light border rounded-pill px-4 fw-semibold" id="saveWeeklySlotsButton">
                    Save weekly slots and continue
                </button>
            </div>
        </div>
    </div>

    <div id="baselineSetupPage" class="teacher-setup-page">
        <div id="baselineUploadSection" class="teacher-setup-section mt-0">
            <div class="teacher-setup-step-head">
                <div>
                    <h4 class="teacher-setup-step-title">Upload baseline and generate plan</h4>
                    <p class="teacher-setup-step-copy">
                        Students and weekly slots are ready. Upload the baseline file for this subject and generate the plan.
                    </p>
                </div>
                <span class="teacher-setup-step-badge">3</span>
            </div>

            <div class="teacher-setup-dropzone" id="setupDropArea">
                <i class="bi bi-cloud-arrow-up fs-1 text-primary mb-3 d-block"></i>
                <div class="fw-semibold mb-2">Upload baseline Excel</div>
                <div class="text-secondary mb-3">Drag and drop the completed `.xlsx` file here or choose it manually.</div>
                <label for="setupFileInput" class="btn btn-light border rounded-pill px-4 fw-semibold">Choose file</label>
                <input id="setupFileInput" type="file" class="d-none" accept=".xlsx" disabled>
                <div class="small text-secondary mt-3">Only `.xlsx` files are accepted for this subject setup.</div>
                <div id="setupFileError" class="teacher-setup-inline-error"></div>
                <div id="setupFileSummary" class="teacher-setup-file-summary d-none"></div>
            </div>

            <div class="teacher-setup-modal-actions">
                <button type="button" class="btn btn-info rounded-pill px-4 fw-semibold" id="generatePlanButton">
                    Generate plan
                </button>
            </div>
        </div>
    </div>

    <div class="teacher-setup-footer">
        <p id="teacherSetupFooterCopy" class="teacher-setup-footer-copy">Step 1 of 3: upload students for this teacher.</p>
        <button type="button" class="btn btn-light border rounded-pill px-4 d-none" id="setupBackButton">Back</button>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const backendBaseUrl = "http://localhost:3000";
    const uploadAssessmentSection = document.getElementById("uploadAssessmentSection");
    const planProgressSection = document.getElementById("planProgressSection");
    const dashboardPlanSummaryText = document.getElementById("dashboardPlanSummaryText");
    const dashboardPlanLabel = document.getElementById("dashboardPlanLabel");
    const dashboardPlanProgressValue = document.getElementById("dashboardPlanProgressValue");
    const dashboardPlanProgressBar = document.getElementById("dashboardPlanProgressBar");
    const dashboardCompletedItems = document.getElementById("dashboardCompletedItems");
    const dashboardRemainingItems = document.getElementById("dashboardRemainingItems");
    const dashboardClassSpeed = document.getElementById("dashboardClassSpeed");
    const dashboardReorderStatus = document.getElementById("dashboardReorderStatus");
    const teacherDashboardSubjectLabels = Array.from(document.querySelectorAll("[data-dashboard-subject-label]"));
    const teacherDashboardSubjectMenus = Array.from(document.querySelectorAll("[data-dashboard-subject-menu]"));
    const teacherDashboardSkillFilterButton = document.getElementById("teacherDashboardSkillFilterButton");
    const teacherDashboardSkillsList = document.getElementById("teacherDashboardSkillsList");
    const teacherDashboardSkillsEmpty = document.getElementById("teacherDashboardSkillsEmpty");
    const teacherDashboardTasksBody = document.getElementById("teacherDashboardTasksBody");
    const teacherDashboardTasksEmptyRow = document.getElementById("teacherDashboardTasksEmptyRow");
    const teacherDashboardTasksPrevious = document.getElementById("teacherDashboardTasksPrevious");
    const teacherDashboardTasksNext = document.getElementById("teacherDashboardTasksNext");
    const teacherDashboardTasksPageText = document.getElementById("teacherDashboardTasksPageText");
    let currentDashboardSubjectId = localStorage.getItem("teacherSelectedSubject") || "2";
    let selectedBaselineFiles = [];
    let teacherDashboardSkillRows = [];
    let teacherDashboardSkillSort = "lowest";
    let teacherDashboardTasks = [];
    let teacherDashboardTaskPage = 1;
    const teacherDashboardTasksPageSize = 5;
    let teacherDashboardPlanSubjects = [];
