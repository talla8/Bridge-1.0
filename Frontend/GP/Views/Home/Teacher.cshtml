    const teacherDashboardGrade = document.getElementById("teacherDashboardGrade");
    const teacherDashboardSection = document.getElementById("teacherDashboardSection");
    const teacherDashboardStudentCount = document.getElementById("teacherDashboardStudentCount");
    const teacherDashboardOverallProgressValue = document.getElementById("teacherDashboardOverallProgressValue");
    const teacherDashboardClassesRemainingValue = document.getElementById("teacherDashboardClassesRemainingValue");
    const teacherDashboardAtRiskValue = document.getElementById("teacherDashboardAtRiskValue");
    const dashboardGenerateSubjectText = document.getElementById("dashboardGenerateSubjectText");
    const dashboardSetupTitle = document.getElementById("dashboardSetupTitle");
    const dashboardSetupStatusBadge = document.getElementById("dashboardSetupStatusBadge");
    const openSetupModalButton = document.getElementById("openSetupModalButton");
    const teacherSetupModal = document.getElementById("teacherSetupModal");
    const teacherSetupModalBackdrop = document.getElementById("teacherSetupModalBackdrop");
    const closeSetupModalButton = document.getElementById("closeSetupModalButton");
    const teacherSetupModalTitle = document.getElementById("teacherSetupModalTitle");
    const teacherSetupModalCopy = document.getElementById("teacherSetupModalCopy");
    const teacherSetupProgressSteps = Array.from(document.querySelectorAll("[data-setup-progress-step]"));
    const studentsSetupPage = document.getElementById("studentsSetupPage");
    const weeklySlotsPage = document.getElementById("weeklySlotsPage");
    const baselineSetupPage = document.getElementById("baselineSetupPage");
    const teacherSetupFooterCopy = document.getElementById("teacherSetupFooterCopy");
    const setupBackButton = document.getElementById("setupBackButton");
    const setupDropArea = document.getElementById("setupDropArea");
    const setupFileInput = document.getElementById("setupFileInput");
    const setupFileSummary = document.getElementById("setupFileSummary");
    const setupFileError = document.getElementById("setupFileError");
    const studentsSetupFileInput = document.getElementById("studentsSetupFileInput");
    const studentsSetupFileSummary = document.getElementById("studentsSetupFileSummary");
    const studentsSetupFileError = document.getElementById("studentsSetupFileError");
    const uploadStudentsSetupButton = document.getElementById("uploadStudentsSetupButton");
    const studentsSetupStatusText = document.getElementById("studentsSetupStatusText");
    const weeklySlotsSection = document.getElementById("weeklySlotsSection");
    const setupSubjectDisplay = document.getElementById("setupSubjectDisplay");
    const setupSemesterSelect = document.getElementById("setupSemesterSelect");
    const setupSlotsGrid = document.getElementById("setupSlotsGrid");
    const setupTotalSlotsBadge = document.getElementById("setupTotalSlotsBadge");
    const setupWeeklySlotsHint = document.getElementById("setupWeeklySlotsHint");
    const saveWeeklySlotsButton = document.getElementById("saveWeeklySlotsButton");
    const baselineUploadSection = document.getElementById("baselineUploadSection");
    const generatePlanButton = document.getElementById("generatePlanButton");
    const weeklySlotDays = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday"];
    let setupSlotCounts = Object.fromEntries(weeklySlotDays.map((day) => [day, 0]));
    let setupWeeklySlotsSaved = false;
    let setupStudentsReady = false;
    let selectedStudentsSetupFile = null;
    let currentSetupStep = 1;

    function getMinimumWeeklySlots(subjectId) {
      if (String(subjectId) === "2") {
        return 7;
      }

      if (String(subjectId) === "1") {
        return 5;
      }

      return 1;
    }

    function setTeacherDashboardHeader(profile, studentCount) {
      const fullName = profile?.fullName || sessionStorage.getItem("bridgeUserName") || "Teacher";
      const grade = profile?.grade || sessionStorage.getItem("bridgeTeacherGrade") || "";
      const section = sessionStorage.getItem("bridgeTeacherSection") || "";

      if (teacherWelcomeText) {
        teacherWelcomeText.textContent = `Welcome, ${fullName}!`;
      }

      if (teacherDashboardGrade) {
        teacherDashboardGrade.innerHTML = `<i class="bi bi-book me-1"></i> ${grade || "Grade -"}`;
      }

      if (teacherDashboardSection) {
        teacherDashboardSection.innerHTML = `<i class="bi bi-diagram-3 me-1"></i> ${section ? `Section ${section}` : "Section -"}`;
      }

      if (teacherDashboardStudentCount) {
        teacherDashboardStudentCount.innerHTML = `<i class="bi bi-people me-1"></i> Total of ${studentCount} Students`;
      }
    }

    function setTeacherDashboardTopMetrics({
      overallProgress = 0,
      classesRemaining = 0,
      atRiskStudents = 0
    } = {}) {
      if (teacherDashboardOverallProgressValue) {
        teacherDashboardOverallProgressValue.textContent = `${Math.max(0, Number(overallProgress) || 0)}%`;
      }

      if (teacherDashboardClassesRemainingValue) {
        teacherDashboardClassesRemainingValue.textContent = String(Math.max(0, Number(classesRemaining) || 0));
      }

      if (teacherDashboardAtRiskValue) {
        teacherDashboardAtRiskValue.textContent = String(Math.max(0, Number(atRiskStudents) || 0));
      }
    }

    async function hydrateTeacherDashboardHeader() {
      const token = sessionStorage.getItem("bridgeAccessToken");

      if (!token) {
        setTeacherDashboardHeader(null, 0);
        return;
      }

      try {
        const [profileResponse, studentsResponse] = await Promise.all([
          fetch(`${backendBaseUrl}/auth/profile`, {
            headers: {
              Authorization: `Bearer ${token}`
            }
          }),
          fetch(`${backendBaseUrl}/students/myStudents`, {
            headers: {
              Authorization: `Bearer ${token}`
            }
          })
        ]);

        const profile = profileResponse.ok ? await profileResponse.json() : null;
        const students = studentsResponse.ok ? await studentsResponse.json() : [];

        if (profile?.fullName) {
          sessionStorage.setItem("bridgeUserName", profile.fullName);
        }

        if (profile?.grade) {
          sessionStorage.setItem("bridgeTeacherGrade", profile.grade);
        }

        setTeacherDashboardHeader(profile, Array.isArray(students) ? students.length : 0);
      } catch {
        setTeacherDashboardHeader(null, 0);
      }
    }

    hydrateTeacherDashboardHeader();

    function setDashboardMode(hasPlan) {
      uploadAssessmentSection?.classList.toggle("d-none", hasPlan);
      planProgressSection?.classList.toggle("d-none", !hasPlan);
    }

    function getSubjectName(subjectId) {
      return String(subjectId) === "1" ? "Math" : String(subjectId) === "2" ? "Arabic" : "Subject";
    }

    function getTaskContextLabel(task) {
      if (task?.description?.trim()) {
        return task.description.trim();
      }

      if (task?.item?.notes?.trim()) {
        return task.item.notes.trim();
      }

      if (task?.day && task?.slotNumber) {
        return `${task.day} • Slot ${task.slotNumber}`;
      }

      return "-";
    }

    function getSubjectPlanStorageKey(subjectId) {
      return `bridgeGeneratedPlan:${subjectId}`;
    }

    function getSubjectSemesterStorageKey(subjectId) {
      return `teacherSelectedSemester:${subjectId}`;
    }

    function getSubjectWeeklySlotsStorageKey(subjectId) {
      return `teacherWeeklySlots:${subjectId}`;
    }

    function renderTeacherDashboardSubjectMenus() {
      const subjectIds = teacherDashboardPlanSubjects.length
        ? teacherDashboardPlanSubjects
        : teacherDashboardCoreSubjects;

      teacherDashboardSubjectMenus.forEach((menu) => {
        menu.innerHTML = subjectIds
          .map((subjectId) => `
            <li>
              <button
                type="button"
                class="dropdown-item ${String(subjectId) === String(currentDashboardSubjectId) ? "active" : ""}"
                data-subject-dashboard-id="${subjectId}">
                ${getSubjectName(subjectId)}
              </button>
            </li>
          `)
          .join("");
      });

      document.querySelectorAll("[data-subject-dashboard-id]").forEach((button) => {
        button.addEventListener("click", () => {
          const subjectId = button.getAttribute("data-subject-dashboard-id") || currentDashboardSubjectId;
          currentDashboardSubjectId = subjectId;
          localStorage.setItem("teacherSelectedSubject", subjectId);
          setTeacherDashboardSubjectLabels(getSubjectName(subjectId));
          renderTeacherDashboardSubjectMenus();
          initializeSetupFormForSubject();
          hydrateTeacherPlanState();
          hydrateTeacherDashboardSkillsAndTasks();
        });
      });
    }

    async function hydrateTeacherDashboardSubjects() {
      const token = sessionStorage.getItem("bridgeAccessToken");

      if (!token) {
        teacherDashboardPlanSubjects = [...teacherDashboardCoreSubjects];
        renderTeacherDashboardSubjectMenus();
        return;
      }

      try {
        const response = await fetch(`${backendBaseUrl}/plans/mine`, {
          headers: {
            Authorization: `Bearer ${token}`
          }
        });

        const plans = response.ok ? await response.json().catch(() => []) : [];
        const subjectIds = Array.from(
          new Set(
            [...teacherDashboardCoreSubjects, ...(Array.isArray(plans) ? plans : [])
              .map((plan) => String(plan?.subjectId || "").trim())
              .filter(Boolean)]
          )
        );

        teacherDashboardPlanSubjects = subjectIds.length ? subjectIds : [...teacherDashboardCoreSubjects];

        if (!teacherDashboardPlanSubjects.includes(String(currentDashboardSubjectId))) {
          currentDashboardSubjectId = teacherDashboardPlanSubjects[0];
          localStorage.setItem("teacherSelectedSubject", currentDashboardSubjectId);
        }

        setTeacherDashboardSubjectLabels(getSubjectName(currentDashboardSubjectId));
        renderTeacherDashboardSubjectMenus();
      } catch {
        teacherDashboardPlanSubjects = [...teacherDashboardCoreSubjects];
        renderTeacherDashboardSubjectMenus();
      }
    }

    function setTeacherDashboardSubjectLabels(label) {
      teacherDashboardSubjectLabels.forEach((button) => {
        button.textContent = label;
      });

      if (dashboardSetupTitle) {
        dashboardSetupTitle.textContent = `Set up ${label}`;
      }

      if (teacherSetupModalTitle) {
        teacherSetupModalTitle.textContent = `Set up ${label}`;
      }

      if (teacherSetupModalCopy) {
        teacherSetupModalCopy.textContent = `Finish the ${label} setup in order: upload students, save semester and weekly slots, then upload the baseline and generate the plan.`;
      }

      if (setupSubjectDisplay) {
        setupSubjectDisplay.value = label;
      }
    }

    function determineSetupStep() {
      if (!setupStudentsReady) {
        return 1;
      }

      if (!setupWeeklySlotsSaved) {
        return 2;
      }

      return 3;
    }

    function updateDashboardSetupState() {
      const label = getSubjectName(currentDashboardSubjectId);
      const needsStudents = !setupStudentsReady;
      const needsSlots = !setupWeeklySlotsSaved;
      const baselineReady = !needsStudents && !needsSlots;

      if (dashboardSetupTitle) {
        dashboardSetupTitle.textContent = baselineReady
          ? `${label} baseline`
          : `Set up ${label}`;
      }

      if (dashboardGenerateSubjectText) {
        if (needsStudents) {
          dashboardGenerateSubjectText.textContent = `${label} still needs student setup before you can continue with weekly slots and baseline upload.`;
        } else if (needsSlots) {
          dashboardGenerateSubjectText.textContent = `${label} students are ready. Save the semester and weekly slots to unlock the baseline upload.`;
        } else {
          dashboardGenerateSubjectText.textContent = `${label} is ready for baseline upload. Open the setup and upload the baseline file to generate the plan.`;
        }
      }

      if (dashboardSetupStatusBadge) {
        dashboardSetupStatusBadge.textContent = baselineReady ? "Baseline ready" : "Setup needed";
        dashboardSetupStatusBadge.classList.toggle("teacher-setup-card-badge-ready", baselineReady);
      }

      if (openSetupModalButton) {
        openSetupModalButton.textContent = baselineReady
          ? `Upload ${label} baseline`
          : `Set up ${label}`;
      }
    }

    function setSetupPage(step) {
      currentSetupStep = step;
      studentsSetupPage?.classList.toggle("is-active", step === 1);
      weeklySlotsPage?.classList.toggle("is-active", step === 2);
      baselineSetupPage?.classList.toggle("is-active", step === 3);

      teacherSetupProgressSteps.forEach((item) => {
        const itemStep = Number(item.getAttribute("data-setup-progress-step") || "0");
        item.classList.toggle("is-active", itemStep === step);
        item.classList.toggle("is-complete", itemStep < step);
      });

      if (teacherSetupFooterCopy) {
        if (step === 1) {
          teacherSetupFooterCopy.textContent = "Step 1 of 3: upload the class student file first.";
        } else if (step === 2) {
          teacherSetupFooterCopy.textContent = "Step 2 of 3: choose the semester and save the weekly teaching slots.";
        } else {
          teacherSetupFooterCopy.textContent = "Step 3 of 3: upload the baseline file and generate the subject plan.";
        }
      }

      if (setupBackButton) {
        const showBack = (step === 2 && setupStudentsReady) || step === 3;
        setupBackButton.classList.toggle("d-none", !showBack);
      }
    }

    function openSetupModal() {
      initializeSetupFormForSubject().finally(() => {
        teacherSetupModal?.classList.remove("d-none");
        teacherSetupModalBackdrop?.classList.remove("d-none");
      });
    }

    function closeSetupModal() {
      teacherSetupModal?.classList.add("d-none");
      teacherSetupModalBackdrop?.classList.add("d-none");
    }

    function updateSetupTotalSlots() {
      const total = Object.values(setupSlotCounts).reduce((sum, value) => sum + value, 0);
      if (setupTotalSlotsBadge) {
        setupTotalSlotsBadge.textContent = String(total);
      }
      if (setupWeeklySlotsHint) {
        const minimumWeeklySlots = getMinimumWeeklySlots(currentDashboardSubjectId);
        setupWeeklySlotsHint.textContent = `Minimum ${minimumWeeklySlots} weekly slots for ${getSubjectName(currentDashboardSubjectId)}. Save weekly slots before uploading the baseline.`;
      }
      return total;
    }

    function renderStudentsSetupFile(file) {
      if (!studentsSetupFileSummary) {
        return;
      }

      if (!file) {
        studentsSetupFileSummary.classList.add("d-none");
        studentsSetupFileSummary.innerHTML = "";
        return;
      }

      studentsSetupFileSummary.classList.remove("d-none");
      studentsSetupFileSummary.innerHTML = `
        <strong>${file.name}</strong>
        <span class="text-secondary">(${(file.size / 1024).toFixed(1)} KB)</span>
      `;
    }

    function showFileError(target, message) {
      if (!target) {
        return;
      }

      target.textContent = message;
      target.classList.add("show");
    }

    function hideFileError(target) {
      if (!target) {
        return;
      }

      target.textContent = "";
      target.classList.remove("show");
    }

    function isAcceptedExcelFile(file) {
      if (!file?.name) {
        return false;
      }

      return file.name.toLowerCase().endsWith(".xlsx");
    }

    function setWeeklySlotsEnabled(enabled) {
      weeklySlotsSection?.classList.toggle("is-disabled", !enabled);
      if (setupSemesterSelect) {
        setupSemesterSelect.disabled = !enabled;
      }
      setupSlotsGrid?.querySelectorAll("button").forEach((button) => {
        button.disabled = !enabled;
      });
      if (saveWeeklySlotsButton) {
        saveWeeklySlotsButton.disabled = !enabled;
      }
    }

    function updateSetupCountDisplay(day) {
      const target = document.getElementById(`setup-count-${day}`);
      if (target) {
        target.textContent = String(setupSlotCounts[day]);
      }
    }

    function buildSetupSlotsGrid() {
      if (!setupSlotsGrid) {
        return;
      }

      setupSlotsGrid.innerHTML = "";
      weeklySlotDays.forEach((day) => {
        const card = document.createElement("div");
        card.className = "teacher-slot-card";
        card.innerHTML = `
          <h4>${day}</h4>
          <p>Available teaching slots.</p>
          <div class="teacher-slot-counter">
            <button type="button" data-setup-day="${day}" data-setup-action="decrease">-</button>
            <span id="setup-count-${day}">${setupSlotCounts[day]}</span>
            <button type="button" data-setup-day="${day}" data-setup-action="increase">+</button>
          </div>
        `;
        setupSlotsGrid.appendChild(card);
      });
    }

    function setBaselineUploadEnabled(enabled) {
      baselineUploadSection?.classList.toggle("is-disabled", !enabled);
      if (setupFileInput) {
        setupFileInput.disabled = !enabled;
      }
      setGenerateButtonEnabled(enabled && Boolean(selectedBaselineFiles[0]));
    }

    function setGenerateButtonEnabled(enabled) {
      if (!generatePlanButton) {
        return;
      }

      generatePlanButton.disabled = !enabled;
      generatePlanButton.classList.toggle("opacity-50", !enabled);
    }

    async function initializeSetupFormForSubject() {
      const token = sessionStorage.getItem("bridgeAccessToken");
      const subjectId = currentDashboardSubjectId;
      const storedSemester = localStorage.getItem(getSubjectSemesterStorageKey(subjectId))
        || localStorage.getItem("teacherSelectedSemester")
        || "";
      const storedSlotCounts = localStorage.getItem(getSubjectWeeklySlotsStorageKey(subjectId));

      setupWeeklySlotsSaved = false;
      setupStudentsReady = false;
      selectedStudentsSetupFile = null;
      selectedBaselineFiles = [];
      setupSemesterSelect.value = storedSemester;
      setupSlotCounts = Object.fromEntries(weeklySlotDays.map((day) => [day, 0]));

      if (storedSlotCounts) {
        try {
          const parsed = JSON.parse(storedSlotCounts);
          weeklySlotDays.forEach((day) => {
            setupSlotCounts[day] = Number(parsed?.[day] ?? 0);
          });
        } catch {}
      }

      if (token) {
        try {
          const studentsResponse = await fetch(`${backendBaseUrl}/students/myStudents`, {
            headers: { Authorization: `Bearer ${token}` }
          });
          const students = studentsResponse.ok ? await studentsResponse.json().catch(() => []) : [];
          const studentsCount = Array.isArray(students) ? students.length : 0;
          setupStudentsReady = studentsCount > 0;

          if (studentsSetupStatusText) {
            studentsSetupStatusText.textContent = setupStudentsReady
              ? `${studentsCount} student(s) are already set up for this teacher. You can upload another file to add more students if needed.`
              : "No students are set up for this teacher yet.";
          }

          const response = await fetch(`${backendBaseUrl}/plans/weekly-slots/${encodeURIComponent(subjectId)}`, {
            headers: { Authorization: `Bearer ${token}` }
          });

          const data = response.ok ? await response.json().catch(() => null) : null;
          if (data?.slots?.length) {
            setupSlotCounts = Object.fromEntries(weeklySlotDays.map((day) => [day, 0]));
            data.slots.forEach((slot) => {
              const day = String(slot?.day || "");
              if (day in setupSlotCounts) {
                setupSlotCounts[day] += 1;
              }
            });
            setupWeeklySlotsSaved = Boolean(storedSemester);
          }
        } catch {}
      }

      buildSetupSlotsGrid();
      updateSetupTotalSlots();
      renderStudentsSetupFile(null);
      renderSelectedFile(null);
      hideFileError(studentsSetupFileError);
      hideFileError(setupFileError);
      setWeeklySlotsEnabled(setupStudentsReady);
      setBaselineUploadEnabled(setupStudentsReady && setupWeeklySlotsSaved);
      updateDashboardSetupState();
      setSetupPage(determineSetupStep());
    }

    setupSlotsGrid?.addEventListener("click", (event) => {
      const button = event.target.closest("button[data-setup-day]");
      if (!button) {
        return;
      }

      const day = button.getAttribute("data-setup-day");
      const action = button.getAttribute("data-setup-action");
      const currentValue = setupSlotCounts[day];

      if (action === "increase" && currentValue < 7) {
        setupSlotCounts[day] = currentValue + 1;
      }

      if (action === "decrease" && currentValue > 0) {
        setupSlotCounts[day] = currentValue - 1;
      }

      setupWeeklySlotsSaved = false;
      updateSetupCountDisplay(day);
      updateSetupTotalSlots();
      setBaselineUploadEnabled(false);
    });

    studentsSetupFileInput?.addEventListener("change", (event) => {
      const selectedFile = event.target.files?.[0] ?? null;

      if (selectedFile && !isAcceptedExcelFile(selectedFile)) {
        selectedStudentsSetupFile = null;
        renderStudentsSetupFile(null);
        studentsSetupFileInput.value = "";
        showFileError(studentsSetupFileError, "Only .xlsx files are accepted here. Please choose the Excel template file.");
        return;
      }

      hideFileError(studentsSetupFileError);
      selectedStudentsSetupFile = selectedFile;
      renderStudentsSetupFile(selectedStudentsSetupFile);
    });

    function formatSkillTitle(skillId) {
      switch (String(skillId)) {
        case "skill_counting":
          return "Counting Skills";
        case "skill_number_manipulation":
          return "Number Manipulation";
        case "skill_problem_solving":
          return "Problem Solving";
        case "skill_vocal":
          return "Vocal Awareness";
        case "skill_sounds_of_letters":
          return "Sounds of Letters";
        case "skill_writing":
          return "Writing";
        default:
          return String(skillId || "Skill");
      }
    }

    function renderDashboardSkills() {
      if (!teacherDashboardSkillsList || !teacherDashboardSkillsEmpty) {
        return;
      }

      const rows = teacherDashboardSkillRows.slice().sort((left, right) =>
        teacherDashboardSkillSort === "highest"
          ? Number(right.avg ?? 0) - Number(left.avg ?? 0)
          : Number(left.avg ?? 0) - Number(right.avg ?? 0)
      );

      teacherDashboardSkillsList.innerHTML = "";
      if (!rows.length) {
        teacherDashboardSkillsEmpty.classList.remove("d-none");
        return;
      }

      teacherDashboardSkillsEmpty.classList.add("d-none");
      rows.forEach((row) => {
        const wrapper = document.createElement("div");
        wrapper.className = "mb-4";
        const pct = Math.max(0, Math.min(100, Number(row.avg ?? 0)));
        wrapper.innerHTML = `
          <div class="fw-semibold mb-2">${formatSkillTitle(row.skillId)}</div>
          <div class="progress rounded-pill" style="height:16px">
            <div class="progress-bar bg-primary bg-opacity-25 rounded-pill" style="width:${pct}%"></div>
          </div>
        `;
        teacherDashboardSkillsList.appendChild(wrapper);
      });
    }

    function formatTaskStatus(status) {
      return String(status || "OPEN")
        .replaceAll("_", " ")
        .replace(/\b\w/g, (char) => char.toUpperCase());
    }

    function formatTaskDate(value) {
      if (!value) return "-";
      const date = new Date(value);
      return Number.isNaN(date.getTime()) ? "-" : date.toLocaleDateString();
    }

    function getTaskTitle(task) {
      return task?.title || task?.item?.title || "-";
    }

    function getTaskStatus(task) {
      return task?.status || task?.item?.status || "OPEN";
    }

    function renderDashboardTasks() {
      if (!teacherDashboardTasksBody || !teacherDashboardTasksEmptyRow) {
        return;
      }

      const totalPages = Math.max(1, Math.ceil(teacherDashboardTasks.length / teacherDashboardTasksPageSize));
      teacherDashboardTaskPage = Math.min(Math.max(1, teacherDashboardTaskPage), totalPages);
      const startIndex = (teacherDashboardTaskPage - 1) * teacherDashboardTasksPageSize;
      const visibleRows = teacherDashboardTasks.slice(startIndex, startIndex + teacherDashboardTasksPageSize);

      teacherDashboardTasksBody.innerHTML = "";
      teacherDashboardTasksEmptyRow.classList.toggle("d-none", visibleRows.length > 0);

      visibleRows.forEach((task, index) => {
        const row = document.createElement("tr");
        row.innerHTML = `
          <td class="small">${String(startIndex + index + 1).padStart(2, "0")}</td>
          <td class="small">${getTaskTitle(task)}</td>
          <td class="small">${getTaskContextLabel(task)}</td>
          <td class="small">${formatTaskDate(task.dueDate || task.sessionDate || task.createdAt)}</td>
          <td class="small">
            <span class="badge rounded-pill bg-warning bg-opacity-25 text-dark px-3 py-2">
              ${formatTaskStatus(getTaskStatus(task))}
            </span>
          </td>
          <td class="text-center">
            <a class="btn btn-link text-dark p-1" href="@Url.Action("Analysis", "Home")" title="Open plan">
              <i class="bi bi-arrow-right-circle"></i>
            </a>
          </td>
        `;
        teacherDashboardTasksBody.appendChild(row);
      });

      if (teacherDashboardTasksPageText) {
        teacherDashboardTasksPageText.textContent = `Page ${teacherDashboardTaskPage} of ${totalPages}`;
      }

      if (teacherDashboardTasksPrevious) {
        teacherDashboardTasksPrevious.disabled = teacherDashboardTaskPage <= 1;
      }

      if (teacherDashboardTasksNext) {
        teacherDashboardTasksNext.disabled = teacherDashboardTaskPage >= totalPages;
      }
    }

    function getReorderStatusLabel(summary) {
      if (summary?.compressionApplied) {
        return "Compression active";
      }

      if (summary?.bufferUsed) {
        return "Using buffer";
      }

      if (summary?.planNeedsReordering) {
        return "Needs reorder";
      }

      return "On track";
    }

    function applyDashboardPlanSummary(plan, summary) {
      setDashboardMode(true);
      dashboardPlanSummaryText.textContent = `${getSubjectName(plan.subjectId)} plan with ${Array.isArray(plan.sessions) ? plan.sessions.length : 0} generated sessions.`;
      dashboardPlanLabel.textContent = plan.planName || "Generated plan";
      dashboardPlanProgressValue.textContent = `${Number(summary?.progressPercentage ?? 0)}%`;
      dashboardPlanProgressBar.style.width = `${Number(summary?.progressPercentage ?? 0)}%`;
      dashboardCompletedItems.textContent = String(Number(summary?.completedItems ?? 0));
      dashboardRemainingItems.textContent = String(Number(summary?.remainingItems ?? 0));
      dashboardClassSpeed.textContent = `${Number(summary?.classSpeedPercentage ?? 100)}%`;
      dashboardReorderStatus.textContent = getReorderStatusLabel(summary);
      const remainingSessions = Array.isArray(plan?.sessions)
        ? plan.sessions.filter((session) =>
            Array.isArray(session?.items) &&
            session.items.some((item) => String(item?.status || "").toUpperCase() !== "COMPLETED")
          ).length
        : 0;

      setTeacherDashboardTopMetrics({
        overallProgress: Number(summary?.progressPercentage ?? 0),
        classesRemaining: remainingSessions
      });
    }

    async function hydrateTeacherPlanState() {
      const token = sessionStorage.getItem("bridgeAccessToken");
      const subjectId = currentDashboardSubjectId;
      if (!token) {
        setDashboardMode(false);
        setTeacherDashboardTopMetrics();
        return;
      }

      let plan = null;
      const storedPlan = sessionStorage.getItem(getSubjectPlanStorageKey(subjectId));

      if (storedPlan) {
        try {
          plan = JSON.parse(storedPlan);
        } catch {
          plan = null;
        }
      }

      try {
        async function fetchLatestPlanForSubject() {
          const plansResponse = await fetch(`${backendBaseUrl}/plans/mine`, {
            headers: {
              Authorization: `Bearer ${token}`
            }
          });

          if (!plansResponse.ok) {
            return null;
          }

          const plans = await plansResponse.json().catch(() => []);
          if (!Array.isArray(plans) || !plans.length) {
            return null;
          }

          const subjectPlans = plans
            .filter((entry) => String(entry?.subjectId) === String(subjectId))
            .sort((left, right) => new Date(right?.startDate || 0).getTime() - new Date(left?.startDate || 0).getTime());

          const latestPlan = subjectPlans[0] || null;
          if (latestPlan?.planId) {
            sessionStorage.setItem(getSubjectPlanStorageKey(subjectId), JSON.stringify(latestPlan));
            sessionStorage.setItem("bridgeGeneratedPlan", JSON.stringify(latestPlan));
            return latestPlan;
          }

          return null;
        }

        if (!plan?.planId) {
          plan = await fetchLatestPlanForSubject();
        }

        if (!plan?.planId) {
          setDashboardMode(false);
          setTeacherDashboardTopMetrics();
          return;
        }

        async function fetchPlanProgress(activePlan) {
          const progressResponse = await fetch(`${backendBaseUrl}/plans/${activePlan.planId}/progress`, {
            headers: {
              Authorization: `Bearer ${token}`
            }
          });

          if (!progressResponse.ok) {
            return null;
          }

          return progressResponse.json().catch(() => null);
        }

        let progress = await fetchPlanProgress(plan);

        if (!progress) {
          const latestPlan = await fetchLatestPlanForSubject();

          if (!latestPlan?.planId || latestPlan.planId === plan.planId) {
            sessionStorage.removeItem(getSubjectPlanStorageKey(subjectId));
            setDashboardMode(false);
            setTeacherDashboardTopMetrics();
            return;
          }

          plan = latestPlan;
          progress = await fetchPlanProgress(plan);
        }

        if (!progress) {
          sessionStorage.removeItem(getSubjectPlanStorageKey(subjectId));
          setDashboardMode(false);
          setTeacherDashboardTopMetrics();
          return;
        }

        sessionStorage.setItem("bridgeGeneratedPlan", JSON.stringify(plan));
        applyDashboardPlanSummary(plan, progress);
      } catch {
        setDashboardMode(false);
        setTeacherDashboardTopMetrics();
      }
    }

    async function hydrateTeacherDashboardSkillsAndTasks() {
      const token = sessionStorage.getItem("bridgeAccessToken");
      const subjectId = currentDashboardSubjectId;
      if (!token) {
        teacherDashboardSkillRows = [];
        teacherDashboardTasks = [];
        renderDashboardSkills();
        renderDashboardTasks();
        return;
      }

      try {
        const headers = {
          Authorization: `Bearer ${token}`
        };

        const [skillsResponse, tasksResponse, weakStudentsResponse] = await Promise.all([
          fetch(`${backendBaseUrl}/statistics/class/skills?subjectId=${encodeURIComponent(subjectId)}`, { headers }),
          fetch(`${backendBaseUrl}/plans/todo/today`, { headers }),
          fetch(`${backendBaseUrl}/statistics/weak-students?subjectId=${encodeURIComponent(subjectId)}`, { headers })
        ]);

        teacherDashboardSkillRows = skillsResponse.ok
          ? await skillsResponse.json().catch(() => [])
          : [];

        const tasks = tasksResponse.ok
          ? await tasksResponse.json().catch(() => [])
          : [];

        teacherDashboardTasks = Array.isArray(tasks)
          ? tasks.filter((task) => String(task?.subjectId || "") === String(subjectId))
          : [];

        const atRiskStudents = weakStudentsResponse?.ok
          ? await weakStudentsResponse.json().catch(() => [])
          : [];

        setTeacherDashboardTopMetrics({
          overallProgress: teacherDashboardOverallProgressValue?.textContent?.replace("%", "") || 0,
          classesRemaining: teacherDashboardClassesRemainingValue?.textContent || 0,
          atRiskStudents: Array.isArray(atRiskStudents) ? atRiskStudents.length : 0
        });

        teacherDashboardTaskPage = 1;
        renderDashboardSkills();
        renderDashboardTasks();
      } catch {
        teacherDashboardSkillRows = [];
        teacherDashboardTasks = [];
        setTeacherDashboardTopMetrics({
          overallProgress: teacherDashboardOverallProgressValue?.textContent?.replace("%", "") || 0,
          classesRemaining: teacherDashboardClassesRemainingValue?.textContent || 0,
          atRiskStudents: 0
        });
        renderDashboardSkills();
        renderDashboardTasks();
      }
    }

    teacherDashboardTasksPrevious?.addEventListener("click", () => {
      teacherDashboardTaskPage = Math.max(1, teacherDashboardTaskPage - 1);
      renderDashboardTasks();
    });

    teacherDashboardTasksNext?.addEventListener("click", () => {
      const totalPages = Math.max(1, Math.ceil(teacherDashboardTasks.length / teacherDashboardTasksPageSize));
      teacherDashboardTaskPage = Math.min(totalPages, teacherDashboardTaskPage + 1);
      renderDashboardTasks();
    });

    document.querySelectorAll("[data-skill-sort]").forEach((button) => {
      button.addEventListener("click", () => {
        teacherDashboardSkillSort = button.getAttribute("data-skill-sort") || "lowest";
        if (teacherDashboardSkillFilterButton) {
          teacherDashboardSkillFilterButton.textContent =
            teacherDashboardSkillSort === "highest" ? "Highest first" : "Lowest first";
        }
        renderDashboardSkills();
      });
    });

    setTeacherDashboardSubjectLabels(getSubjectName(currentDashboardSubjectId));
    renderTeacherDashboardSubjectMenus();
    hydrateTeacherDashboardSubjects().then(() => {
      initializeSetupFormForSubject();
      hydrateTeacherPlanState();
      hydrateTeacherDashboardSkillsAndTasks();
    });

    function renderSelectedFile(file) {
      if (!setupFileSummary) {
        return;
      }

      if (!file) {
        setupFileSummary.classList.add("d-none");
        setupFileSummary.innerHTML = "";
        return;
      }

      setupFileSummary.classList.remove("d-none");
      setupFileSummary.innerHTML = `
        <strong>${file.name}</strong>
        <span class="text-secondary">(${(file.size / 1024).toFixed(1)} KB)</span>
      `;
    }

    ["dragenter","dragover","dragleave","drop"].forEach(eventName => {
      setupDropArea?.addEventListener(eventName, e => e.preventDefault());
    });

    setupDropArea?.addEventListener("drop", e => {
      handleFiles(e.dataTransfer.files);
    });

    setupFileInput?.addEventListener("change", e => {
      handleFiles(e.target.files);
    });

    function handleFiles(files) {
      if (setupFileInput?.disabled) {
        return;
      }
      const selectedFile = Array.from(files || [])[0] ?? null;

      if (selectedFile && !isAcceptedExcelFile(selectedFile)) {
        selectedBaselineFiles = [];
        renderSelectedFile(null);
        if (setupFileInput) {
          setupFileInput.value = "";
        }
        showFileError(setupFileError, "Only .xlsx files are accepted for baseline upload. Please choose the completed Excel file.");
        setGenerateButtonEnabled(false);
        return;
      }

      hideFileError(setupFileError);
      selectedBaselineFiles = selectedFile ? [selectedFile] : [];
      renderSelectedFile(selectedFile);
      setGenerateButtonEnabled(setupStudentsReady && setupWeeklySlotsSaved && Boolean(selectedBaselineFiles[0]));
    }

    async function uploadStudentsForSetup() {
      const token = sessionStorage.getItem("bridgeAccessToken");

      if (!token) {
        alert("You need to sign in again before uploading students.");
        return;
      }

      if (!selectedStudentsSetupFile) {
        alert("Choose the students Excel file first.");
        return;
      }

      uploadStudentsSetupButton.disabled = true;

      try {
        const formData = new FormData();
        formData.append("file", selectedStudentsSetupFile);

        const response = await fetch(`${backendBaseUrl}/students/import-template`, {
          method: "POST",
          headers: {
            Authorization: `Bearer ${token}`
          },
          body: formData
        });

        const data = await response.json().catch(() => null);
        if (!response.ok || !Array.isArray(data)) {
          const message = Array.isArray(data?.message)
            ? data.message.join(", ")
            : data?.message;
          throw new Error(message || "Unable to upload students.");
        }

        const studentsCount = data.length;
        setupStudentsReady = studentsCount > 0;
        if (studentsSetupStatusText) {
          studentsSetupStatusText.textContent = `${studentsCount} student(s) were uploaded successfully for this teacher.`;
        }

        setWeeklySlotsEnabled(setupStudentsReady);
        setBaselineUploadEnabled(setupStudentsReady && setupWeeklySlotsSaved);
        updateDashboardSetupState();
        setSetupPage(2);
        renderStudentsSetupFile(null);
        selectedStudentsSetupFile = null;
        if (studentsSetupFileInput) {
          studentsSetupFileInput.value = "";
        }
        await hydrateTeacherDashboardHeader();
      } catch (error) {
        alert(error.message || "Unable to upload students.");
      } finally {
        uploadStudentsSetupButton.disabled = false;
      }
    }

    async function saveWeeklySlotsForSetup() {
      const token = sessionStorage.getItem("bridgeAccessToken");
      const subjectId = currentDashboardSubjectId;
      const semester = setupSemesterSelect?.value || "";

      if (!token) {
        alert("You need to sign in again before saving weekly slots.");
        return;
      }

      if (!semester) {
        alert("Please choose the semester first.");
        return;
      }

      const minimumWeeklySlots = getMinimumWeeklySlots(subjectId);
      if (updateSetupTotalSlots() < minimumWeeklySlots) {
        alert(`${getSubjectName(subjectId)} needs at least ${minimumWeeklySlots} weekly slots.`);
        return;
      }

      const slots = weeklySlotDays.flatMap((day) =>
        Array.from({ length: setupSlotCounts[day] }, (_, index) => ({
          day,
          slotNumber: index + 1
        }))
      );

      saveWeeklySlotsButton.disabled = true;

      try {
        const response = await fetch(`${backendBaseUrl}/plans/weekly-slots`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`
          },
          body: JSON.stringify({
            subjectId,
            slots
          })
        });

        const data = await response.json().catch(() => null);
        if (!response.ok) {
          const message = Array.isArray(data?.message)
            ? data.message.join(", ")
            : data?.message;
          throw new Error(message || "Unable to save weekly slots.");
        }

        localStorage.setItem("teacherSelectedSubject", subjectId);
        localStorage.setItem("teacherSelectedSemester", semester);
        localStorage.setItem(getSubjectSemesterStorageKey(subjectId), semester);
        localStorage.setItem(getSubjectWeeklySlotsStorageKey(subjectId), JSON.stringify(setupSlotCounts));
        setupWeeklySlotsSaved = true;
        setBaselineUploadEnabled(setupStudentsReady);
        updateDashboardSetupState();
        setSetupPage(3);
      } catch (error) {
        alert(error.message || "Unable to save weekly slots.");
      } finally {
        saveWeeklySlotsButton.disabled = false;
      }
    }

    async function generatePlanFromBaseline() {
      const token = sessionStorage.getItem("bridgeAccessToken");
      const selectedFile = selectedBaselineFiles[0];
      const subjectId = currentDashboardSubjectId;
      const semester = Number(localStorage.getItem("teacherSelectedSemester") || "1");

      if (!token) {
        alert("You need to sign in again before generating a plan.");
        return;
      }

      if (!selectedFile) {
        alert("Please upload the baseline Excel file first.");
        return;
      }

      if (!setupStudentsReady) {
        alert("Upload the students file first.");
        return;
      }

      if (!setupWeeklySlotsSaved) {
        alert("Save the semester and weekly slots before uploading the baseline.");
        return;
      }

      if (!subjectId) {
        alert("Weekly slots are missing a selected subject. Go back to setup and save them again.");
        return;
      }

      generatePlanButton.classList.add("disabled");
      generatePlanButton.textContent = "Generating...";
      generatePlanButton.style.pointerEvents = "none";
      generatePlanButton.disabled = true;

      try {
        const formData = new FormData();
        formData.append("file", selectedFile);

        const normalizationResponse = await fetch(`${backendBaseUrl}/baseline/normalization?subjectId=${encodeURIComponent(subjectId)}`, {
          method: "POST",
          headers: {
            Authorization: `Bearer ${token}`
          },
          body: formData
        });
        const normalizedRows = await normalizationResponse.json().catch(() => null);
        if (!normalizationResponse.ok || !Array.isArray(normalizedRows)) {
          throw new Error(normalizedRows?.message || "Unable to normalize baseline rows.");
        }

        const matchResponse = await fetch(`${backendBaseUrl}/baseline/matchStudents`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`
          },
          body: JSON.stringify(normalizedRows)
        });
        const matchedRows = await matchResponse.json().catch(() => null);
        if (!matchResponse.ok || !Array.isArray(matchedRows)) {
          throw new Error(matchedRows?.message || "Unable to match baseline rows to students.");
        }

        const saveResponse = await fetch(`${backendBaseUrl}/baseline/save?subjectId=${encodeURIComponent(subjectId)}`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`
          },
          body: JSON.stringify(matchedRows)
        });
        const saveData = await saveResponse.json().catch(() => null);
        if (!saveResponse.ok) {
          throw new Error(saveData?.message || "Unable to save baseline results.");
        }

        sessionStorage.setItem("bridgeBaselineReady", "true");

        const planResponse = await fetch(`${backendBaseUrl}/plans/generate`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`
          },
          body: JSON.stringify({
            subjectId,
            semester
          })
        });
        const generatedPlan = await planResponse.json().catch(() => null);
        if (!planResponse.ok || !generatedPlan?.planId) {
          throw new Error(generatedPlan?.message || "Unable to generate plan.");
        }

        sessionStorage.setItem(getSubjectPlanStorageKey(subjectId), JSON.stringify(generatedPlan));
        sessionStorage.setItem("bridgeGeneratedPlan", JSON.stringify(generatedPlan));
        selectedBaselineFiles = [];
        renderSelectedFile(null);
        setGenerateButtonEnabled(false);
        closeSetupModal();
        await hydrateTeacherPlanState();
        await hydrateTeacherDashboardSkillsAndTasks();
      } catch (error) {
        alert(error.message || "Unable to generate the learning plan.");
      } finally {
        generatePlanButton.classList.remove("disabled");
        generatePlanButton.textContent = "Generate plan";
        generatePlanButton.style.pointerEvents = "";
        setGenerateButtonEnabled(setupStudentsReady && setupWeeklySlotsSaved && Boolean(selectedBaselineFiles[0]));
      }
    }

    openSetupModalButton?.addEventListener("click", openSetupModal);
    closeSetupModalButton?.addEventListener("click", closeSetupModal);
    teacherSetupModalBackdrop?.addEventListener("click", closeSetupModal);
    setupBackButton?.addEventListener("click", () => {
      if (currentSetupStep === 3) {
        setSetupPage(2);
        return;
      }

      if (currentSetupStep === 2) {
        setSetupPage(1);
      }
    });
    uploadStudentsSetupButton?.addEventListener("click", (event) => {
      event.preventDefault();
      uploadStudentsForSetup();
    });
    saveWeeklySlotsButton?.addEventListener("click", (event) => {
      event.preventDefault();
      saveWeeklySlotsForSetup();
    });
    document.getElementById("generatePlanButton")?.addEventListener("click", (event) => {
      event.preventDefault();
      generatePlanFromBaseline();
    });
});
</script>

</div>
