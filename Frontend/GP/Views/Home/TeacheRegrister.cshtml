@{
    ViewData["Title"] = "TeacheRegrister";
}

<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-lg-6">
            <h1 class="fw-bold mb-1">Create teacher account</h1>
            <p class="text-secondary mb-4">Register with an institution code, or continue as an individual teacher with your school name.</p>

            <div id="teacherErrorBox" class="alert alert-danger d-none"></div>

            <form id="teacherRegisterForm">
                <div class="row">
                    <div class="mb-3 col-12">
                        <input type="text" id="teacherNameInput" class="form-control p-3" placeholder="Full Name">
                    </div>

                    <div class="mb-3 col-6">
                        <input type="email" id="teacherEmailInput" class="form-control p-3" placeholder="Email Address">
                    </div>
                    <div class="mb-3 col-6">
                        <input type="tel" id="teacherPhoneInput" class="form-control p-3" placeholder="Phone Number">
                    </div>
                    <div class="mb-3 col-6">
                        <select id="teacherGradeInput" class="form-select p-3">
                            <option value="">Choose Grade</option>
                            <option value="First Grade">First Grade</option>
                            <option value="Second Grade">Second Grade</option>
                            <option value="Third Grade">Third Grade</option>
                        </select>
                    </div>
                    <div class="mb-3 col-6">
                        <input type="text" id="teacherSectionInput" class="form-control p-3" placeholder="Section (Optional)">
                    </div>
                    <div class="mb-3 col-12">
                        <input type="text" id="teacherSchoolInput" class="form-control p-3" placeholder="School Name (Required if no institution code)">
                    </div>
                    <div class="mb-3 col-12">
                        <input type="text" id="teacherInstitutionCodeInput" class="form-control p-3" placeholder="Institution Code (Optional)">
                    </div>
                    <div class="mb-3 col-6">
                        <input type="password" id="teacherPasswordInput" class="form-control p-3" placeholder="Password">
                        <small id="teacherPasswordStrength" class="fw-semibold"></small>
                    </div>
                    <div class="mb-3 col-6">
                        <input type="password" id="teacherConfirmPasswordInput" class="form-control p-3" placeholder="Confirm Password">
                        <small id="teacherMatchText" class="fw-semibold"></small>
                    </div>

                    <div class="d-flex gap-3 mb-4">
                        <button type="submit"
                                class="btn px-4 text-white"
                                id="teacherRegisterBtn"
                                style="background:#c9c6ff">
                            Next →
                        </button>

                        <a class="btn px-4"
                           style="border:1px solid #c9c6ff;color:#c9c6ff"
                           asp-action="SignUp"
                           asp-controller="Home">
                            Back
                        </a>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-lg-6 text-center">
            <img src="~/img/illustration.png" class="img-fluid" style="max-height:420px">
        </div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const teacherRegisterForm = document.getElementById("teacherRegisterForm");
    const teacherRegisterBtn = document.getElementById("teacherRegisterBtn");
    const teacherErrorBox = document.getElementById("teacherErrorBox");
    const teacherPasswordInput = document.getElementById("teacherPasswordInput");
    const teacherConfirmPasswordInput = document.getElementById("teacherConfirmPasswordInput");
    const teacherPasswordStrength = document.getElementById("teacherPasswordStrength");
    const teacherMatchText = document.getElementById("teacherMatchText");

    function showTeacherError(message) {
        teacherErrorBox.textContent = message;
        teacherErrorBox.classList.remove("d-none");
    }

    function hideTeacherError() {
        teacherErrorBox.classList.add("d-none");
    }

    function checkTeacherPasswordStrength() {
        const value = teacherPasswordInput.value;
        let strength = 0;

        if (value.length >= 8) strength++;
        if (/[A-Z]/.test(value)) strength++;
        if (/[a-z]/.test(value)) strength++;
        if (/[0-9]/.test(value)) strength++;

        if (!value.length) {
            teacherPasswordStrength.textContent = "";
            return;
        }

        if (strength <= 2) {
            teacherPasswordStrength.textContent = "Weak password";
            teacherPasswordStrength.style.color = "red";
        } else if (strength === 3) {
            teacherPasswordStrength.textContent = "Medium password";
            teacherPasswordStrength.style.color = "orange";
        } else {
            teacherPasswordStrength.textContent = "Strong password";
            teacherPasswordStrength.style.color = "green";
        }
    }

    function checkTeacherPasswordMatch() {
        if (!teacherConfirmPasswordInput.value.length) {
            teacherMatchText.textContent = "";
            return;
        }

        if (teacherPasswordInput.value === teacherConfirmPasswordInput.value) {
            teacherMatchText.textContent = "Passwords match";
            teacherMatchText.style.color = "green";
        } else {
            teacherMatchText.textContent = "Passwords do not match";
            teacherMatchText.style.color = "red";
        }
    }

    teacherPasswordInput.addEventListener("input", () => {
        checkTeacherPasswordStrength();
        checkTeacherPasswordMatch();
    });
    teacherConfirmPasswordInput.addEventListener("input", checkTeacherPasswordMatch);

    teacherRegisterForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        hideTeacherError();

        const payload = {
            userFullName: document.getElementById("teacherNameInput").value.trim(),
            email: document.getElementById("teacherEmailInput").value.trim(),
            phoneNumber: document.getElementById("teacherPhoneInput").value.trim() || undefined,
            grade: document.getElementById("teacherGradeInput").value,
            section: document.getElementById("teacherSectionInput").value.trim() || undefined,
            school: document.getElementById("teacherSchoolInput").value.trim() || undefined,
            institutionCode: document.getElementById("teacherInstitutionCodeInput").value.trim() || undefined,
            password: teacherPasswordInput.value
        };

        if (!payload.userFullName || !payload.email || !payload.grade || !payload.password) {
            showTeacherError("Please complete your full name, email, grade, and password.");
            return;
        }

        if (!payload.institutionCode && !payload.school) {
            showTeacherError("Enter an institution code or provide a school name.");
            return;
        }

        if (payload.password !== teacherConfirmPasswordInput.value) {
            showTeacherError("Passwords do not match.");
            return;
        }

        teacherRegisterBtn.disabled = true;

        try {
            const response = await fetch(`${backendBaseUrl}/auth/signup/teacher`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(payload)
            });

            const data = await response.json().catch(() => null);
            if (!response.ok) {
                const message = Array.isArray(data?.message) ? data.message.join(", ") : data?.message;
                throw new Error(message || "Unable to create teacher account.");
            }

            sessionStorage.setItem("bridgePendingTeacherSetup", "true");
            sessionStorage.setItem("bridgeTeacherSetupComplete", "false");
            sessionStorage.setItem("bridgeTeacherGrade", payload.grade);
            sessionStorage.setItem("bridgeUserRole", "Teacher");
            sessionStorage.setItem("bridgeUserName", payload.userFullName);
            if (data?.access_token) {
                sessionStorage.setItem("bridgeAccessToken", data.access_token);
            }
            sessionStorage.setItem("bridgeVerificationRole", "teacher");
            window.location.href = '@Url.Action("Verification", "Home")';
        } catch (error) {
            showTeacherError(error.message || "Unable to connect to the server.");
        } finally {
            teacherRegisterBtn.disabled = false;
        }
    });
</script>
