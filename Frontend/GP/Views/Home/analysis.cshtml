@{
    ViewData["Title"] = "analysis";
}

<style>
    .bridge-accent {
        background: #c9c6ff !important;
        border-color: #c9c6ff !important;
        color: #1f2430 !important;
    }
    .plan-monitor-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:24px; margin-top:28px; }
    .plan-monitor-card { border:1px solid #e5e7eb; border-radius:24px; background:#fff; padding:20px; box-shadow:0 10px 28px rgba(17,30,39,.04); }
    .plan-monitor-card h3 { font-size:20px; font-weight:800; color:#111E27; margin-bottom:12px; }
    .plan-archive-list { display:grid; gap:12px; }
    .plan-archive-item { border:1px solid #e5e7eb; border-radius:18px; padding:14px 16px; background:#f3f4f6; color:#6b7280; }
    .plan-archive-item strong { color:#374151; display:block; margin-bottom:4px; }
    .plan-archive-item small { display:block; }
    .plan-archive-item-head { display:flex; align-items:flex-start; justify-content:space-between; gap:12px; }
    .plan-archive-action { border:1px solid #dbe3f0; background:#fff; color:#374151; border-radius:999px; padding:6px 12px; font-size:13px; font-weight:700; white-space:nowrap; }
    .activity-quick-status {
        display:inline-flex;
        align-items:center;
        justify-content:center;
        width:30px;
        height:30px;
        border-radius:999px;
        border:1px solid #cbd5e1;
        background:#fff;
        color:#475569;
        margin-inline-end:10px;
        flex-shrink:0;
    }
    .activity-quick-status.completed {
        border-color:#86efac;
        background:#dcfce7;
        color:#166534;
    }
    .plan-warning-banner { margin-top:16px; border:1px solid #FDE48A; background:#fffbeb; color:#92400e; border-radius:18px; padding:14px 16px; font-weight:600; display:none; }
    .plan-warning-banner.show { display:block; }
    .plan-speed-value { color:#3AA2ED !important; }
    .plan-speed-label { margin-top:6px; font-size:14px; font-weight:700; color:#6b7280; }
    .plan-mode-row { margin-top:18px; display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; }
    .plan-mode-copy { color:#4b5563; font-size:14px; }
    .plan-mode-toggle { display:inline-flex; align-items:center; gap:10px; font-weight:700; color:#111E27; }
    .plan-mode-toggle input { width:44px; height:24px; accent-color:#3AA2ED; }
    .plan-reason-row { display:flex; flex-wrap:wrap; gap:8px; margin-top:12px; }
    .plan-reason-pill { display:inline-flex; align-items:center; border-radius:999px; padding:6px 12px; font-size:13px; font-weight:700; border:1px solid #e5e7eb; background:#fff; color:#374151; }
    .plan-reason-pill.behind { border-color:#FCD64D; background:#fffbeb; color:#92400e; }
    .plan-reason-pill.overflow { border-color:#fca5a5; background:#fef2f2; color:#b91c1c; }
    .plan-reason-pill.track { border-color:#bbf7d0; background:#f0fdf4; color:#166534; }
    .plan-reason-pill.buffer { border-color:#bfdbfe; background:#eff6ff; color:#1D8AD8; }
    .plan-reason-pill.compression { border-color:#ddd6fe; background:#f5f3ff; color:#288FD9; }
    .plan-details-summary { margin-top:12px; display:grid; gap:10px; }
    .plan-details-summary-item { border:1px solid #e5e7eb; border-radius:16px; background:#f9fafb; padding:12px 14px; color:#374151; font-size:14px; }
    .plan-details-summary-item strong { color:#111E27; }
    .plan-compression-list { display:grid; gap:10px; margin-top:12px; }
    .plan-compression-item { border:1px solid #e5e7eb; border-radius:16px; padding:12px 14px; background:#fff; }
    .plan-compression-item strong { display:block; color:#111E27; margin-bottom:4px; }
    .plan-compression-item small { color:#6b7280; display:block; }
    .reorder-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15,31,42,.45);
        z-index: 1050;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }
    .reorder-modal {
        position: relative;
        width: min(92vw, 520px);
        max-width: 520px;
        background: #fff;
        border-radius: 24px;
        box-shadow: 0 22px 50px rgba(15,31,42,.25);
        z-index: 1051;
        padding: 24px;
        margin: 0 auto;
    }
    .reorder-modal h3 { font-size:26px; font-weight:800; color:#111E27; margin-bottom:10px; }
    .reorder-modal p { color:#4b5563; margin-bottom:16px; line-height:1.6; }
    .reorder-modal-note { margin-top:12px; color:#6b7280; font-size:14px; }
    .reorder-modal-actions { display:flex; justify-content:flex-end; gap:12px; }
    .reorder-modal-actions button { border-radius:14px; padding:10px 16px; font-weight:700; border:1px solid #dbe3f0; background:#fff; color:#374151; }
    .reorder-modal-actions .primary { background:linear-gradient(135deg,#82CBFF,#6DC2FF); border-color:transparent; color:#fff; }
    .no-plan-panel { margin-top:24px; border:1px solid #e5e7eb; border-radius:24px; background:#fff; padding:24px; box-shadow:0 10px 28px rgba(17,30,39,.04); display:none; }
    .no-plan-panel.show { display:block; }
    .no-plan-panel h2 { font-size:28px; font-weight:800; color:#111E27; margin-bottom:8px; }
    .no-plan-panel p { color:#6b7280; margin-bottom:18px; }
    .no-plan-upload { border:2px dashed #cec8ff; border-radius:20px; background:#faf9ff; padding:28px; text-align:center; }
    .no-plan-upload.is-disabled { opacity:.55; pointer-events:none; }
    .no-plan-upload strong { display:block; color:#111E27; font-size:18px; margin-bottom:8px; }
    .no-plan-upload small { display:block; color:#6b7280; margin-top:8px; }
    .no-plan-file-summary { margin-top:14px; padding:12px 14px; border:1px solid #e5e7eb; border-radius:16px; background:#fff; color:#374151; display:none; }
    .no-plan-file-summary.show { display:block; }
    .no-plan-actions { display:flex; justify-content:flex-end; gap:12px; flex-wrap:wrap; margin-top:18px; }
    .no-plan-actions .btn { border-radius:999px; font-weight:700; padding:10px 18px; }
    .no-plan-actions .btn:disabled { opacity:.55; cursor:not-allowed; }
    .day-session-stack { display:grid; gap:14px; }
    .session-slot-label {
        display:inline-flex;
        align-items:center;
        align-self:flex-start;
        margin-bottom:10px;
        padding:6px 12px;
        border-radius:999px;
        background:#f5f3ff;
        color:#5b21b6;
        font-size:12px;
        font-weight:800;
    }
    @@media (max-width: 991px) { .plan-monitor-grid { grid-template-columns:1fr; } }
</style>

<div class="teacher-shell">
    <partial name="_TeacherSidebar" />
    <div class="teacher-shell-content">
        <div class="container py-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <h1 class="fw-bold mb-1">Generated Learning Plan</h1>
                    <p class="text-secondary mb-0" id="planSummaryText">
                        Review the generated sessions for the selected week and subject.
                    </p>
                </div>

                <div class="dropdown">
                    <button class="btn btn-light border rounded-pill dropdown-toggle text-secondary"
                            data-bs-toggle="dropdown"
                            id="planIdButton">
                        Plan ID
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><span class="dropdown-item-text" id="planMetaLabel">Current generated plan</span></li>
                    </ul>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3" id="subjectTabs">
                <button type="button" class="btn btn-light border rounded-pill px-4 subject-tab-btn" data-subject-id="2">Arabic</button>
                <button type="button" class="btn btn-light border rounded-pill px-4 subject-tab-btn" data-subject-id="1">Math</button>
            </div>

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mt-3">
                <div class="dropdown" id="weekFilterSection">
                    <button class="btn btn-light border rounded-pill px-4 dropdown-toggle text-secondary"
                            data-bs-toggle="dropdown"
                            id="weekFilterButton">
                        Week 1
                    </button>
                    <ul class="dropdown-menu" id="weekFilterMenu"></ul>
                </div>
            </div>

            <div id="noPlanPanel" class="no-plan-panel">
                <h2>No @("subject") plan yet</h2>
                <p id="noPlanMessage">Upload the baseline file for this subject, then generate its plan.</p>
                <div id="noPlanDropArea" class="no-plan-upload">
                    <strong>Upload baseline Excel</strong>
                    <div>Drag and drop the completed `.xlsx` baseline file here or</div>
                    <label for="noPlanFileInput" class="btn btn-light border rounded-pill mt-3">Choose file</label>
                    <input id="noPlanFileInput" type="file" class="d-none" accept=".xlsx" />
                    <small>Only `.xlsx` files are accepted.</small>
                    <div id="noPlanFileSummary" class="no-plan-file-summary"></div>
                </div>
                <div class="no-plan-actions">
                    <a class="btn btn-light border" href="@Url.Action("SetupStudents", "Home")">Manage students</a>
                    <button type="button" class="btn bridge-accent" id="generateMissingPlanButton">Generate @("subject") plan</button>
                </div>
            </div>

            <div class="row g-4 mt-3" id="planSummaryCards">
                <div class="col-12 col-md-3">
                    <div class="border rounded-4 p-4 h-100">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-graph-up-arrow fs-2 text-secondary"></i>
                            <div>
                                <div class="fs-2 fw-bold text-success" id="planProgressValue">0%</div>
                                <div class="text-secondary">Progress made</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-3">
                    <div class="border rounded-4 p-4 h-100">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-journal-check fs-2 text-secondary"></i>
                            <div>
                                <div class="fs-2 fw-bold" id="sessionCountValue">0</div>
                                <div class="text-secondary">Sessions in selected week</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-3">
                    <div class="border rounded-4 p-4 h-100">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-speedometer2 fs-2 text-secondary"></i>
                            <div>
                                <div class="fs-2 fw-bold plan-speed-value" id="classSpeedValue">100%</div>
                                <div class="text-secondary">Class speed</div>
                                <div class="plan-speed-label" id="classSpeedLabel">On track</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-3">
                    <div class="border rounded-4 p-4 h-100">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-clipboard2-pulse fs-2 text-secondary"></i>
                            <div>
                                <div class="fs-2 fw-bold" id="atRiskValue">0</div>
                                <div class="text-secondary">At Risk Students</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="plan-warning-banner" id="reorderBanner"></div>
            <div class="plan-reason-row" id="reorderReasonRow"></div>
            <div class="mt-2 d-flex justify-content-end">
                <button type="button" class="btn btn-sm btn-light border rounded-pill" id="reorderDetailsButton">More info</button>
            </div>
            <div class="plan-mode-row">
                <div>
                    <div class="fw-semibold text-dark">Reordering mode</div>
                    <div class="plan-mode-copy" id="planModeDescription">Manual mode keeps reordering under teacher control.</div>
                </div>
                <label class="plan-mode-toggle">
                    <span id="planModeLabel">Manual</span>
                    <input id="autoReorderSwitch" type="checkbox" />
                </label>
            </div>
        </div>

        <div class="container py-4" id="planBoardSection">
            <section class="weekly-plan-shell">
                <div class="weekly-plan-grid" id="weeklyPlanGrid"></div>

                <div class="weekly-plan-footer">
                    <div class="week-pager" id="weekPager"></div>
                    <div class="plan-actions">
                        <button type="button" class="plan-secondary-btn" id="replanBtn">Reorder</button>
                        <a class="plan-secondary-btn plan-link-btn" asp-controller="Home" asp-action="History">History</a>
                    </div>
                </div>
            </section>

            <section class="plan-monitor-grid">
                <article class="plan-monitor-card">
                    <h3>Postponed Activities</h3>
                    <div id="postponedArchiveList" class="plan-archive-list"></div>
                </article>
                <article class="plan-monitor-card">
                    <h3>Cancelled Activities</h3>
                    <div id="cancelledArchiveList" class="plan-archive-list"></div>
                </article>
                <article class="plan-monitor-card">
                    <h3>Unplaced Activities</h3>
                    <div id="unplacedArchiveList" class="plan-archive-list"></div>
                </article>
            </section>
        </div>
    </div>
</div>

<div class="activity-panel-backdrop d-none" id="activityPanelBackdrop"></div>
<aside class="activity-panel d-none" id="activityDetailsPanel" aria-label="Activity details">
    <div class="activity-panel-header">
        <span>Activity Details</span>
        <button type="button" class="activity-icon js-close-panels" aria-label="Close"><i class="bi bi-x"></i></button>
    </div>
    <div class="activity-panel-body">
        <button type="button" class="activity-icon activity-panel-edit" id="detailsEditButton" aria-label="Edit activity"><i class="bi bi-pencil"></i></button>
        <h3 id="detailsTitle">Activity name</h3>
        <p id="detailsUnit">Unit name</p>
        <dl class="activity-detail-list">
            <div><dt>Duration</dt><dd id="detailsDuration">5 minutes</dd></div>
            <div><dt>Status</dt><dd id="detailsStatus">Planned</dd></div>
            <div><dt>Notes</dt><dd id="detailsNotes">No notes yet</dd></div>
        </dl>
    </div>
</aside>

<aside class="activity-panel edit-panel d-none" id="activityEditPanel" aria-label="Edit activity">
    <div class="activity-panel-header">
        <span>Edit Activity</span>
        <button type="button" class="activity-icon js-close-panels" aria-label="Close"><i class="bi bi-x"></i></button>
    </div>
    <div class="activity-panel-body">
        <label class="edit-label">Duration</label>
        <div class="duration-control">
            <button type="button" id="durationIncreaseButton">+</button>
            <strong id="editDuration">5 minutes</strong>
            <button type="button" id="durationDecreaseButton">-</button>
        </div>
        <label class="edit-label">Status</label>
        <div class="status-options">
            <label><input type="radio" name="activityStatus" value="Planned"> Planned</label>
            <label><input type="radio" name="activityStatus" value="Completed"> Completed</label>
            <label><input type="radio" name="activityStatus" value="Postponed"> Postpone</label>
            <label><input type="radio" name="activityStatus" value="Cancelled"> Cancelled</label>
        </div>
        <label class="edit-label" for="activityNotes">Notes</label>
        <textarea id="activityNotes" rows="4"></textarea>
    </div>
    <div class="activity-panel-footer">
        <button type="button" class="activity-cancel-btn js-close-panels">Cancel</button>
        <button type="button" class="activity-save-btn" id="activitySaveButton">Save</button>
    </div>
</aside>

<div class="reorder-modal-backdrop d-none" id="reorderPromptBackdrop">
    <div class="reorder-modal d-none" id="reorderPromptModal" aria-label="Plan reorder recommendation">
        <h3>Plan Reorder Recommended</h3>
        <p id="reorderPromptMessage">The current class pace suggests replanning future sessions.</p>
        <div class="reorder-modal-actions">
            <button type="button" id="reorderPromptLaterButton">Later</button>
            <button type="button" class="primary" id="reorderPromptNowButton">Reorder now</button>
        </div>
    </div>
</div>

<div class="reorder-modal-backdrop d-none" id="autoReorderChoiceBackdrop">
    <div class="reorder-modal d-none" id="autoReorderChoiceModal" aria-label="Automatic reorder setup">
        <h3>Automatic Reordering</h3>
        <p>Bridge can monitor class pace and session overflow, then repack future sessions when the current plan falls behind.</p>
        <div class="reorder-modal-note">Automatic mode only changes future sessions. Postponed items stay archived, cancelled items stay out of the active plan, and history keeps the trace.</div>
        <div class="reorder-modal-actions">
            <button type="button" id="autoReorderSkipButton">Skip for now</button>
            <button type="button" class="primary" id="autoReorderEnableButton">Enable auto reordering</button>
        </div>
    </div>
</div>

<div class="reorder-modal-backdrop d-none" id="autoReorderInfoBackdrop">
    <div class="reorder-modal d-none" id="autoReorderInfoModal" aria-label="Automatic reorder details">
        <h3>Plan Reordered Automatically</h3>
        <p id="autoReorderInfoMessage">Bridge updated the future sessions to keep the class on track.</p>
        <div class="reorder-modal-actions">
            <button type="button" id="autoReorderInfoMoreButton">More info</button>
            <button type="button" id="autoReorderInfoCloseButton">Close</button>
        </div>
    </div>
</div>

<div class="reorder-modal-backdrop d-none" id="reorderDetailsBackdrop">
    <div class="reorder-modal d-none" id="reorderDetailsModal" aria-label="Plan reorder details">
        <h3>Reorder Details</h3>
        <p id="reorderDetailsMessage">Bridge reviewed the current plan and adjusted future sessions.</p>
        <div class="plan-details-summary" id="reorderDetailsSummary"></div>
        <div class="plan-compression-list" id="reorderCompressionList"></div>
        <div class="plan-compression-list" id="reorderUnplacedList"></div>
        <div class="reorder-modal-actions">
            <button type="button" id="reorderDetailsCloseButton">Close</button>
        </div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const dayOrder = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday"];
    let currentSubjectId = localStorage.getItem("teacherSelectedSubject") || "2";
    const planStorage = sessionStorage.getItem(`bridgeGeneratedPlan:${currentSubjectId}`) || sessionStorage.getItem("bridgeGeneratedPlan");
    let generatedPlan = planStorage ? JSON.parse(planStorage) : null;
    const token = sessionStorage.getItem("bridgeAccessToken");
    const teacherGrade = sessionStorage.getItem("teacherGrade") || sessionStorage.getItem("bridgeTeacherGrade") || "Grade";

    const subjectTabs = document.getElementById("subjectTabs");
    const planIdButton = document.getElementById("planIdButton");
    const planMetaLabel = document.getElementById("planMetaLabel");
    const planSummaryText = document.getElementById("planSummaryText");
    const weekFilterButton = document.getElementById("weekFilterButton");
    const weekFilterMenu = document.getElementById("weekFilterMenu");
    const weekFilterSection = document.getElementById("weekFilterSection");
    const planExportActions = document.getElementById("planExportActions");
    const planSummaryCards = document.getElementById("planSummaryCards");
    const planBoardSection = document.getElementById("planBoardSection");
    const noPlanPanel = document.getElementById("noPlanPanel");
    const noPlanMessage = document.getElementById("noPlanMessage");
    const noPlanDropArea = document.getElementById("noPlanDropArea");
    const noPlanFileInput = document.getElementById("noPlanFileInput");
    const noPlanFileSummary = document.getElementById("noPlanFileSummary");
    const generateMissingPlanButton = document.getElementById("generateMissingPlanButton");
    const noPlanManageStudentsButton = noPlanPanel?.querySelector("a.btn");
    const planProgressValue = document.getElementById("planProgressValue");
    const sessionCountValue = document.getElementById("sessionCountValue");
    const classSpeedValue = document.getElementById("classSpeedValue");
    const classSpeedLabel = document.getElementById("classSpeedLabel");
    const atRiskValue = document.getElementById("atRiskValue");
    const weeklyPlanGrid = document.getElementById("weeklyPlanGrid");
    const weekPager = document.getElementById("weekPager");
    const reorderBanner = document.getElementById("reorderBanner");
    const reorderReasonRow = document.getElementById("reorderReasonRow");
    const postponedArchiveList = document.getElementById("postponedArchiveList");
    const cancelledArchiveList = document.getElementById("cancelledArchiveList");
    const unplacedArchiveList = document.getElementById("unplacedArchiveList");
    const activityPanelBackdrop = document.getElementById("activityPanelBackdrop");
    const activityDetailsPanel = document.getElementById("activityDetailsPanel");
    const activityEditPanel = document.getElementById("activityEditPanel");
    const detailsTitle = document.getElementById("detailsTitle");
    const detailsUnit = document.getElementById("detailsUnit");
    const detailsDuration = document.getElementById("detailsDuration");
    const detailsStatus = document.getElementById("detailsStatus");
    const detailsNotes = document.getElementById("detailsNotes");
    const editDuration = document.getElementById("editDuration");
    const activityNotes = document.getElementById("activityNotes");
    const detailsEditButton = document.getElementById("detailsEditButton");
    const durationIncreaseButton = document.getElementById("durationIncreaseButton");
    const durationDecreaseButton = document.getElementById("durationDecreaseButton");
    const activitySaveButton = document.getElementById("activitySaveButton");
    const replanBtn = document.getElementById("replanBtn");
    const reorderPromptBackdrop = document.getElementById("reorderPromptBackdrop");
    const reorderPromptModal = document.getElementById("reorderPromptModal");
    const reorderPromptMessage = document.getElementById("reorderPromptMessage");
    const reorderPromptLaterButton = document.getElementById("reorderPromptLaterButton");
    const reorderPromptNowButton = document.getElementById("reorderPromptNowButton");
    const reorderDetailsButton = document.getElementById("reorderDetailsButton");
    const planModeDescription = document.getElementById("planModeDescription");
    const planModeLabel = document.getElementById("planModeLabel");
    const autoReorderSwitch = document.getElementById("autoReorderSwitch");
    const autoReorderChoiceBackdrop = document.getElementById("autoReorderChoiceBackdrop");
    const autoReorderChoiceModal = document.getElementById("autoReorderChoiceModal");
    const autoReorderEnableButton = document.getElementById("autoReorderEnableButton");
    const autoReorderSkipButton = document.getElementById("autoReorderSkipButton");
    const autoReorderInfoBackdrop = document.getElementById("autoReorderInfoBackdrop");
    const autoReorderInfoModal = document.getElementById("autoReorderInfoModal");
    const autoReorderInfoMessage = document.getElementById("autoReorderInfoMessage");
    const autoReorderInfoMoreButton = document.getElementById("autoReorderInfoMoreButton");
    const autoReorderInfoCloseButton = document.getElementById("autoReorderInfoCloseButton");
    const reorderDetailsBackdrop = document.getElementById("reorderDetailsBackdrop");
    const reorderDetailsModal = document.getElementById("reorderDetailsModal");
    const reorderDetailsMessage = document.getElementById("reorderDetailsMessage");
    const reorderDetailsSummary = document.getElementById("reorderDetailsSummary");
    const reorderCompressionList = document.getElementById("reorderCompressionList");
    const reorderUnplacedList = document.getElementById("reorderUnplacedList");
    const reorderDetailsCloseButton = document.getElementById("reorderDetailsCloseButton");
    const maxActivityMinutes = 25;
    let selectedActivity = null;
    let selectedAnchor = null;
    let selectedWeekNo = 1;
    let editedDurationMinutes = 0;
    let planSummaryState = null;
    let dismissedReorderFingerprint = null;
    let isAutoReorderEnabled = false;
    let isAutoReordering = false;
    let lastAutoReorderFingerprint = null;
    let selectedBaselineFile = null;
    let isCurrentSubjectSetupReady = false;

    function getPlanStorageKey(subjectId = currentSubjectId) {
        return `bridgeGeneratedPlan:${subjectId}`;
    }

    function subjectLabel(subjectId) {
        if (String(subjectId) === "1") return "Math";
        if (String(subjectId) === "2") return "Arabic";
        return `Subject ${subjectId}`;
    }

    function skillLabel(skillId) {
        const labels = {
            skill_counting: "مهارات العد",
            skill_number_manipulation: "مهارات التلاعب بالأعداد",
            skill_problem_solving: "مهارات حل المسائل",
            skill_vocal: "الوعي الصوتي",
            skill_sounds_of_letters: "قراءة أصوات الحروف",
            skill_writing: "الكتابة"
        };

        return labels[skillId] ?? skillId;
    }

    function setActiveSubjectTabs() {
        subjectTabs?.querySelectorAll("[data-subject-id]").forEach((button) => {
            const isActive = String(button.dataset.subjectId) === String(currentSubjectId);
            button.classList.toggle("bridge-accent", isActive);
        });
    }

    function setNoPlanState(isNoPlan) {
        noPlanPanel?.classList.toggle("show", isNoPlan);
        weekFilterSection?.classList.toggle("d-none", isNoPlan);
        planExportActions?.classList.toggle("d-none", isNoPlan);
        planSummaryCards?.classList.toggle("d-none", isNoPlan);
        planBoardSection?.classList.toggle("d-none", isNoPlan);
        reorderDetailsButton?.classList.toggle("d-none", isNoPlan);
    }

    function getSubjectSemesterStorageKey(subjectId) {
        return `teacherSelectedSemester:${subjectId}`;
    }

    function setNoPlanSetupState(isReady) {
        isCurrentSubjectSetupReady = Boolean(isReady);
        noPlanDropArea?.classList.toggle("is-disabled", !isCurrentSubjectSetupReady);

        if (noPlanFileInput) {
            noPlanFileInput.disabled = !isCurrentSubjectSetupReady;
        }

        if (generateMissingPlanButton) {
            generateMissingPlanButton.disabled = !isCurrentSubjectSetupReady;
            generateMissingPlanButton.textContent = `Generate ${subjectLabel(currentSubjectId)} plan`;
        }

        if (!isCurrentSubjectSetupReady) {
            selectedBaselineFile = null;
            renderNoPlanFile(null);
            if (noPlanMessage) {
                noPlanMessage.textContent = `Set up ${subjectLabel(currentSubjectId)} first by choosing the semester and saving weekly slots before uploading the baseline.`;
            }
            if (noPlanManageStudentsButton) {
                noPlanManageStudentsButton.textContent = `Set up ${subjectLabel(currentSubjectId)}`;
            }
            return;
        }

        if (noPlanMessage) {
            noPlanMessage.textContent = `Upload the baseline file for ${subjectLabel(currentSubjectId)}, then generate its plan here.`;
        }

        if (noPlanManageStudentsButton) {
            noPlanManageStudentsButton.textContent = "Manage students";
        }
    }

    async function hydrateNoPlanSetupState() {
        const storedSemester = localStorage.getItem(getSubjectSemesterStorageKey(currentSubjectId))
            || localStorage.getItem("teacherSelectedSemester")
            || "";

        if (!token || !storedSemester) {
            setNoPlanSetupState(false);
            return;
        }

        try {
            const response = await fetch(`${backendBaseUrl}/plans/weekly-slots/${encodeURIComponent(currentSubjectId)}`, {
                headers: { Authorization: `Bearer ${token}` }
            });
            const data = response.ok ? await response.json().catch(() => null) : null;
            const hasWeeklySlots = Array.isArray(data?.slots) && data.slots.length > 0;
            setNoPlanSetupState(hasWeeklySlots);
        } catch {
            setNoPlanSetupState(false);
        }
    }

    function renderNoPlanFile(file) {
        if (!noPlanFileSummary) return;
        if (!file) {
            noPlanFileSummary.classList.remove("show");
            noPlanFileSummary.textContent = "";
            return;
        }

        noPlanFileSummary.classList.add("show");
        noPlanFileSummary.innerHTML = `<strong>${file.name}</strong> <span class="text-secondary">(${(file.size / 1024).toFixed(1)} KB)</span>`;
    }

    function normalizeStatus(status) {
        const statusMap = {
            PLANNED: "Planned",
            COMPLETED: "Completed",
            POSTPONED: "Postponed",
            CANCELLED: "Cancelled",
            Planned: "Planned",
            Completed: "Completed",
            Postponed: "Postponed",
            Cancelled: "Cancelled"
        };

        return statusMap[status] ?? "Planned";
    }

    function renderWeekFilter(maxWeek, selectedWeek) {
        weekFilterMenu.innerHTML = "";

        for (let week = 1; week <= maxWeek; week++) {
            const item = document.createElement("li");
            item.innerHTML = `<button type="button" class="dropdown-item" data-week="${week}">Week ${week}</button>`;
            weekFilterMenu.appendChild(item);
        }
    }

    function renderWeekPager(maxWeek, selectedWeek) {
        weekPager.innerHTML = "";

        const previous = document.createElement("button");
        previous.type = "button";
        previous.disabled = selectedWeek === 1;
        previous.innerHTML = `<i class="bi bi-chevron-left"></i>`;
        previous.dataset.week = String(Math.max(1, selectedWeek - 1));
        weekPager.appendChild(previous);

        const visibleWeeks = Array.from(
            new Set([1, 2, 3, selectedWeek, maxWeek].filter((week) => week >= 1 && week <= maxWeek))
        ).sort((left, right) => left - right);

        visibleWeeks.forEach((week, index) => {
            const previousWeek = visibleWeeks[index - 1];
            if (index > 0 && week - previousWeek > 1) {
                const dots = document.createElement("span");
                dots.textContent = "...";
                weekPager.appendChild(dots);
            }

            const button = document.createElement("button");
            button.type = "button";
            button.dataset.week = String(week);
            button.className = week === selectedWeek ? "active" : "";
            button.textContent = String(week);
            weekPager.appendChild(button);
        });

        const next = document.createElement("button");
        next.type = "button";
        next.disabled = selectedWeek === maxWeek;
        next.innerHTML = `<i class="bi bi-chevron-right"></i>`;
        next.dataset.week = String(Math.min(maxWeek, selectedWeek + 1));
        weekPager.appendChild(next);

        const label = document.createElement("small");
        label.textContent = `week ${selectedWeek} of ${maxWeek}`;
        weekPager.appendChild(label);
    }

    function formatDateRange(sessions) {
        if (!sessions.length) {
            return "No dates";
        }

        const sortedDates = sessions
            .map((session) => new Date(session.sessionDate))
            .sort((a, b) => a - b);

        const formatter = new Intl.DateTimeFormat("en-US", {
            month: "short",
            day: "numeric"
        });

        return `${formatter.format(sortedDates[0])} - ${formatter.format(sortedDates[sortedDates.length - 1])}`;
    }

    function updateWeekHeader(subjectId, selectedWeek, weekSessions) {
        const dateRange = formatDateRange(weekSessions);
        weekFilterButton.textContent = `${teacherGrade} | ${subjectLabel(subjectId)} | Week ${selectedWeek} (${dateRange})`;
    }

    function describeSession(session) {
        const items = Array.isArray(session.items)
            ? session.items.filter((item) => !["Cancelled", "Postponed"].includes(normalizeStatus(item.status)))
            : [];
        const skillIds = Array.from(
            new Set(
                items.flatMap((item) => Array.isArray(item.skillsSupported) ? item.skillsSupported : [])
            )
        );
        const itemBreakdown = items.map((item) => ({
            name: item.title ?? item.name ?? "Planned activity",
            minutes: Number(item.estimatedTime ?? item.estimatedMinutes ?? 0),
            status: normalizeStatus(item.status),
            notes: item.notes ?? "No notes yet",
            sourceItem: item,
            skillNames: Array.isArray(item.skillsSupported)
                ? item.skillsSupported.map((skill) => skillLabel(skill))
                : []
        }));
        const totalMinutes = itemBreakdown.reduce((sum, item) => sum + item.minutes, 0);
        const focusSummary = skillIds.length
            ? skillIds.map((skill) => skillLabel(skill)).join(" • ")
            : "Planned lesson";
        const firstItem = items[0];

        return {
            title: skillIds.length ? `${skillLabel(skillIds[0])} Focus` : (firstItem?.name ?? "Teaching session"),
            lessonLabel: firstItem
                ? `Unit ${firstItem.unitNo} • Lesson ${firstItem.lessonNo}`
                : "Planned lesson",
            focusSummary,
            itemCount: itemBreakdown.length,
            totalMinutes,
            itemBreakdown
        };
    }

    function renderArchiveList(target, items, emptyText) {
        if (!items?.length) {
            target.innerHTML = `<div class="plan-archive-item"><small>${emptyText}</small></div>`;
            return;
        }

        target.innerHTML = items.map((item) => `
            <div class="plan-archive-item">
                <div class="plan-archive-item-head">
                    <strong>${item.title}</strong>
                    <button type="button" class="plan-archive-action js-restore-archived-item" data-plan-item-id="${item.planItemId}" data-session-id="${item.sessionId}">Back to planned</button>
                </div>
                <small>${item.day} • Week ${item.sessionWeekNo} • ${item.estimatedTime} minutes</small>
                <small>${item.notes || "No notes"}</small>
            </div>
        `).join("");
    }

    function renderUnplacedList(target, items, emptyText) {
        if (!items?.length) {
            target.innerHTML = `<div class="plan-archive-item"><small>${emptyText}</small></div>`;
            return;
        }

        target.innerHTML = items.map((item) => `
            <div class="plan-archive-item">
                <div class="plan-archive-item-head">
                    <strong>${item.title}</strong>
                    <span class="plan-reason-pill ${String(item.priority || "LOW").toUpperCase() === "HIGH" ? "behind" : String(item.priority || "LOW").toUpperCase() === "MID" ? "overflow" : "buffer"}">${item.priority || "LOW"} priority</span>
                </div>
                <small>${Number(item.estimatedTime ?? 0)} minutes</small>
                <small>${item.originalDay || "Unknown day"}${item.originalSessionWeekNo ? ` • Week ${item.originalSessionWeekNo}` : ""}</small>
            </div>
        `).join("");
    }

    function getReorderFingerprint(summary) {
        if (!summary?.planNeedsReordering) return null;
        return `${generatedPlan?.planId || ""}:${summary.classSpeedPercentage}:${summary.reorderReasons?.join(",")}:${summary.overloadedSessions}`;
    }

    function buildReorderMessage(summary) {
        const reasons = Array.isArray(summary?.reorderReasons) ? summary.reorderReasons : [];
        const messages = [];

        if (reasons.includes("PROGRESS_BEHIND")) {
            messages.push(`Class pace is ${summary.classSpeedPercentage}% of expected progress.`);
        }
        if (reasons.includes("SESSION_OVERFLOW")) {
            messages.push(`${summary.overloadedSessions} session(s) are over their time limit.`);
        }

        return messages.length
            ? `${messages.join(" ")} Reorder future sessions to keep the plan on track.`
            : "The current class pace suggests replanning future sessions.";
    }

    function getPlanModeStorageKey() {
        return generatedPlan?.planId ? `bridgePlanReorderMode:${generatedPlan.planId}` : null;
    }

    function getStoredPlanMode() {
        const key = getPlanModeStorageKey();
        return key ? sessionStorage.getItem(key) : null;
    }

    function persistPlanMode(mode) {
        const key = getPlanModeStorageKey();
        if (!key) return;
        sessionStorage.setItem(key, mode);
    }

    function updatePlanModeUi() {
        autoReorderSwitch.checked = isAutoReorderEnabled;
        planModeLabel.textContent = isAutoReorderEnabled ? "Auto" : "Manual";
        planModeDescription.textContent = isAutoReorderEnabled
            ? "Auto mode reorders future sessions whenever pace or timing pressure makes it necessary."
            : "Manual mode keeps reordering under teacher control.";
        replanBtn.disabled = isAutoReorderEnabled || isAutoReordering;
        replanBtn.classList.toggle("opacity-50", isAutoReorderEnabled);
        replanBtn.title = isAutoReorderEnabled
            ? "Switch to manual mode to reorder by hand."
            : "Reorder future sessions manually.";
    }

    function getClassSpeedState(speed) {
        const value = Number(speed ?? 100);
        if (value < 70) {
            return { label: "Critical slowdown", pillClass: "behind" };
        }
        if (value < 85) {
            return { label: "Behind pace", pillClass: "behind" };
        }
        if (value < 95) {
            return { label: "Slightly behind", pillClass: "overflow" };
        }
        if (value <= 110) {
            return { label: "On track", pillClass: "track" };
        }
        return { label: "Ahead of pace", pillClass: "track" };
    }

    function renderReasonPills(summary) {
        const pills = [];
        const speedState = getClassSpeedState(summary?.classSpeedPercentage);
        pills.push(`<span class="plan-reason-pill ${speedState.pillClass}">${speedState.label}</span>`);

        if (summary?.reorderReasons?.includes("PROGRESS_BEHIND")) {
            pills.push(`<span class="plan-reason-pill behind">Progress trigger</span>`);
        }

        if (summary?.reorderReasons?.includes("SESSION_OVERFLOW")) {
            pills.push(`<span class="plan-reason-pill overflow">Session overflow</span>`);
        }

        if (summary?.bufferUsed) {
            pills.push(`<span class="plan-reason-pill buffer">Buffer used</span>`);
        }

        if (summary?.compressionApplied) {
            pills.push(`<span class="plan-reason-pill compression">Compression applied</span>`);
        }

        reorderReasonRow.innerHTML = pills.join("");
    }

    function hideReorderPrompt() {
        reorderPromptBackdrop.classList.add("d-none");
        reorderPromptModal.classList.add("d-none");
    }

    function hideAutoReorderChoice() {
        autoReorderChoiceBackdrop.classList.add("d-none");
        autoReorderChoiceModal.classList.add("d-none");
    }

    function showAutoReorderChoice() {
        autoReorderChoiceBackdrop.classList.remove("d-none");
        autoReorderChoiceModal.classList.remove("d-none");
    }

    function hideAutoReorderInfo() {
        autoReorderInfoBackdrop.classList.add("d-none");
        autoReorderInfoModal.classList.add("d-none");
    }

    function hideReorderDetails() {
        reorderDetailsBackdrop.classList.add("d-none");
        reorderDetailsModal.classList.add("d-none");
    }

    function renderReorderDetails(summary = planSummaryState) {
        if (!summary) {
            reorderDetailsSummary.innerHTML = "";
            reorderCompressionList.innerHTML = "";
            reorderUnplacedList.innerHTML = "";
            return;
        }

        reorderDetailsMessage.textContent = buildReorderMessage(summary);
        const summaryItems = [
            `<div class="plan-details-summary-item"><strong>Class speed:</strong> ${Number(summary.classSpeedPercentage ?? 100)}%</div>`,
            `<div class="plan-details-summary-item"><strong>Expected completed minutes:</strong> ${Number(summary.expectedCompletedMinutes ?? 0)}</div>`,
            `<div class="plan-details-summary-item"><strong>Actual completed minutes:</strong> ${Number(summary.actualCompletedMinutes ?? 0)}</div>`,
            `<div class="plan-details-summary-item"><strong>Buffer used:</strong> ${summary.bufferUsed ? `${Number(summary.bufferMinutesUsed ?? 0)} minute(s)` : "No"}</div>`,
            `<div class="plan-details-summary-item"><strong>Compression applied:</strong> ${summary.compressionApplied ? "Yes" : "No"}</div>`
        ];

        reorderDetailsSummary.innerHTML = summaryItems.join("");

        if (Array.isArray(summary.compressedItems) && summary.compressedItems.length > 0) {
            reorderCompressionList.innerHTML = summary.compressedItems.map((item) => `
                <div class="plan-compression-item">
                    <strong>${item.title}</strong>
                    <small>${item.priority} priority</small>
                    <small>${Number(item.oldEstimatedTime ?? 0)} min → ${Number(item.newEstimatedTime ?? 0)} min</small>
                </div>
            `).join("");
        } else {
            reorderCompressionList.innerHTML = `<div class="plan-details-summary-item"><strong>No activities were compressed.</strong></div>`;
        }

        if (Array.isArray(summary.unplacedItems) && summary.unplacedItems.length > 0) {
            reorderUnplacedList.innerHTML = summary.unplacedItems.map((item) => `
                <div class="plan-compression-item">
                    <strong>${item.title}</strong>
                    <small>${item.priority} priority</small>
                    <small>${Number(item.estimatedTime ?? 0)} min • ${item.originalDay || "Unknown day"}${item.originalSessionWeekNo ? ` • Week ${item.originalSessionWeekNo}` : ""}</small>
                </div>
            `).join("");
        } else {
            reorderUnplacedList.innerHTML = `<div class="plan-details-summary-item"><strong>No activities remain unplaced after reordering.</strong></div>`;
        }
    }

    function showReorderDetails(summary = planSummaryState) {
        renderReorderDetails(summary);
        reorderDetailsBackdrop.classList.remove("d-none");
        reorderDetailsModal.classList.remove("d-none");
    }

    function showAutoReorderInfo(summary) {
        autoReorderInfoMessage.textContent = buildReorderMessage(summary);
        autoReorderInfoBackdrop.classList.remove("d-none");
        autoReorderInfoModal.classList.remove("d-none");
    }

    function showReorderPrompt(summary) {
        if (isAutoReorderEnabled) {
            return;
        }
        const fingerprint = getReorderFingerprint(summary);
        if (!fingerprint || dismissedReorderFingerprint === fingerprint) {
            return;
        }

        reorderPromptMessage.textContent = buildReorderMessage(summary);
        reorderPromptBackdrop.classList.remove("d-none");
        reorderPromptModal.classList.remove("d-none");
    }

    function applyPlanSummary(summary) {
        planSummaryState = summary;
        planProgressValue.textContent = `${Number(summary?.progressPercentage ?? 0)}%`;
        classSpeedValue.textContent = `${Number(summary?.classSpeedPercentage ?? 100)}%`;
        classSpeedLabel.textContent = getClassSpeedState(summary?.classSpeedPercentage).label;
        renderArchiveList(
            postponedArchiveList,
            summary?.postponedItems ?? [],
            "No postponed activities."
        );
        renderArchiveList(
            cancelledArchiveList,
            summary?.cancelledItemsArchive ?? [],
            "No cancelled activities."
        );
        renderUnplacedList(
            unplacedArchiveList,
            summary?.unplacedItems ?? [],
            "No unplaced activities."
        );
        renderReasonPills(summary);
        if (summary?.planNeedsReordering) {
            reorderBanner.textContent = buildReorderMessage(summary);
            reorderBanner.classList.add("show");
            if (isAutoReorderEnabled) {
                const fingerprint = getReorderFingerprint(summary);
                if (fingerprint && fingerprint !== lastAutoReorderFingerprint && !isAutoReordering) {
                    lastAutoReorderFingerprint = fingerprint;
                    void replanSelectedWeek({
                        silent: true,
                        showAutoInfo: true,
                        summary,
                        anchorMode: "auto"
                    });
                }
            } else {
                showReorderPrompt(summary);
            }
        } else {
            reorderBanner.classList.remove("show");
            hideReorderPrompt();
        }
    }

    function resetPlanSummaryUi() {
        planSummaryState = null;
        planProgressValue.textContent = "0%";
        classSpeedValue.textContent = "100%";
        classSpeedLabel.textContent = "On track";
        sessionCountValue.textContent = "0";
        atRiskValue.textContent = "0";
        renderArchiveList(postponedArchiveList, [], "No postponed activities.");
        renderArchiveList(cancelledArchiveList, [], "No cancelled activities.");
        renderUnplacedList(unplacedArchiveList, [], "No unplaced activities.");
        reorderReasonRow.innerHTML = `<span class="plan-reason-pill track">On track</span>`;
        reorderBanner.classList.remove("show");
        reorderBanner.textContent = "";
        hideReorderPrompt();
        hideAutoReorderInfo();
        hideReorderDetails();
    }

    async function loadPlanSummary() {
        if (!generatedPlan?.planId || !token) {
            return;
        }

        try {
            const response = await fetch(`${backendBaseUrl}/plans/${generatedPlan.planId}/progress`, {
                headers: { Authorization: `Bearer ${token}` }
            });
            const data = await response.json().catch(() => null);
            if (!response.ok || !data) {
                return;
            }
            applyPlanSummary(data);
        } catch {
            return;
        }
    }

    function renderBoard(sessions, selectedWeek, totalWeeks) {
        selectedWeekNo = selectedWeek;
        const weekSessions = sessions.filter(
            (session) => Number(session.sessionWeekNo) === selectedWeek
        );

        planProgressValue.textContent = "0%";
        sessionCountValue.textContent = String(weekSessions.length);
        updateWeekHeader(generatedPlan?.subjectId ?? "", selectedWeek, weekSessions);
        renderWeekPager(totalWeeks, selectedWeek);

        weeklyPlanGrid.innerHTML = "";

        dayOrder.forEach((day) => {
            const daySessions = weekSessions
                .filter((entry) => entry.day === day)
                .sort((left, right) => Number(left.slotNumber ?? 0) - Number(right.slotNumber ?? 0));
            const column = document.createElement("article");
            column.className = "day-plan-column";

            if (!daySessions.length) {
                column.innerHTML = `
                    <div class="day-pill">${day}</div>
                    <div class="empty-session-card"></div>
                `;
                weeklyPlanGrid.appendChild(column);
                return;
            }

            const sessionCards = daySessions.map((session, sessionPosition) => {
                const summary = describeSession(session);
                const activityRows = summary.itemBreakdown.length
                    ? summary.itemBreakdown.map((item, index) => {
                        const statusBadge = item.status === "Completed"
                            ? `<span class="activity-status-badge activity-status-badge-completed">Completed</span>`
                            : "";
                        const rowClass = item.status === "Completed"
                            ? "activity-row activity-row-completed"
                            : "activity-row";

                        const quickStatusButton = `
                            <button
                                type="button"
                                class="activity-quick-status js-toggle-complete ${item.status === "Completed" ? "completed" : ""}"
                                data-session-id="${session.sessionId}"
                                data-index="${index}"
                                data-status="${item.status}"
                                aria-label="${item.status === "Completed" ? "Mark activity as planned" : "Mark activity as completed"}">
                                <i class="bi ${item.status === "Completed" ? "bi-check2" : "bi-circle"}"></i>
                            </button>
                        `;

                        return `
                        <div class="${rowClass}">
                            <div class="activity-row-main">
                                ${quickStatusButton}
                                <span class="activity-row-title">${item.name}</span>
                                ${statusBadge}
                            </div>
                            <div>
                                <button type="button" class="activity-icon js-edit-activity" data-session-id="${session.sessionId}" data-index="${index}" aria-label="Edit activity"><i class="bi bi-pencil"></i></button>
                                <button type="button" class="activity-icon js-show-details" data-session-id="${session.sessionId}" data-index="${index}" aria-label="Show details"><i class="bi bi-card-list"></i></button>
                            </div>
                            <small><i class="bi bi-clock"></i> ${item.minutes} minutes</small>
                        </div>
                    `;
                    }).join("")
                    : `<div class="activity-row activity-row-plain"><span>No activities assigned</span></div>`;

                const classNumber = Number(session.slotNumber ?? sessionPosition + 1);

                return `
                    <div class="session-card">
                        <div class="session-slot-label">Class ${classNumber}</div>
                        <h2 class="session-title">${summary.title}</h2>
                        <p class="session-unit">${summary.lessonLabel}</p>
                        <p class="session-skills">Skill Focus: <span>${summary.focusSummary}</span></p>
                        <div class="session-meta">
                            <span><i class="bi bi-lightbulb"></i> ${summary.itemCount} Activities</span>
                            <span><i class="bi bi-clock"></i> ${summary.totalMinutes} minutes</span>
                        </div>
                        <div class="activity-list">${activityRows}</div>
                    </div>
                `;
            }).join("");

            column.innerHTML = `
                <div class="day-pill">${day}</div>
                <div class="day-session-stack">
                    ${sessionCards}
                </div>
            `;

            weeklyPlanGrid.appendChild(column);
        });

        attachActivityActions(weekSessions);
    }

    function findActivity(weekSessions, sessionId, index) {
        const session = weekSessions.find((entry) => entry.sessionId === sessionId);
        if (!session) return null;
        const summary = describeSession(session);
        return {
            session,
            item: summary.itemBreakdown[Number(index)],
            sourceItem: summary.itemBreakdown[Number(index)]?.sourceItem,
            title: summary.itemBreakdown[Number(index)]?.name ?? "Activity name",
            unit: summary.lessonLabel
        };
    }

    function fillPanels(activity) {
        selectedActivity = activity;
        const item = activity?.item;
        const status = normalizeStatus(item?.status);
        detailsTitle.textContent = activity?.title ?? "Activity name";
        detailsUnit.textContent = activity?.unit ?? "Unit name";
        detailsDuration.textContent = `${item?.minutes ?? 0} minutes`;
        detailsStatus.textContent = status;
        detailsNotes.textContent = item?.notes ?? "No notes yet";
        editedDurationMinutes = Number(item?.minutes ?? 0);
        editDuration.textContent = `${editedDurationMinutes} minutes`;
        activityNotes.value = item?.notes === "No notes yet" ? "" : item?.notes ?? "";

        document.querySelectorAll('input[name="activityStatus"]').forEach((input) => {
            input.checked = input.value === status;
        });
    }

    function recalculateSessionDuration(session) {
        const items = Array.isArray(session.items) ? session.items : [];
        session.usedDuration = items
            .filter((item) => normalizeStatus(item.status) !== "Cancelled" && normalizeStatus(item.status) !== "Postponed")
            .reduce((sum, item) => sum + Number(item.estimatedTime ?? item.estimatedMinutes ?? 0), 0);
    }

    function saveGeneratedPlan() {
        if (generatedPlan) {
            sessionStorage.setItem(getPlanStorageKey(generatedPlan.subjectId), JSON.stringify(generatedPlan));
            sessionStorage.setItem("bridgeGeneratedPlan", JSON.stringify(generatedPlan));
        }
    }

    function replaceSessionInGeneratedPlan(updatedSession) {
        if (!generatedPlan?.sessions || !updatedSession?.sessionId) return;

        generatedPlan.sessions = generatedPlan.sessions.map((session) =>
            session.sessionId === updatedSession.sessionId ? updatedSession : session
        );
    }

    function getFirstSessionForSelectedWeek() {
        if (!generatedPlan?.sessions) return null;

        return generatedPlan.sessions
            .filter((session) => Number(session.sessionWeekNo) === selectedWeekNo)
            .sort((left, right) => {
                const leftDay = dayOrder.indexOf(left.day);
                const rightDay = dayOrder.indexOf(right.day);
                return leftDay - rightDay || Number(left.slotNumber ?? 0) - Number(right.slotNumber ?? 0);
            })[0] ?? null;
    }

    function getFirstFutureReorderableSession() {
        if (!generatedPlan?.sessions) return null;

        const startOfToday = new Date();
        startOfToday.setHours(0, 0, 0, 0);
        const cutoff = startOfToday.getTime();
        const futureSessions = generatedPlan.sessions
            .filter((session) => new Date(session.sessionDate).getTime() >= cutoff)
            .sort((left, right) => {
                const leftDate = new Date(left.sessionDate).getTime();
                const rightDate = new Date(right.sessionDate).getTime();
                if (leftDate !== rightDate) {
                    return leftDate - rightDate;
                }

                const leftDay = dayOrder.indexOf(left.day);
                const rightDay = dayOrder.indexOf(right.day);
                if (leftDay !== rightDay) {
                    return leftDay - rightDay;
                }

                return Number(left.slotNumber ?? 0) - Number(right.slotNumber ?? 0);
            });

        const preferredSession = futureSessions.find((session) =>
            Array.isArray(session.items) &&
            session.items.some((item) => normalizeStatus(item.status) === "Planned")
        );

        const selectedWeekSession = getFirstSessionForSelectedWeek();
        if (
            selectedWeekSession &&
            Array.isArray(selectedWeekSession.items) &&
            selectedWeekSession.items.some((item) => normalizeStatus(item.status) === "Planned")
        ) {
            return selectedWeekSession;
        }

        return preferredSession ?? futureSessions[0] ?? selectedWeekSession;
    }

    function updateStoredPlanFromResponse(updatedPlan, summary = null) {
        if (!generatedPlan || !updatedPlan) return;

        Object.assign(generatedPlan, updatedPlan);
        saveGeneratedPlan();

        const totalWeeks = Math.max(1, Number(generatedPlan.totalWeeks ?? 0));
        planMetaLabel.textContent = `${teacherGrade} | ${subjectLabel(generatedPlan.subjectId)} | ${totalWeeks} weeks`;
        planSummaryText.textContent = `${subjectLabel(generatedPlan.subjectId)} plan with ${generatedPlan.sessions.length} generated sessions.`;
        renderWeekFilter(totalWeeks, selectedWeekNo);
        renderBoard(generatedPlan.sessions, selectedWeekNo, totalWeeks);
        if (summary) {
            applyPlanSummary(summary);
        }
    }

    async function replanSelectedWeek(options = {}) {
        const { silent = false, showAutoInfo = false, summary = null, anchorMode = "selected" } = options;
        if (!generatedPlan?.planId) {
            if (!silent) {
                alert("No generated plan is available to reorder.");
            }
            return;
        }

        if (!token) {
            if (!silent) {
                alert("You need to be logged in before reordering the plan.");
            }
            return;
        }

        const anchorSession = anchorMode === "auto"
            ? getFirstFutureReorderableSession()
            : getFirstSessionForSelectedWeek();
        if (!anchorSession?.sessionId) {
            if (!silent) {
                alert("No session found in this week to reorder from.");
            }
            return;
        }

        isAutoReordering = true;
        updatePlanModeUi();
        replanBtn.textContent = silent ? "Auto reordering..." : "Reordering...";

        try {
            const response = await fetch(`${backendBaseUrl}/plans/${generatedPlan.planId}/replan`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    Authorization: `Bearer ${token}`
                },
                body: JSON.stringify({
                    fromSessionId: anchorSession.sessionId
                })
            });

            const data = await response.json().catch(() => null);

            if (!response.ok) {
                throw new Error(data?.message || "Unable to reorder the plan.");
            }

            updateStoredPlanFromResponse(data?.plan, data?.summary ?? null);
            if (showAutoInfo) {
                showAutoReorderInfo(data?.summary ?? summary ?? planSummaryState);
            }

            if (data?.planOverCapacity) {
                if (!silent) {
                    alert(`${data.unplacedItems?.length ?? 0} item(s) could not fit in the remaining sessions.`);
                }
            }
        } catch (error) {
            if (!silent) {
                alert(error.message || "Unable to reorder the plan.");
            }
        } finally {
            isAutoReordering = false;
            updatePlanModeUi();
            replanBtn.textContent = "Reorder";
        }
    }

    function updateDuration(delta) {
        editedDurationMinutes = Math.max(1, Math.min(maxActivityMinutes, editedDurationMinutes + delta));
        editDuration.textContent = `${editedDurationMinutes} minutes`;
    }

    async function saveActivityEdit() {
        if (!selectedActivity?.sourceItem || !selectedActivity?.session || !generatedPlan) {
            closeActivityPanels();
            return;
        }

        if (!token) {
            alert("You need to be logged in before updating the activity.");
            return;
        }

        if (!generatedPlan.planId || !selectedActivity.session.sessionId || !selectedActivity.sourceItem.planItemId) {
            alert("This activity is missing the ids needed for updating.");
            return;
        }

        const selectedStatus = document.querySelector('input[name="activityStatus"]:checked')?.value ?? "Planned";
        const previousDuration = Number(selectedActivity.sourceItem.estimatedTime ?? selectedActivity.sourceItem.estimatedMinutes ?? 0);
        const previousStatus = normalizeStatus(selectedActivity.sourceItem.status);
        const hasMaterialChange =
            editedDurationMinutes !== previousDuration ||
            selectedStatus !== previousStatus;

        if (editedDurationMinutes > maxActivityMinutes) {
            alert(`Each activity is limited to ${maxActivityMinutes} minutes.`);
            return;
        }

        if (hasMaterialChange) {
            lastAutoReorderFingerprint = null;
            dismissedReorderFingerprint = null;
        }

        activitySaveButton.disabled = true;
        activitySaveButton.textContent = "Saving...";

        try {
            if (editedDurationMinutes !== previousDuration) {
                const timeResponse = await fetch(`${backendBaseUrl}/plans/${generatedPlan.planId}/items/time`, {
                    method: "PATCH",
                    headers: {
                        "Content-Type": "application/json",
                        Authorization: `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        sessionId: selectedActivity.session.sessionId,
                        planItemId: selectedActivity.sourceItem.planItemId,
                        estimatedMinutes: editedDurationMinutes
                    })
                });

                const timeData = await timeResponse.json().catch(() => null);
                if (!timeResponse.ok) {
                    throw new Error(timeData?.message || "Unable to update activity duration.");
                }

                replaceSessionInGeneratedPlan(timeData?.session);
                selectedActivity.session = timeData?.session;
                const refreshedItem = timeData?.session?.items?.find((item) => item.planItemId === selectedActivity.sourceItem.planItemId);
                if (refreshedItem) {
                    selectedActivity.sourceItem = refreshedItem;
                }
                if (timeData?.progress) {
                    applyPlanSummary(timeData.progress);
                }
            }

            if (selectedStatus !== previousStatus) {
                const statusResponse = await fetch(`${backendBaseUrl}/plans/${generatedPlan.planId}/items/status`, {
                    method: "PATCH",
                    headers: {
                        "Content-Type": "application/json",
                        Authorization: `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        sessionId: selectedActivity.session.sessionId,
                        planItemId: selectedActivity.sourceItem.planItemId,
                        status: selectedStatus
                    })
                });

                const statusData = await statusResponse.json().catch(() => null);
                if (!statusResponse.ok) {
                    throw new Error(statusData?.message || "Unable to update activity status.");
                }

                if (statusData?.session) {
                    replaceSessionInGeneratedPlan(statusData.session);
                    selectedActivity.session = statusData.session;
                    const refreshedItem = statusData.session.items?.find((item) => item.planItemId === selectedActivity.sourceItem.planItemId);
                    if (refreshedItem) {
                        selectedActivity.sourceItem = refreshedItem;
                    }
                }
                if (statusData?.progress) {
                    applyPlanSummary(statusData.progress);
                }
            }

            selectedActivity.sourceItem.notes = activityNotes.value.trim() || undefined;

            recalculateSessionDuration(selectedActivity.session);
            replaceSessionInGeneratedPlan(selectedActivity.session);
            saveGeneratedPlan();
            closeActivityPanels();
            renderWeekFilter(Math.max(1, Number(generatedPlan.totalWeeks ?? 0)), selectedWeekNo);
            renderBoard(generatedPlan.sessions, selectedWeekNo, Math.max(1, Number(generatedPlan.totalWeeks ?? 0)));
        } catch (error) {
            alert(error.message || "Unable to save activity changes.");
        } finally {
            activitySaveButton.disabled = false;
            activitySaveButton.textContent = "Save";
        }
    }

    function closeActivityPanels() {
        activityPanelBackdrop.classList.add("d-none");
        activityDetailsPanel.classList.add("d-none");
        activityEditPanel.classList.add("d-none");
    }

    function placePanel(panel, anchor) {
        if (!panel || !anchor) return;

        const panelWidth = panel.offsetWidth || 384;
        const panelHeight = panel.offsetHeight || 420;
        const anchorRect = anchor.getBoundingClientRect();
        const gap = 12;
        const margin = 16;
        const viewportWidth = window.innerWidth;
        const viewportHeight = window.innerHeight;

        let left = anchorRect.right + gap;
        let top = anchorRect.top;

        if (left + panelWidth > viewportWidth - margin) {
            left = anchorRect.left - panelWidth - gap;
        }

        if (left < margin) {
            left = Math.min(anchorRect.right + gap, viewportWidth - panelWidth - margin);
        }

        if (top + panelHeight > viewportHeight - margin) {
            top = viewportHeight - panelHeight - margin;
        }

        if (top < margin) {
            top = margin;
        }

        panel.style.left = `${left}px`;
        panel.style.top = `${top}px`;
    }

    function openDetailsPanel(activity, anchor) {
        selectedAnchor = anchor;
        fillPanels(activity);
        activityPanelBackdrop.classList.remove("d-none");
        activityDetailsPanel.classList.remove("d-none");
        activityEditPanel.classList.add("d-none");
        placePanel(activityDetailsPanel, selectedAnchor);
    }

    function openEditPanel(activity = selectedActivity, anchor = selectedAnchor) {
        selectedAnchor = anchor;
        fillPanels(activity);
        activityPanelBackdrop.classList.remove("d-none");
        activityDetailsPanel.classList.add("d-none");
        activityEditPanel.classList.remove("d-none");
        placePanel(activityEditPanel, selectedAnchor);
    }

    function attachActivityActions(weekSessions) {
        document.querySelectorAll(".js-toggle-complete").forEach((button) => {
            button.addEventListener("click", async () => {
                const activity = findActivity(weekSessions, button.dataset.sessionId, button.dataset.index);
                if (!activity?.sourceItem || !activity?.session) {
                    return;
                }

                const nextStatus = normalizeStatus(button.dataset.status) === "Completed"
                    ? "Planned"
                    : "Completed";

                await updateActivityStatusDirect(activity, nextStatus);
            });
        });

        document.querySelectorAll(".js-show-details").forEach((button) => {
            button.addEventListener("click", () => {
                openDetailsPanel(findActivity(weekSessions, button.dataset.sessionId, button.dataset.index), button.closest(".activity-row"));
            });
        });

        document.querySelectorAll(".js-edit-activity").forEach((button) => {
            button.addEventListener("click", () => {
                openEditPanel(findActivity(weekSessions, button.dataset.sessionId, button.dataset.index), button.closest(".activity-row"));
            });
        });
    }

    async function updateActivityStatusDirect(activity, nextStatus) {
        if (!generatedPlan?.planId || !token || !activity?.session?.sessionId || !activity?.sourceItem?.planItemId) {
            return;
        }

        try {
            const response = await fetch(`${backendBaseUrl}/plans/${generatedPlan.planId}/items/status`, {
                method: "PATCH",
                headers: {
                    "Content-Type": "application/json",
                    Authorization: `Bearer ${token}`
                },
                body: JSON.stringify({
                    sessionId: activity.session.sessionId,
                    planItemId: activity.sourceItem.planItemId,
                    status: nextStatus
                })
            });

            const data = await response.json().catch(() => null);
            if (!response.ok) {
                throw new Error(data?.message || "Unable to update activity status.");
            }

            if (data?.session) {
                replaceSessionInGeneratedPlan(data.session);
            }
            if (data?.progress) {
                applyPlanSummary(data.progress);
            }

            saveGeneratedPlan();
            renderBoard(
                generatedPlan.sessions,
                selectedWeekNo,
                Math.max(1, Number(generatedPlan.totalWeeks ?? 0)),
            );
        } catch (error) {
            alert(error.message || "Unable to update activity status.");
        }
    }

    async function loadAtRiskStudents() {
        if (!token) {
            return;
        }

        try {
            const response = await fetch(`${backendBaseUrl}/statistics/weak-students?subjectId=${encodeURIComponent(currentSubjectId)}`, {
                headers: {
                    Authorization: `Bearer ${token}`
                }
            });

            const data = await response.json().catch(() => null);

            if (!response.ok) {
                return;
            }

            atRiskValue.textContent = Array.isArray(data) ? String(data.length) : "0";
        } catch {
            atRiskValue.textContent = "0";
        }
    }

    async function restoreArchivedItem(planItemId, sessionId) {
        if (!generatedPlan?.planId || !token || !planItemId || !sessionId) {
            return;
        }

        try {
            const response = await fetch(`${backendBaseUrl}/plans/${generatedPlan.planId}/items/status`, {
                method: "PATCH",
                headers: {
                    "Content-Type": "application/json",
                    Authorization: `Bearer ${token}`
                },
                body: JSON.stringify({
                    sessionId,
                    planItemId,
                    status: "Planned"
                })
            });

            const data = await response.json().catch(() => null);
            if (!response.ok) {
                throw new Error(data?.message || "Unable to restore the activity.");
            }

            if (data?.session) {
                replaceSessionInGeneratedPlan(data.session);
            }
            if (data?.progress) {
                applyPlanSummary(data.progress);
            }

            saveGeneratedPlan();
            renderBoard(
                generatedPlan.sessions,
                selectedWeekNo,
                Math.max(1, Number(generatedPlan.totalWeeks ?? 0)),
            );
        } catch (error) {
            alert(error.message || "Unable to restore the activity.");
        }
    }

    function initializePlanBoard() {
        setActiveSubjectTabs();
        if (!generatedPlan || !Array.isArray(generatedPlan.sessions)) {
            planIdButton.textContent = "No plan";
            planMetaLabel.textContent = `${teacherGrade} | ${subjectLabel(currentSubjectId)} | No generated plan`;
            planSummaryText.textContent = `No ${subjectLabel(currentSubjectId).toLowerCase()} plan was found for this subject.`;
            if (noPlanPanel && noPlanMessage && generateMissingPlanButton) {
                generateMissingPlanButton.textContent = `Generate ${subjectLabel(currentSubjectId)} plan`;
            }
            setNoPlanState(true);
            void hydrateNoPlanSetupState();
            resetPlanSummaryUi();
            renderBoard([], 1, 1);
            return;
        }

        setNoPlanState(false);
        const totalWeeks = Math.max(1, Number(generatedPlan.totalWeeks ?? 0));
        const initialWeek = 1;
        const storedMode = getStoredPlanMode();
        isAutoReorderEnabled = storedMode === "auto";
        updatePlanModeUi();

        planIdButton.textContent = generatedPlan.planId
            ? `plan-ID: ${generatedPlan.planId}`
            : "Current plan";
        planMetaLabel.textContent = `${teacherGrade} | ${subjectLabel(generatedPlan.subjectId)} | ${totalWeeks} weeks`;
        planSummaryText.textContent = `${subjectLabel(generatedPlan.subjectId)} plan with ${generatedPlan.sessions.length} generated sessions.`;

        renderWeekFilter(totalWeeks, initialWeek);
        renderBoard(generatedPlan.sessions, initialWeek, totalWeeks);
        loadAtRiskStudents();
        loadPlanSummary();
        if (!storedMode) {
            showAutoReorderChoice();
        }
    }

    async function loadPlanForSubject(subjectId) {
        if (!token) {
            return;
        }

        currentSubjectId = String(subjectId);
        localStorage.setItem("teacherSelectedSubject", currentSubjectId);
        const cachedPlan = sessionStorage.getItem(getPlanStorageKey(currentSubjectId));

        if (cachedPlan) {
            try {
                generatedPlan = JSON.parse(cachedPlan);
            } catch {
                generatedPlan = null;
            }
        } else {
            generatedPlan = null;
        }

        try {
            const response = await fetch(`${backendBaseUrl}/plans/mine`, {
                headers: {
                    Authorization: `Bearer ${token}`
                }
            });
            const plans = await response.json().catch(() => []);

            if (response.ok && Array.isArray(plans)) {
                const subjectPlan = plans
                    .filter((entry) => String(entry?.subjectId) === currentSubjectId)
                    .sort((left, right) => new Date(right?.startDate || 0).getTime() - new Date(left?.startDate || 0).getTime())[0] ?? null;

                if (subjectPlan?.planId) {
                    generatedPlan = subjectPlan;
                    sessionStorage.setItem(getPlanStorageKey(currentSubjectId), JSON.stringify(subjectPlan));
                    sessionStorage.setItem("bridgeGeneratedPlan", JSON.stringify(subjectPlan));
                } else if (!cachedPlan) {
                    generatedPlan = null;
                }
            }
        } catch {
            if (!cachedPlan) {
                generatedPlan = null;
            }
        }

        selectedWeekNo = 1;
        dismissedReorderFingerprint = null;
        lastAutoReorderFingerprint = null;
        initializePlanBoard();
    }

    initializePlanBoard();

    ["dragenter", "dragover", "dragleave", "drop"].forEach((eventName) => {
        noPlanDropArea?.addEventListener(eventName, (event) => {
            event.preventDefault();
            event.stopPropagation();
        });
    });

    ["dragenter", "dragover"].forEach((eventName) => {
        noPlanDropArea?.addEventListener(eventName, () => {
            noPlanDropArea.classList.add("bridge-accent");
        });
    });

    ["dragleave", "drop"].forEach((eventName) => {
        noPlanDropArea?.addEventListener(eventName, () => {
            noPlanDropArea.classList.remove("bridge-accent");
        });
    });

    noPlanDropArea?.addEventListener("drop", (event) => {
        if (!isCurrentSubjectSetupReady) {
            return;
        }
        const files = event.dataTransfer?.files;
        selectedBaselineFile = files?.[0] ?? null;
        renderNoPlanFile(selectedBaselineFile);
    });

    noPlanFileInput?.addEventListener("change", (event) => {
        if (!isCurrentSubjectSetupReady) {
            return;
        }
        selectedBaselineFile = event.target.files?.[0] ?? null;
        renderNoPlanFile(selectedBaselineFile);
    });

    async function generateMissingPlanForSubject() {
        if (!token) {
            alert("Sign in again before generating a plan.");
            return;
        }

        if (!isCurrentSubjectSetupReady) {
            alert(`Set up ${subjectLabel(currentSubjectId)} first by choosing the semester and saving weekly slots.`);
            return;
        }

        if (!selectedBaselineFile) {
            alert("Upload the baseline Excel file first.");
            return;
        }

        generateMissingPlanButton.disabled = true;
        generateMissingPlanButton.textContent = "Generating...";

        try {
            const formData = new FormData();
            formData.append("file", selectedBaselineFile);

            const normalizationResponse = await fetch(`${backendBaseUrl}/baseline/normalization?subjectId=${encodeURIComponent(currentSubjectId)}`, {
                method: "POST",
                headers: { Authorization: `Bearer ${token}` },
                body: formData
            });
            const normalizedRows = await normalizationResponse.json().catch(() => null);
            if (!normalizationResponse.ok || !Array.isArray(normalizedRows)) {
                throw new Error(normalizedRows?.message || "Unable to normalize baseline rows.");
            }

            const matchResponse = await fetch(`${backendBaseUrl}/baseline/matchStudents`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    Authorization: `Bearer ${token}`
                },
                body: JSON.stringify(normalizedRows)
            });
            const matchedRows = await matchResponse.json().catch(() => null);
            if (!matchResponse.ok || !Array.isArray(matchedRows)) {
                throw new Error(matchedRows?.message || "Unable to match baseline rows to students.");
            }

            const saveResponse = await fetch(`${backendBaseUrl}/baseline/save?subjectId=${encodeURIComponent(currentSubjectId)}`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    Authorization: `Bearer ${token}`
                },
                body: JSON.stringify(matchedRows)
            });
            const saveData = await saveResponse.json().catch(() => null);
            if (!saveResponse.ok) {
                throw new Error(saveData?.message || "Unable to save baseline results.");
            }

            const semester = Number(localStorage.getItem("teacherSelectedSemester") || "1");
            const planResponse = await fetch(`${backendBaseUrl}/plans/generate`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    Authorization: `Bearer ${token}`
                },
                body: JSON.stringify({
                    subjectId: currentSubjectId,
                    semester
                })
            });
            const planData = await planResponse.json().catch(() => null);
            if (!planResponse.ok || !planData?.planId) {
                throw new Error(planData?.message || "Unable to generate plan.");
            }

            generatedPlan = planData;
            sessionStorage.setItem(getPlanStorageKey(currentSubjectId), JSON.stringify(planData));
            sessionStorage.setItem("bridgeGeneratedPlan", JSON.stringify(planData));
            selectedBaselineFile = null;
            renderNoPlanFile(null);
            initializePlanBoard();
        } catch (error) {
            alert(error.message || "Unable to generate the plan.");
        } finally {
            generateMissingPlanButton.disabled = false;
            generateMissingPlanButton.textContent = `Generate ${subjectLabel(currentSubjectId)} plan`;
        }
    }

    generateMissingPlanButton?.addEventListener("click", () => {
        void generateMissingPlanForSubject();
    });

    detailsEditButton.addEventListener("click", () => openEditPanel());
    durationIncreaseButton.addEventListener("click", () => updateDuration(1));
    durationDecreaseButton.addEventListener("click", () => updateDuration(-1));
    activitySaveButton.addEventListener("click", saveActivityEdit);
    replanBtn.addEventListener("click", replanSelectedWeek);
    autoReorderSwitch.addEventListener("change", () => {
        isAutoReorderEnabled = autoReorderSwitch.checked;
        persistPlanMode(isAutoReorderEnabled ? "auto" : "manual");
        updatePlanModeUi();

        if (isAutoReorderEnabled && planSummaryState?.planNeedsReordering && !isAutoReordering) {
            void replanSelectedWeek({
                silent: true,
                showAutoInfo: true,
                summary: planSummaryState,
                anchorMode: "auto"
            });
        }
    });
    reorderPromptLaterButton.addEventListener("click", () => {
        dismissedReorderFingerprint = getReorderFingerprint(planSummaryState);
        hideReorderPrompt();
    });
    reorderPromptNowButton.addEventListener("click", async () => {
        hideReorderPrompt();
        dismissedReorderFingerprint = getReorderFingerprint(planSummaryState);
        await replanSelectedWeek();
    });
    reorderPromptBackdrop.addEventListener("click", () => {
        dismissedReorderFingerprint = getReorderFingerprint(planSummaryState);
        hideReorderPrompt();
    });
    autoReorderEnableButton.addEventListener("click", () => {
        isAutoReorderEnabled = true;
        persistPlanMode("auto");
        updatePlanModeUi();
        hideAutoReorderChoice();
        if (planSummaryState?.planNeedsReordering) {
            void replanSelectedWeek({
                silent: true,
                showAutoInfo: true,
                summary: planSummaryState,
                anchorMode: "auto"
            });
        }
    });
    autoReorderSkipButton.addEventListener("click", () => {
        isAutoReorderEnabled = false;
        persistPlanMode("manual");
        updatePlanModeUi();
        hideAutoReorderChoice();
    });
    autoReorderChoiceBackdrop.addEventListener("click", hideAutoReorderChoice);
    autoReorderInfoBackdrop.addEventListener("click", hideAutoReorderInfo);
    reorderDetailsBackdrop.addEventListener("click", hideReorderDetails);
    autoReorderInfoCloseButton.addEventListener("click", hideAutoReorderInfo);
    autoReorderInfoMoreButton.addEventListener("click", () => showReorderDetails());
    reorderDetailsButton.addEventListener("click", () => showReorderDetails());
    reorderDetailsCloseButton.addEventListener("click", hideReorderDetails);
    activityPanelBackdrop.addEventListener("click", closeActivityPanels);
    document.querySelectorAll(".js-close-panels").forEach((button) => {
        button.addEventListener("click", closeActivityPanels);
    });
    weekFilterMenu.addEventListener("click", (event) => {
        const button = event.target.closest("[data-week]");
        if (!button || !generatedPlan?.sessions) {
            return;
        }

        const selectedWeek = Number(button.dataset.week);
        renderWeekFilter(Math.max(1, Number(generatedPlan.totalWeeks ?? 0)), selectedWeek);
        renderBoard(generatedPlan.sessions, selectedWeek, Math.max(1, Number(generatedPlan.totalWeeks ?? 0)));
    });
    weekPager.addEventListener("click", (event) => {
        const button = event.target.closest("[data-week]");
        if (!button || button.disabled || !generatedPlan?.sessions) return;

        const selectedWeek = Number(button.dataset.week);
        renderWeekFilter(Math.max(1, Number(generatedPlan.totalWeeks ?? 0)), selectedWeek);
        renderBoard(generatedPlan.sessions, selectedWeek, Math.max(1, Number(generatedPlan.totalWeeks ?? 0)));
    });
    [postponedArchiveList, cancelledArchiveList].forEach((container) => {
        container?.addEventListener("click", (event) => {
            const button = event.target.closest(".js-restore-archived-item");
            if (!button) {
                return;
            }

            void restoreArchivedItem(button.dataset.planItemId, button.dataset.sessionId);
        });
    });
    subjectTabs?.addEventListener("click", (event) => {
        const button = event.target.closest("[data-subject-id]");
        if (!button) {
            return;
        }

        void loadPlanForSubject(button.dataset.subjectId);
    });
</script>
