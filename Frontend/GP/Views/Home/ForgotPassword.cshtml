@{
    ViewData["Title"] = "Forgot Password";
}

<style>
    .forgot-password-shell {
        min-height: calc(100vh - 9rem);
        display: flex;
        align-items: center;
        padding: 2rem 0 3rem;
    }

    .forgot-password-card {
        width: 100%;
        max-width: 36rem;
        padding: 2.25rem;
        border: 1px solid rgba(168, 164, 217, 0.26);
        border-radius: 1.75rem;
        background: rgba(255, 255, 255, 0.82);
        box-shadow: 0 24px 48px rgba(86, 97, 122, 0.12);
        backdrop-filter: blur(10px);
    }

    .forgot-password-kicker {
        margin-bottom: 0.5rem;
        color: #7b6ee6;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .forgot-password-title {
        margin-bottom: 0.65rem;
        color: #20202b;
        font-size: clamp(2rem, 3vw, 2.65rem);
        font-weight: 800;
        line-height: 1.05;
    }

    .forgot-password-copy {
        margin-bottom: 1.5rem;
        color: #6b7280;
        font-size: 1rem;
        line-height: 1.7;
    }

    .forgot-password-card .form-control {
        min-height: 3.6rem;
        border-radius: 1rem;
        border-color: rgba(168, 164, 217, 0.4);
        padding: 1rem 1.1rem;
    }

    .forgot-password-card .form-label {
        margin-bottom: 0.55rem;
        color: #3b4151;
        font-weight: 700;
    }

    .forgot-password-actions {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
    }

    .forgot-password-primary,
    .forgot-password-secondary {
        min-height: 3rem;
        padding: 0.8rem 1.3rem;
        border-radius: 999px;
        font-weight: 700;
        text-decoration: none;
    }

    .forgot-password-primary {
        border: none;
        background: linear-gradient(135deg, #c8c5ff 0%, #8f6de5 100%);
        color: #fff;
        box-shadow: 0 18px 30px rgba(143, 109, 229, 0.2);
    }

    .forgot-password-primary:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .forgot-password-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #c9c6ff;
        background: #fff;
        color: #8f6de5;
    }

    .forgot-password-status {
        border-radius: 1rem;
        padding: 0.95rem 1rem;
        font-weight: 600;
    }

    @@media (max-width: 767.98px) {
        .forgot-password-shell {
            min-height: auto;
            padding-top: 1rem;
        }

        .forgot-password-card {
            padding: 1.4rem;
            border-radius: 1.25rem;
        }

        .forgot-password-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .forgot-password-primary,
        .forgot-password-secondary {
            width: 100%;
        }
    }
</style>

<div class="container forgot-password-shell">
    <div class="row justify-content-center w-100">
        <div class="col-xl-5 col-lg-6 col-md-8">
            <div class="forgot-password-card">
                <div class="forgot-password-kicker">Account Recovery</div>
                <h1 class="forgot-password-title">Forgot your password?</h1>
                <p class="forgot-password-copy">
                    Enter the email address linked to your account and we’ll send you a verification code to reset your password.
                </p>

                <div id="forgotErrorBox" class="alert alert-danger forgot-password-status d-none"></div>
                <div id="forgotSuccessBox" class="alert alert-success forgot-password-status d-none"></div>

                <div class="mb-2">
                    <label class="form-label" for="email">Email Address</label>
                    <input type="email" class="form-control" id="email" placeholder="Enter your email address">
                </div>

                <div class="forgot-password-actions">
                    <button type="button" class="forgot-password-primary" id="sendResetButton">Send Code</button>
                    <a asp-action="Login" asp-controller="Home" class="forgot-password-secondary">Back to Login</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const emailField = document.getElementById("email");
    const sendResetButton = document.getElementById("sendResetButton");
    const forgotErrorBox = document.getElementById("forgotErrorBox");
    const forgotSuccessBox = document.getElementById("forgotSuccessBox");

    function showForgotError(message) {
        forgotSuccessBox.classList.add("d-none");
        forgotErrorBox.textContent = message;
        forgotErrorBox.classList.remove("d-none");
    }

    function showForgotSuccess(message) {
        forgotErrorBox.classList.add("d-none");
        forgotSuccessBox.textContent = message;
        forgotSuccessBox.classList.remove("d-none");
    }

    sendResetButton.addEventListener("click", async () => {
        const email = emailField.value.trim();
        if (!email) {
            showForgotError("Please enter your email.");
            return;
        }

        sendResetButton.disabled = true;
        sendResetButton.textContent = "Sending...";

        try {
            const response = await fetch(`${backendBaseUrl}/auth/forgot-password`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ email })
            });

            const data = await response.json().catch(() => null);
            if (!response.ok) {
                const message = Array.isArray(data?.message) ? data.message.join(", ") : data?.message;
                throw new Error(message || "Unable to send reset code.");
            }

            sessionStorage.setItem("bridgeResetEmail", email);
            showForgotSuccess(data?.message || "Password reset email sent successfully.");
            setTimeout(() => {
                window.location.href = '@Url.Action("NewPassword", "Home")';
            }, 1200);
        } catch (error) {
            showForgotError(error.message || "Unable to connect to the server.");
        } finally {
            sendResetButton.disabled = false;
            sendResetButton.textContent = "Send Code";
        }
    });
</script>
