@{
    ViewData["Title"] = "Forgot Password";
}

<div class="page-wrap">
    <div class="forgot-card">
        <h1 class="forgot-title">Forgot Password?</h1>
        <p class="forgot-text">
            Enter your email address and we’ll send you a code to reset your password.
        </p>

        <div id="forgotErrorBox" class="alert alert-danger d-none"></div>
        <div id="forgotSuccessBox" class="alert alert-success d-none"></div>

        <div class="mb-3">
            <label class="form-label">Email Address</label>
            <input type="email" class="form-control" id="email" placeholder="Enter your email">
        </div>

        <button type="button" class="send-btn" id="sendResetButton">Send Code</button>

        <a asp-action="Login" asp-controller="Home" class="back-link">Back to Login</a>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const emailField = document.getElementById("email");
    const sendResetButton = document.getElementById("sendResetButton");
    const forgotErrorBox = document.getElementById("forgotErrorBox");
    const forgotSuccessBox = document.getElementById("forgotSuccessBox");

    function showForgotError(message) {
        forgotSuccessBox.classList.add("d-none");
        forgotErrorBox.textContent = message;
        forgotErrorBox.classList.remove("d-none");
    }

    function showForgotSuccess(message) {
        forgotErrorBox.classList.add("d-none");
        forgotSuccessBox.textContent = message;
        forgotSuccessBox.classList.remove("d-none");
    }

    sendResetButton.addEventListener("click", async () => {
        const email = emailField.value.trim();
        if (!email) {
            showForgotError("Please enter your email.");
            return;
        }

        sendResetButton.disabled = true;

        try {
            const response = await fetch(`${backendBaseUrl}/auth/forgot-password`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ email })
            });

            const data = await response.json().catch(() => null);
            if (!response.ok) {
                const message = Array.isArray(data?.message) ? data.message.join(", ") : data?.message;
                throw new Error(message || "Unable to send reset code.");
            }

            sessionStorage.setItem("bridgeResetEmail", email);
            showForgotSuccess(data?.message || "Password reset email sent successfully.");
            setTimeout(() => {
                window.location.href = '@Url.Action("NewPassword", "Home")';
            }, 1200);
        } catch (error) {
            showForgotError(error.message || "Unable to connect to the server.");
        } finally {
            sendResetButton.disabled = false;
        }
    });
</script>
