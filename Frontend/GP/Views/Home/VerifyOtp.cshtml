@{
    ViewData["Title"] = "VerifyOtp";
}

<style>
    .bridge-accent {
        background: #c9c6ff !important;
        border-color: #c9c6ff !important;
        color: #1f2430 !important;
    }

    .bridge-accent-outline {
        border-color: #c9c6ff !important;
        color: #74AED8 !important;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h1 class="fw-bold mb-2">Verify your account</h1>
                <p class="text-secondary mb-4">
                    Enter the OTP code sent to your email to verify your teacher account.
                </p>

                <div class="mb-3">
                    <label for="otpInput" class="form-label fw-semibold">OTP code</label>
                    <input type="text"
                           id="otpInput"
                           class="form-control p-3"
                           placeholder="Enter OTP">
                </div>

                <div class="d-flex gap-3">
                    <button type="button" class="btn px-4 bridge-accent" id="verifyOtpBtn">
                        Verify
                    </button>
                    <a asp-action="TeacheRegrister"
                       asp-controller="Home"
                       class="btn px-4 bridge-accent-outline">
                        Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const verifyOtpBtn = document.getElementById("verifyOtpBtn");
    const otpInput = document.getElementById("otpInput");

    verifyOtpBtn.addEventListener("click", async function () {
        if (!otpInput.value.trim()) {
            alert("Please enter the OTP code first.");
            return;
        }

        verifyOtpBtn.disabled = true;

        try {
            const response = await fetch(`${backendBaseUrl}/auth/verify-email`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    token: otpInput.value.trim()
                })
            });

            const data = await response.json().catch(() => null);

            if (!response.ok) {
                const message = Array.isArray(data?.message)
                    ? data.message.join(", ")
                    : data?.message;
                throw new Error(message || "Unable to verify the OTP.");
            }

            localStorage.setItem("teacherOtpVerified", "true");
            window.location.href = '@Url.Action("SetupStudents", "Home")';
        } catch (error) {
            alert(error.message || "Unable to verify the OTP.");
        } finally {
            verifyOtpBtn.disabled = false;
        }
    });
</script>
