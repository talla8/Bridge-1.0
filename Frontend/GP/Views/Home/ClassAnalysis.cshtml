@{
    ViewData["Title"] = "Class Analysis";
}

<style>
    .class-analysis-page {
        padding: 1.5rem 0 3rem;
    }

    .class-analysis-title {
        margin: 0;
        color: #0F1920;
        font-size: clamp(2.3rem, 4vw, 3.5rem);
        font-weight: 800;
    }

    .class-analysis-subtitle {
        margin: 0.45rem 0 0;
        color: #74AED8;
        font-size: 1.1rem;
    }

    .class-analysis-card {
        height: 100%;
        padding: 1.2rem 1.25rem;
        border: 1px solid rgba(23,55,77, 0.12);
        border-radius: 1.2rem;
        background: #fff;
        box-shadow: 0 12px 28px rgba(23,55,77, 0.08);
    }

    .class-analysis-card-label {
        color: #555b68;
        font-size: 0.95rem;
    }

    .class-analysis-card-value {
        margin-top: 0.7rem;
        color: #09090f;
        font-size: 3rem;
        font-weight: 800;
        line-height: 1;
    }

    .class-analysis-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-top: 1.15rem;
        padding: 0.75rem 1.35rem;
        border-radius: 999px;
        background: #efedff;
        color: #B1DEFF;
        font-weight: 700;
    }

    .class-analysis-pill-warning {
        background: #fff7da;
        color: #F5CE42;
    }

    .class-analysis-top-skills {
        display: grid;
        gap: 0.15rem;
        margin-top: 0.75rem;
        color: #12131a;
        font-size: 0.95rem;
        font-weight: 800;
    }

    .class-analysis-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(21rem, 1fr);
        gap: 1.75rem;
        margin-top: 2rem;
    }

    .class-analysis-table-card,
    .class-analysis-insight-card {
        padding: 1.45rem;
        border: 1px solid rgba(23,55,77, 0.12);
        border-radius: 1.4rem;
        background: #fff;
        box-shadow: 0 12px 28px rgba(23,55,77, 0.08);
    }

    .class-analysis-table-head,
    .class-analysis-table-row {
        display: grid;
        grid-template-columns: minmax(10rem, 1.2fr) minmax(6rem, 0.7fr) minmax(11rem, 1.4fr) minmax(6rem, 0.7fr);
        gap: 0.75rem;
        align-items: center;
    }

    .class-analysis-table-head {
        padding: 0 1rem 0.8rem;
        color: #232530;
        font-size: 0.95rem;
    }

    .class-analysis-table-row {
        margin-top: 0.85rem;
        padding: 1rem;
        border: 1px solid rgba(23,55,77, 0.12);
        border-radius: 1rem;
        background: #fff;
    }

    .class-analysis-skill-name {
        color: #14151d;
        font-size: 0.95rem;
        font-weight: 700;
    }

    .class-analysis-progress {
        width: 100%;
        height: 0.5rem;
        border-radius: 999px;
        background: #f0edf7;
        overflow: hidden;
    }

    .class-analysis-progress-wrap {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .class-analysis-progress span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: #c8c5ff;
    }

    .class-analysis-progress-value {
        min-width: 3rem;
        color: #232530;
        font-size: 0.92rem;
        font-weight: 700;
        text-align: end;
    }

    .class-analysis-priority {
        color: #232530;
        font-weight: 700;
    }

    .class-analysis-insight-top {
        display: flex;
        gap: 1rem;
        align-items: flex-start;
    }

    .class-analysis-insight-icon {
        font-size: 3.4rem;
        line-height: 1;
    }

    .class-analysis-insight-title {
        margin: 0;
        color: #09090f;
        font-size: 3rem;
        font-weight: 800;
        line-height: 1;
    }

    .class-analysis-insight-copy {
        margin: 0.9rem 0 0;
        color: #4e5563;
        font-size: 1rem;
        line-height: 1.55;
    }

    .class-analysis-insight-bar {
        width: 100%;
        height: 0.75rem;
        margin-top: 2rem;
        border-radius: 999px;
        background: #f1edf7;
        overflow: hidden;
    }

    .class-analysis-insight-bar span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: #c8c5ff;
    }

    .class-analysis-empty {
        margin-top: 1rem;
        color: #6b7280;
    }

    .class-analysis-action-card {
        margin-top: 1.75rem;
        padding: 1.45rem;
        border: 1px solid rgba(23,55,77, 0.12);
        border-radius: 1.4rem;
        background: #fff;
        box-shadow: 0 12px 28px rgba(23,55,77, 0.08);
    }

    .class-analysis-action-kicker {
        color: #74AED8;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .class-analysis-action-title {
        margin: 0.55rem 0 0;
        color: #111E27;
        font-size: 1.7rem;
        font-weight: 800;
    }

    .class-analysis-action-copy {
        margin: 0.85rem 0 0;
        color: #4b5563;
        font-size: 1rem;
        line-height: 1.6;
        max-width: 60rem;
    }

    .class-analysis-action-meta {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1rem;
    }

    .class-analysis-action-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        border-radius: 999px;
        padding: 0.55rem 0.9rem;
        background: #f5f3ff;
        color: #509ED6;
        font-size: 0.88rem;
        font-weight: 700;
    }

    .class-analysis-action-actions {
        display: flex;
        gap: 0.85rem;
        flex-wrap: wrap;
        margin-top: 1.2rem;
    }

    .class-analysis-action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
        border-radius: 0.95rem;
        padding: 0.9rem 1.15rem;
        font-size: 0.95rem;
        font-weight: 700;
        text-decoration: none;
        cursor: pointer;
    }

    .class-analysis-action-btn-primary {
        background: linear-gradient(135deg, #82CBFF, #6DC2FF);
        color: #fff;
    }

    .class-analysis-action-btn-secondary {
        border: 1px solid #dbe3f0;
        background: #fff;
        color: #374151;
    }

    @@media (max-width: 1199.98px) {
        .class-analysis-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 767.98px) {
        .class-analysis-table-head,
        .class-analysis-table-row {
            grid-template-columns: 1fr;
        }

        .class-analysis-table-head {
            display: none;
        }
    }
</style>

<div class="teacher-shell">
    <partial name="_TeacherSidebar" />
    <div class="teacher-shell-content">
        <div class="container class-analysis-page">
            <div>
                <h1 class="class-analysis-title">Class Analysis</h1>
                <p class="class-analysis-subtitle">Summary of Class Performance</p>
            </div>

            <div class="row g-4 mt-3">
                <div class="col-12 col-md-6 col-xl-3">
                    <div class="class-analysis-card">
                        <div class="class-analysis-card-label">Class Average</div>
                        <div class="class-analysis-card-value" id="classAverageValue">0%</div>
                        <div class="class-analysis-pill">Needs Focus</div>
                    </div>
                </div>

                <div class="col-12 col-md-6 col-xl-3">
                    <div class="class-analysis-card">
                        <div class="class-analysis-card-label">Students Needing Support</div>
                        <div class="class-analysis-card-value" id="needSupportValue">0</div>
                        <div class="class-analysis-pill class-analysis-pill-warning" id="needSupportPct">0% Of Class</div>
                    </div>
                </div>

                <div class="col-12 col-md-6 col-xl-3">
                    <div class="class-analysis-card">
                        <div class="class-analysis-card-label">Top 3 Skills:</div>
                        <div class="class-analysis-top-skills" id="topSkillsList"></div>
                        <div class="class-analysis-pill class-analysis-pill-warning">Need more Focus!</div>
                    </div>
                </div>
            </div>

            <section class="class-analysis-action-card">
                <div class="class-analysis-action-kicker">Recommended Next Step</div>
                <h2 class="class-analysis-action-title" id="actionRecommendationTitle">No immediate action</h2>
                <p class="class-analysis-action-copy" id="actionRecommendationReason">
                    The class recommendation will appear here once the backend analysis is loaded.
                </p>
                <div class="class-analysis-action-meta">
                    <div class="class-analysis-action-chip" id="actionRecommendationSkill">Focus skill: -</div>
                    <div class="class-analysis-action-chip" id="actionRecommendationScope">Scope: -</div>
                    <div class="class-analysis-action-chip" id="actionRecommendationRecentQuiz">Recent quiz: none</div>
                </div>
                <div class="class-analysis-action-actions">
                    <a id="actionRecommendationPrimary" class="class-analysis-action-btn class-analysis-action-btn-primary" href="@Url.Action("CreateQuiz", "Home")">Open action</a>
                    <a id="actionRecommendationSecondary" class="class-analysis-action-btn class-analysis-action-btn-secondary" href="@Url.Action("WeakStudents", "Home")">Review weak students</a>
                </div>
            </section>

            <div class="class-analysis-grid">
                <section class="class-analysis-table-card">
                    <div class="class-analysis-table-head">
                        <div>Skill</div>
                        <div>Below AVG</div>
                        <div>Class AVG</div>
                        <div>Priority</div>
                    </div>
                    <div id="classAnalysisRows"></div>
                    <p class="class-analysis-empty d-none" id="classAnalysisEmpty">No class skill data available yet.</p>
                </section>

                <section class="class-analysis-insight-card">
                    <div class="class-analysis-insight-top">
                        <div class="class-analysis-insight-icon">💡</div>
                        <div>
                            <h2 class="class-analysis-insight-title">Insights</h2>
                            <p class="class-analysis-insight-copy" id="insightText">
                                No class insight is available yet.
                            </p>
                        </div>
                    </div>
                    <div class="class-analysis-insight-bar">
                        <span id="insightBar" style="width:0%"></span>
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const token = sessionStorage.getItem("bridgeAccessToken");

    const classAverageValue = document.getElementById("classAverageValue");
    const needSupportValue = document.getElementById("needSupportValue");
    const needSupportPct = document.getElementById("needSupportPct");
    const topSkillsList = document.getElementById("topSkillsList");
    const classAnalysisRows = document.getElementById("classAnalysisRows");
    const classAnalysisEmpty = document.getElementById("classAnalysisEmpty");
    const insightText = document.getElementById("insightText");
    const insightBar = document.getElementById("insightBar");
    const actionRecommendationTitle = document.getElementById("actionRecommendationTitle");
    const actionRecommendationReason = document.getElementById("actionRecommendationReason");
    const actionRecommendationSkill = document.getElementById("actionRecommendationSkill");
    const actionRecommendationScope = document.getElementById("actionRecommendationScope");
    const actionRecommendationRecentQuiz = document.getElementById("actionRecommendationRecentQuiz");
    const actionRecommendationPrimary = document.getElementById("actionRecommendationPrimary");
    const actionRecommendationSecondary = document.getElementById("actionRecommendationSecondary");
    const selectedSubjectId = localStorage.getItem("teacherSelectedSubject") || "2";

    const skillNameMap = {
        skill_counting: "Counting Skills",
        skill_number_manipulation: "Number Manipulation",
        skill_problem_solving: "Problem Solving",
        skill_vocal: "Vocal Awareness",
        skill_sounds_of_letters: "Sounds of Letters",
        skill_writing: "Writing"
    };

    function skillLabel(skillId) {
        return skillNameMap[skillId] ?? skillId;
    }

    function priorityLabel(priority) {
        if (!priority) return "Low";
        return String(priority).charAt(0) + String(priority).slice(1).toLowerCase();
    }

    function authorizedHeaders() {
        return token ? { Authorization: `Bearer ${token}` } : {};
    }

    function roundPercent(value) {
        return Math.round(Number(value) || 0);
    }

    function buildInsightCopy(weakestSkill) {
        if (!weakestSkill) {
            return "No class insight is available yet.";
        }

        const weakestName = skillLabel(weakestSkill.skillId);
        const average = roundPercent(weakestSkill.avg);
        return `The lowest-performing skill is "${weakestName}" (${average}%). Consider allocating more practice activities and using the support plan for students below average.`;
    }

    function buildCreateQuizUrl(skill, targetType) {
        const targetUrl = new URL('@Url.Action("CreateQuiz", "Home")', window.location.origin);
        if (skill) {
            targetUrl.searchParams.set("skill", skill);
        }
        if (targetType) {
            targetUrl.searchParams.set("targetType", targetType);
        }
        return targetUrl.toString();
    }

    function applyActionRecommendation(recommendation) {
        const focusSkill = recommendation?.focusSkillName || "-";
        const scopeLabel = recommendation?.targetType === "WHOLE_CLASS"
            ? "Whole class"
            : recommendation?.targetType === "WEAK_STUDENTS"
                ? "Weak students"
                : recommendation?.recommendationType === "GUIDED_PRACTICE"
                    ? "Guided practice"
                    : "-";
        const recentQuizLabel = recommendation?.recentQuizAssigned
            ? `Recent quiz: ${recommendation.daysSinceLastQuizForSkill ?? 0} day(s) ago`
            : "Recent quiz: none";

        actionRecommendationTitle.textContent = recommendation?.actionLabel || "No immediate action";
        actionRecommendationReason.textContent = recommendation?.reason || "No recommendation is available right now.";
        actionRecommendationSkill.textContent = `Focus skill: ${focusSkill}`;
        actionRecommendationScope.textContent = `Scope: ${scopeLabel}`;
        actionRecommendationRecentQuiz.textContent = recentQuizLabel;

        if (recommendation?.recommendationType === "CLASS_QUIZ" || recommendation?.recommendationType === "SUPPORT_GROUP_QUIZ") {
            actionRecommendationPrimary.textContent = recommendation.actionLabel;
            actionRecommendationPrimary.href = buildCreateQuizUrl(recommendation.focusSkillName, recommendation.targetType);
            actionRecommendationSecondary.textContent = "Review weak students";
            actionRecommendationSecondary.href = '@Url.Action("WeakStudents", "Home")';
            return;
        }

        if (recommendation?.recommendationType === "GUIDED_PRACTICE") {
            actionRecommendationPrimary.textContent = "Review weak students";
            actionRecommendationPrimary.href = '@Url.Action("WeakStudents", "Home")';
            actionRecommendationSecondary.textContent = "Create support-group quiz";
            actionRecommendationSecondary.href = buildCreateQuizUrl(recommendation.focusSkillName, "WEAK_STUDENTS");
            return;
        }

        actionRecommendationPrimary.textContent = "Review weak students";
        actionRecommendationPrimary.href = '@Url.Action("WeakStudents", "Home")';
        actionRecommendationSecondary.textContent = "Create class quiz";
        actionRecommendationSecondary.href = buildCreateQuizUrl(recommendation?.focusSkillName, "WHOLE_CLASS");
    }

    async function loadClassAnalysis() {
        if (!token) {
            insightText.textContent = "Sign in again to load class analysis.";
            return;
        }

        try {
            const [classAverageResponse, weakStudentsResponse, classSkillsResponse, studentsResponse, recommendationResponse] = await Promise.all([
                fetch(`${backendBaseUrl}/statistics/class?subjectId=${encodeURIComponent(selectedSubjectId)}`, { headers: authorizedHeaders() }),
                fetch(`${backendBaseUrl}/statistics/weak-students?subjectId=${encodeURIComponent(selectedSubjectId)}`, { headers: authorizedHeaders() }),
                fetch(`${backendBaseUrl}/statistics/class/skills?subjectId=${encodeURIComponent(selectedSubjectId)}`, { headers: authorizedHeaders() }),
                fetch(`${backendBaseUrl}/students/myStudents`, { headers: authorizedHeaders() }),
                fetch(`${backendBaseUrl}/statistics/class/recommendation?subjectId=${encodeURIComponent(selectedSubjectId)}`, { headers: authorizedHeaders() })
            ]);

            const classAverage = await classAverageResponse.json().catch(() => 0);
            const weakStudents = await weakStudentsResponse.json().catch(() => []);
            const classSkills = await classSkillsResponse.json().catch(() => []);
            const students = await studentsResponse.json().catch(() => []);
            const recommendation = await recommendationResponse.json().catch(() => null);

            if (!classAverageResponse.ok || !weakStudentsResponse.ok || !classSkillsResponse.ok || !studentsResponse.ok || !recommendationResponse.ok) {
                throw new Error("Unable to load class analysis.");
            }

            const totalStudents = Array.isArray(students) ? students.length : 0;
            const weakStudentSummaries = Array.isArray(weakStudents) ? weakStudents : [];
            const skillRows = Array.isArray(classSkills) ? classSkills : [];

            classAverageValue.textContent = `${roundPercent(classAverage)}%`;
            needSupportValue.textContent = String(weakStudentSummaries.length);
            needSupportPct.textContent = `${totalStudents ? roundPercent((weakStudentSummaries.length / totalStudents) * 100) : 0}% Of Class`;
            applyActionRecommendation(recommendation);

            topSkillsList.innerHTML = "";
            skillRows.slice(0, 3).forEach((row) => {
                const skill = document.createElement("div");
                skill.textContent = skillLabel(row.skillId);
                topSkillsList.appendChild(skill);
            });

            if (!skillRows.length) {
                classAnalysisRows.innerHTML = "";
                classAnalysisEmpty.classList.remove("d-none");
                classAnalysisEmpty.textContent = "No class skill data is available for this teacher yet.";
                insightText.textContent = "No class insight is available until class skill data exists for this teacher.";
                insightBar.style.width = "0%";
                return;
            }

            classAnalysisEmpty.classList.add("d-none");

            classAnalysisRows.innerHTML = skillRows.map((row) => {
                const belowAverageCount = weakStudentSummaries.filter((student) =>
                    Array.isArray(student.weakSkills) && student.weakSkills.some((skill) => skill.skillId === row.skillId)
                ).length;
                const belowAveragePct = totalStudents ? roundPercent((belowAverageCount / totalStudents) * 100) : 0;
                const classAvg = roundPercent(row.avg);

                return `
                    <div class="class-analysis-table-row">
                        <div class="class-analysis-skill-name">${skillLabel(row.skillId)}</div>
                        <div>${belowAveragePct}%</div>
                        <div>
                            <div class="class-analysis-progress-wrap">
                                <div class="class-analysis-progress">
                                    <span style="width:${classAvg}%" title="${classAvg}%"></span>
                                </div>
                                <span class="class-analysis-progress-value">${classAvg}%</span>
                            </div>
                        </div>
                        <div class="class-analysis-priority">${priorityLabel(row.priority)}</div>
                    </div>
                `;
            }).join("");

            const weakestSkill = skillRows[0];
            insightText.textContent = buildInsightCopy(weakestSkill);
            insightBar.style.width = `${Math.max(0, Math.min(100, roundPercent(weakestSkill.avg)))}%`;
        } catch (error) {
            classAnalysisRows.innerHTML = "";
            classAnalysisEmpty.classList.remove("d-none");
            classAnalysisEmpty.textContent = "Unable to load class skill data right now.";
            insightText.textContent = error.message || "Unable to load class analysis.";
            insightBar.style.width = "0%";
        }
    }

    loadClassAnalysis();
</script>
