@{
    ViewData["Title"] = "Profile";
}

<style>
    .profile-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 28px;
    }

    .profile-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        box-shadow: 0 10px 28px rgba(17,30,39,.06);
    }

    .profile-hero {
        display: flex;
        gap: 22px;
        align-items: center;
        flex-wrap: wrap;
        padding: 26px;
        background: #e8f4fd;
    }

    .profile-avatar {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        background: #c9c6ff;
        color: #4A8AB7;
        font-size: 34px;
        font-weight: 800;
    }

    .profile-name {
        margin: 0;
        font-size: 2rem;
        font-weight: 800;
        color: #111E27;
    }

    .profile-subtitle {
        margin: 6px 0 0;
        color: #6b7280;
        font-size: 15px;
    }

    .profile-tags {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 14px;
    }

    .profile-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 12px;
        border-radius: 999px;
        background: #fff;
        border: 1px solid #dbe3f0;
        color: #4b5563;
        font-size: 13px;
        font-weight: 700;
    }

    .profile-tag-verified {
        background: #e7f7f0;
        border-color: #9fe1cb;
        color: #0f6e56;
    }

    .profile-tag-unverified {
        background: #fff7db;
        border-color: #F3D770;
        color: #8A6C00;
    }

    .profile-verification-banner {
        margin-top: 18px;
        padding: 16px 18px;
        border: 1px solid #F3D770;
        border-radius: 16px;
        background: #fff9e8;
        color: #7A6000;
    }

    .profile-verification-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 12px;
    }

    .profile-section {
        margin-top: 28px;
    }

    .profile-section-label {
        margin: 0 0 12px;
        color: #6b7280;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .profile-grid {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 14px;
    }

    .profile-field {
        grid-column: span 6;
        padding: 18px 20px;
    }

    .profile-field-sm {
        grid-column: span 3;
    }

    .profile-field-head {
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 8px;
    }

    .profile-field-label {
        color: #6b7280;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .profile-field-value {
        color: #111E27;
        font-size: 16px;
        font-weight: 700;
        overflow-wrap: anywhere;
    }

    .profile-field-value-muted {
        color: #9ca3af;
    }

    .profile-field-input {
        width: 100%;
        min-height: 46px;
        padding: 0 12px;
        border: 1px solid #d1d5db;
        border-radius: 12px;
        background: #fff;
        font-size: 15px;
    }

    .profile-field-edit {
        border: none;
        background: transparent;
        color: #6b7280;
    }

    .profile-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 18px;
    }

    .profile-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 18px;
        border-radius: 999px;
        border: 1px solid #d1d5db;
        background: #fff;
        color: #111E27;
        font-weight: 700;
    }

    .profile-btn-primary {
        border-color: transparent;
        background: #0DA4F0;
        color: #fff;
    }

    .profile-status {
        font-size: 14px;
        font-weight: 700;
    }

    .profile-status-success {
        color: #0f6e56;
    }

    .profile-status-error {
        color: #b91c1c;
    }

    .profile-password-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    @@media (max-width: 992px) {
        .profile-field,
        .profile-field-sm {
            grid-column: span 12;
        }

        .profile-password-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="teacher-shell">
    <partial name="_TeacherSidebar" />
    <div class="teacher-shell-content">
        <div class="profile-page">
            <div class="profile-card profile-hero">
                <div id="profileAvatar" class="profile-avatar">--</div>
                <div style="flex:1; min-width: 0;">
                    <h1 id="profileHeaderName" class="profile-name">Profile</h1>
                    <div id="profileHeaderSubtitle" class="profile-subtitle">Loading profile...</div>
                    <div class="profile-tags">
                        <span class="profile-tag"><i class="bi bi-book"></i> <span id="profileGradeTag">-</span></span>
                        <span class="profile-tag"><i class="bi bi-translate"></i> <span id="profileSubjectTag">-</span></span>
                        <span class="profile-tag"><i class="bi bi-people"></i> <span id="profileStudentCountTag">0 Students</span></span>
                        <span id="profileVerifiedTag" class="profile-tag profile-tag-verified"><i class="bi bi-patch-check-fill"></i> Verified</span>
                        <span id="profileUnverifiedTag" class="profile-tag profile-tag-unverified d-none"><i class="bi bi-exclamation-circle"></i> Not verified</span>
                    </div>
                    <div id="profileVerificationBanner" class="profile-verification-banner d-none">
                        <div>Your email is still not verified.</div>
                        <div class="profile-verification-actions">
                            <a asp-controller="Home" asp-action="Verification" id="profileVerifyNowButton" class="profile-btn profile-btn-primary">Verify now</a>
                            <button type="button" id="profileResendVerificationButton" class="profile-btn">Resend code</button>
                        </div>
                        <div id="profileVerificationStatus" class="profile-status mt-2 d-none"></div>
                    </div>
                </div>
            </div>

            <div class="profile-section">
                <h2 class="profile-section-label">Personal Information</h2>
                <div class="profile-grid">
                    <div class="profile-card profile-field">
                        <div class="profile-field-head">
                            <div class="profile-field-label">Full Name</div>
                            <button type="button" class="profile-field-edit" data-edit-field="fullName"><i class="bi bi-pencil"></i></button>
                        </div>
                        <div id="fullNameDisplay" class="profile-field-value">-</div>
                        <input id="fullNameInput" class="profile-field-input d-none" type="text" />
                    </div>

                    <div class="profile-card profile-field">
                        <div class="profile-field-head">
                            <div class="profile-field-label">Email Address</div>
                            <button type="button" class="profile-field-edit" data-edit-field="email"><i class="bi bi-pencil"></i></button>
                        </div>
                        <div id="emailDisplay" class="profile-field-value">-</div>
                        <input id="emailInput" class="profile-field-input d-none" type="email" />
                    </div>

                    <div class="profile-card profile-field">
                        <div class="profile-field-head">
                            <div class="profile-field-label">Phone Number</div>
                            <button type="button" class="profile-field-edit" data-edit-field="phoneNumber"><i class="bi bi-pencil"></i></button>
                        </div>
                        <div id="phoneNumberDisplay" class="profile-field-value profile-field-value-muted">Not set</div>
                        <input id="phoneNumberInput" class="profile-field-input d-none" type="tel" />
                    </div>

                    <div class="profile-card profile-field">
                        <div class="profile-field-head">
                            <div class="profile-field-label">School</div>
                        </div>
                        <div id="schoolDisplay" class="profile-field-value profile-field-value-muted">-</div>
                    </div>

                    <div class="profile-card profile-field profile-field-sm">
                        <div class="profile-field-head">
                            <div class="profile-field-label">Grade</div>
                        </div>
                        <div id="gradeDisplay" class="profile-field-value profile-field-value-muted">-</div>
                    </div>

                    <div class="profile-card profile-field profile-field-sm">
                        <div class="profile-field-head">
                            <div class="profile-field-label">Section</div>
                        </div>
                        <div id="sectionDisplay" class="profile-field-value profile-field-value-muted">-</div>
                    </div>

                    <div class="profile-card profile-field profile-field-sm">
                        <div class="profile-field-head">
                            <div class="profile-field-label">Subject</div>
                        </div>
                        <div id="subjectDisplay" class="profile-field-value profile-field-value-muted">-</div>
                    </div>

                    <div class="profile-card profile-field profile-field-sm">
                        <div class="profile-field-head">
                            <div class="profile-field-label">Students</div>
                        </div>
                        <div id="studentCountDisplay" class="profile-field-value profile-field-value-muted">0</div>
                    </div>
                </div>

                <div class="profile-actions">
                    <button id="saveProfileButton" type="button" class="profile-btn profile-btn-primary">Save Changes</button>
                    <span id="saveProfileStatus" class="profile-status d-none"></span>
                </div>
            </div>

            <div class="profile-section">
                <h2 class="profile-section-label">Change Password</h2>
                <div class="profile-password-grid">
                    <div>
                        <label class="profile-field-label d-block mb-2">Current Password</label>
                        <input id="currentPasswordInput" class="profile-field-input" type="password" />
                    </div>
                    <div>
                        <label class="profile-field-label d-block mb-2">New Password</label>
                        <input id="newPasswordInput" class="profile-field-input" type="password" />
                    </div>
                    <div>
                        <label class="profile-field-label d-block mb-2">Confirm New Password</label>
                        <input id="confirmPasswordInput" class="profile-field-input" type="password" />
                    </div>
                </div>

                <div class="profile-actions">
                    <button id="changePasswordButton" type="button" class="profile-btn profile-btn-primary">Update Password</button>
                    <span id="changePasswordStatus" class="profile-status d-none"></span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const profileToken = sessionStorage.getItem("bridgeAccessToken");
    const profileRole = sessionStorage.getItem("bridgeUserRole");

    const editableFields = {
        fullName: {
            display: document.getElementById("fullNameDisplay"),
            input: document.getElementById("fullNameInput")
        },
        email: {
            display: document.getElementById("emailDisplay"),
            input: document.getElementById("emailInput")
        },
        phoneNumber: {
            display: document.getElementById("phoneNumberDisplay"),
            input: document.getElementById("phoneNumberInput")
        }
    };

    const profileAvatar = document.getElementById("profileAvatar");
    const profileHeaderName = document.getElementById("profileHeaderName");
    const profileHeaderSubtitle = document.getElementById("profileHeaderSubtitle");
    const profileGradeTag = document.getElementById("profileGradeTag");
    const profileSubjectTag = document.getElementById("profileSubjectTag");
    const profileStudentCountTag = document.getElementById("profileStudentCountTag");
    const profileVerifiedTag = document.getElementById("profileVerifiedTag");
    const profileUnverifiedTag = document.getElementById("profileUnverifiedTag");
    const profileVerificationBanner = document.getElementById("profileVerificationBanner");
    const profileVerifyNowButton = document.getElementById("profileVerifyNowButton");
    const profileResendVerificationButton = document.getElementById("profileResendVerificationButton");
    const profileVerificationStatus = document.getElementById("profileVerificationStatus");
    const schoolDisplay = document.getElementById("schoolDisplay");
    const gradeDisplay = document.getElementById("gradeDisplay");
    const sectionDisplay = document.getElementById("sectionDisplay");
    const subjectDisplay = document.getElementById("subjectDisplay");
    const studentCountDisplay = document.getElementById("studentCountDisplay");
    const saveProfileButton = document.getElementById("saveProfileButton");
    const saveProfileStatus = document.getElementById("saveProfileStatus");
    const changePasswordButton = document.getElementById("changePasswordButton");
    const changePasswordStatus = document.getElementById("changePasswordStatus");
    const currentPasswordInput = document.getElementById("currentPasswordInput");
    const newPasswordInput = document.getElementById("newPasswordInput");
    const confirmPasswordInput = document.getElementById("confirmPasswordInput");

    let profileState = null;

    function authorizedHeaders(includeJson = false) {
        const headers = {
            Authorization: `Bearer ${profileToken}`
        };

        if (includeJson) {
            headers["Content-Type"] = "application/json";
        }

        return headers;
    }

    function showStatus(target, message, isError = false) {
        target.textContent = message;
        target.classList.remove("d-none", "profile-status-success", "profile-status-error");
        target.classList.add(isError ? "profile-status-error" : "profile-status-success");
    }

    function hideStatus(target) {
        target.classList.add("d-none");
        target.textContent = "";
    }

    function getInitials(name) {
        const parts = String(name || "").trim().split(/\s+/).filter(Boolean);
        return parts.slice(0, 2).map((part) => part[0]?.toUpperCase() || "").join("") || "--";
    }

    function setEditableField(fieldName, value, emptyLabel = "Not set") {
        const field = editableFields[fieldName];
        const normalizedValue = value ? String(value) : "";
        field.display.textContent = normalizedValue || emptyLabel;
        field.display.classList.toggle("profile-field-value-muted", !normalizedValue);
        field.input.value = normalizedValue;
        field.input.classList.add("d-none");
        field.display.classList.remove("d-none");
    }

    function toggleEdit(fieldName) {
        const field = editableFields[fieldName];
        if (!field) {
            return;
        }

        const isEditing = field.input.classList.contains("d-none");
        if (isEditing) {
            field.display.classList.add("d-none");
            field.input.classList.remove("d-none");
            field.input.focus();
            field.input.select();
            return;
        }

        field.display.textContent = field.input.value.trim() || (fieldName === "phoneNumber" ? "Not set" : "-");
        field.display.classList.toggle("profile-field-value-muted", !field.input.value.trim());
        field.input.classList.add("d-none");
        field.display.classList.remove("d-none");
    }

    function renderProfile(profile) {
        profileState = profile;
        const grade = profile.grade || "-";
        const section = profile.section || "-";
        const subject = profile.subject || "-";
        const studentCount = Number(profile.studentCount || 0);
        const verified = Boolean(profile.isVerified);
        sessionStorage.setItem("bridgeUserVerified", verified ? "true" : "false");

        profileAvatar.textContent = getInitials(profile.fullName);
        profileHeaderName.textContent = profile.fullName || "Profile";
        profileHeaderSubtitle.textContent = `${profile.roleId || "User"} · ${grade}${section !== "-" ? `, Section "${section}"` : ""}`;
        profileGradeTag.textContent = grade;
        profileSubjectTag.textContent = subject;
        profileStudentCountTag.textContent = `${studentCount} Students`;
        profileVerifiedTag.classList.toggle("d-none", !verified);
        profileUnverifiedTag.classList.toggle("d-none", verified);
        profileVerificationBanner.classList.toggle("d-none", verified);
        schoolDisplay.textContent = profile.school || "-";
        schoolDisplay.classList.toggle("profile-field-value-muted", !profile.school);
        gradeDisplay.textContent = grade;
        gradeDisplay.classList.toggle("profile-field-value-muted", grade === "-");
        sectionDisplay.textContent = section;
        sectionDisplay.classList.toggle("profile-field-value-muted", section === "-");
        subjectDisplay.textContent = subject;
        subjectDisplay.classList.toggle("profile-field-value-muted", subject === "-");
        studentCountDisplay.textContent = String(studentCount);
        studentCountDisplay.classList.toggle("profile-field-value-muted", studentCount === 0);

        setEditableField("fullName", profile.fullName, "-");
        setEditableField("email", profile.email, "-");
        setEditableField("phoneNumber", profile.phoneNumber, "Not set");
    }

    async function loadProfile() {
        if (!profileToken) {
            window.location.replace('@Url.Action("Login", "Home")');
            return;
        }

        if (profileRole && profileRole !== "Teacher") {
            window.location.replace('@Url.Action("ParentDashboard", "Home")');
            return;
        }

        const response = await fetch(`${backendBaseUrl}/auth/profile`, {
            headers: authorizedHeaders()
        });
        const data = await response.json().catch(() => null);

        if (!response.ok || !data) {
            throw new Error(data?.message || "Unable to load profile.");
        }

        renderProfile(data);
    }

    function showVerificationStatus(message, isError = false) {
        profileVerificationStatus.textContent = message;
        profileVerificationStatus.classList.remove("d-none");
        profileVerificationStatus.classList.toggle("profile-status-error", isError);
        profileVerificationStatus.classList.toggle("profile-status-success", !isError);
    }

    async function saveProfile() {
        hideStatus(saveProfileStatus);
        const payload = {
            fullName: editableFields.fullName.input.value.trim(),
            email: editableFields.email.input.value.trim(),
            phoneNumber: editableFields.phoneNumber.input.value.trim()
        };

        if (!payload.fullName || !payload.email) {
            showStatus(saveProfileStatus, "Full name and email are required.", true);
            return;
        }

        saveProfileButton.disabled = true;
        saveProfileButton.textContent = "Saving...";

        try {
            const response = await fetch(`${backendBaseUrl}/auth/profile`, {
                method: "PATCH",
                headers: authorizedHeaders(true),
                body: JSON.stringify(payload)
            });
            const data = await response.json().catch(() => null);

            if (!response.ok || !data) {
                const message = Array.isArray(data?.message) ? data.message.join(", ") : data?.message;
                throw new Error(message || "Unable to save profile.");
            }

            sessionStorage.setItem("bridgeUserName", data.fullName || payload.fullName);
            renderProfile(data);
            showStatus(saveProfileStatus, "Profile saved successfully.");
        } catch (error) {
            showStatus(saveProfileStatus, error.message || "Unable to save profile.", true);
        } finally {
            saveProfileButton.disabled = false;
            saveProfileButton.textContent = "Save Changes";
        }
    }

    async function changePassword() {
        hideStatus(changePasswordStatus);
        const currentPassword = currentPasswordInput.value;
        const newPassword = newPasswordInput.value;
        const confirmPassword = confirmPasswordInput.value;

        if (!currentPassword || !newPassword || !confirmPassword) {
            showStatus(changePasswordStatus, "Fill in all password fields.", true);
            return;
        }

        if (newPassword !== confirmPassword) {
            showStatus(changePasswordStatus, "New passwords do not match.", true);
            return;
        }

        if (newPassword.length < 8) {
            showStatus(changePasswordStatus, "New password must be at least 8 characters.", true);
            return;
        }

        changePasswordButton.disabled = true;
        changePasswordButton.textContent = "Updating...";

        try {
            const response = await fetch(`${backendBaseUrl}/auth/change-password`, {
                method: "POST",
                headers: authorizedHeaders(true),
                body: JSON.stringify({
                    currentPassword,
                    newPassword
                })
            });
            const data = await response.json().catch(() => null);

            if (!response.ok) {
                const message = Array.isArray(data?.message) ? data.message.join(", ") : data?.message;
                throw new Error(message || "Unable to update password.");
            }

            currentPasswordInput.value = "";
            newPasswordInput.value = "";
            confirmPasswordInput.value = "";
            showStatus(changePasswordStatus, data?.message || "Password updated successfully.");
        } catch (error) {
            showStatus(changePasswordStatus, error.message || "Unable to update password.", true);
        } finally {
            changePasswordButton.disabled = false;
            changePasswordButton.textContent = "Update Password";
        }
    }

    document.querySelectorAll("[data-edit-field]").forEach((button) => {
        button.addEventListener("click", () => {
            toggleEdit(button.dataset.editField);
        });
    });

    saveProfileButton.addEventListener("click", saveProfile);
    changePasswordButton.addEventListener("click", changePassword);
    profileVerifyNowButton?.addEventListener("click", () => {
        const role = sessionStorage.getItem("bridgeUserRole") || "teacher";
        sessionStorage.setItem("bridgeVerificationRole", String(role).toLowerCase());
    });
    profileResendVerificationButton?.addEventListener("click", async () => {
        hideStatus(profileVerificationStatus);
        profileResendVerificationButton.disabled = true;

        try {
            const response = await fetch(`${backendBaseUrl}/auth/resend-verification`, {
                method: "POST",
                headers: authorizedHeaders()
            });
            const data = await response.json().catch(() => null);

            if (!response.ok) {
                const message = Array.isArray(data?.message) ? data.message.join(", ") : data?.message;
                throw new Error(message || "Unable to resend verification code.");
            }

            showVerificationStatus(data?.message || "Verification code sent.");
        } catch (error) {
            showVerificationStatus(error.message || "Unable to resend verification code.", true);
        } finally {
            profileResendVerificationButton.disabled = false;
        }
    });

    loadProfile().catch((error) => {
        showStatus(saveProfileStatus, error.message || "Unable to load profile.", true);
    });
</script>
