@{
    ViewData["Title"] = "login";
}

<style>
    .auth-password-wrap {
        position: relative;
        display: block;
        width: 100%;
    }

    .auth-password-toggle {
        position: absolute !important;
        top: 50%;
        right: 0.85rem;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        color: #6b7280;
        padding: 0;
        width: 1.5rem;
        height: 1.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
        margin: 0;
        z-index: 3;
    }

    .auth-password-wrap .form-control {
        padding-right: 3rem;
        width: 100%;
    }

    .auth-password-toggle svg {
        width: 1.1rem;
        height: 1.1rem;
        stroke: currentColor;
        fill: none;
        stroke-width: 1.8;
    }

    .auth-password-toggle.is-visible svg {
        opacity: 0.65;
    }
</style>

<div class="container py-5">
    <div class="row align-items-center">
        <div class="col-lg-6">
            <h1 class="fw-bold mb-1">Welcome Back !</h1>
            <p class="text-secondary mb-4">Please login to your account.</p>

            <div id="loginErrorBox" class="alert alert-danger d-none"></div>

            <form id="loginForm" style="height: 17rem;width: 41rem;">
                <div class="ms-3 me-3 pt-3">

                <div class="mb-3">
                    <input type="email"
                           id="emailInput"
                           class="form-control p-3"
                           placeholder="Email Address">
                </div>

                <div class="mb-3 auth-password-wrap">
                    <input type="password"
                           id="passwordInput"
                           class="form-control p-3"
                           placeholder="Password">
                    <button type="button" class="auth-password-toggle" id="loginPasswordToggle" aria-label="Show password" title="Show password">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                    </button>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <a asp-action="ForgotPassword" asp-controller="Home" class="small text-secondary">Forgot Password?</a>
                </div>

                <div class="d-flex gap-3 mb-4">
                    <button type="submit"
                            class="btn px-4 text-white"
                            id="loginBtn"
                            style="background:#c9c6ff">
                        Log in
                    </button>

                    <a class="btn px-4"
                       style="border:1px solid #c9c6ff;color:#c9c6ff"
                       asp-action="SignUp"
                       asp-controller="Home">
                        Sign Up
                    </a>
                </div>
                </div>
                           </form>
        </div>

        <div class="col-lg-6 text-center">
            <img src="~/img/illustration.png" class="img-fluid" style="max-height:420px">
        </div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const loginForm = document.getElementById("loginForm");
    const loginBtn = document.getElementById("loginBtn");
    const loginErrorBox = document.getElementById("loginErrorBox");
    const emailInput = document.getElementById("emailInput");
    const passwordInput = document.getElementById("passwordInput");
    const loginPasswordToggle = document.getElementById("loginPasswordToggle");

    function showError(message) {
        loginErrorBox.textContent = message;
        loginErrorBox.classList.remove("d-none");
    }

    function hideError() {
        loginErrorBox.classList.add("d-none");
    }

    loginPasswordToggle?.addEventListener("click", () => {
        const shouldShow = passwordInput.type === "password";
        passwordInput.type = shouldShow ? "text" : "password";
        loginPasswordToggle.classList.toggle("is-visible", shouldShow);
        loginPasswordToggle.setAttribute("aria-label", shouldShow ? "Hide password" : "Show password");
        loginPasswordToggle.setAttribute("title", shouldShow ? "Hide password" : "Show password");
    });

    function storeUserSession(token, fallbackName) {
        sessionStorage.removeItem("bridgeGeneratedPlan");
        sessionStorage.removeItem("bridgeBaselineReady");
        sessionStorage.removeItem("bridgeTeacherGrade");
        sessionStorage.removeItem("bridgeTeacherSection");
        sessionStorage.setItem("bridgeAccessToken", token);

        try {
            const payloadPart = token.split(".")[1];
            const normalizedPayload = payloadPart.replace(/-/g, "+").replace(/_/g, "/");
            const paddedPayload = normalizedPayload.padEnd(
                normalizedPayload.length + ((4 - normalizedPayload.length % 4) % 4),
                "="
            );
            const decodedPayload = JSON.parse(atob(paddedPayload));
            const displayName = decodedPayload.username || fallbackName || "";
            const roleId = decodedPayload.roleId || "";

            if (displayName) {
                sessionStorage.setItem("bridgeUserName", displayName);
            }

            if (roleId) {
                sessionStorage.setItem("bridgeUserRole", roleId);
            }
        } catch {
            if (fallbackName) {
                sessionStorage.setItem("bridgeUserName", fallbackName);
            }
        }
    }

    loginForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        hideError();

        const email = emailInput.value.trim();
        const password = passwordInput.value;

        if (!email || !password) {
            showError("Please enter your email and password.");
            return;
        }

        loginBtn.disabled = true;

        try {
            const response = await fetch(`${backendBaseUrl}/auth/login`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    email,
                    password
                })
            });

            const data = await response.json().catch(() => null);

            if (!response.ok) {
                const message = Array.isArray(data?.message) ? data.message.join(", ") : data?.message;
                throw new Error(message || "Unable to log in.");
            }

            storeUserSession(data.access_token, email);
            const userRole = sessionStorage.getItem("bridgeUserRole");
            window.location.href = userRole === "Parent"
                ? '@Url.Action("ParentDashboard", "Home")'
                : userRole === "Institution"
                    ? '@Url.Action("InstitutionDashboard", "Home")'
                    : '@Url.Action("Teacher", "Home")';
        } catch (error) {
            showError(error.message || "Unable to connect to the server.");
        } finally {
            loginBtn.disabled = false;
        }
    });
</script>
