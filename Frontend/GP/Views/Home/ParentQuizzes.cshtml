@{
    ViewData["Title"] = "My Quizzes";
}

<style>
    .parent-list-page {
        max-width: 1120px;
        margin: 0 auto;
        padding: 28px;
    }

    .parent-list-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        box-shadow: 0 10px 28px rgba(17,24,39,.06);
        padding: 24px;
    }

    .parent-list-title {
        font-size: 34px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 8px;
    }

    .parent-list-subtitle {
        color: #6b7280;
        margin-bottom: 18px;
    }

    .parent-list-grid {
        display: grid;
        gap: 12px;
    }

    .parent-list-row {
        display: grid;
        grid-template-columns: 1.5fr 1.2fr .9fr .9fr auto;
        gap: 14px;
        align-items: center;
        border: 1px solid #eef2f7;
        border-radius: 18px;
        padding: 16px;
    }

    .parent-list-head {
        background: #f8fafc;
        font-weight: 800;
        color: #374151;
    }

    .parent-list-meta {
        color: #6b7280;
        font-size: 13px;
        margin-top: 4px;
    }

    .parent-list-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 8px 12px;
        font-size: 12px;
        font-weight: 700;
        background: #eef2ff;
        color: #4f46e5;
        width: fit-content;
    }

    .parent-list-btn {
        border: 1px solid #d1d5db;
        border-radius: 999px;
        padding: 9px 14px;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        color: #4f46e5;
        background: #fff;
        white-space: nowrap;
    }

    .parent-list-empty {
        color: #6b7280;
        text-align: center;
        padding: 28px;
    }

    @@media (max-width: 960px) {
        .parent-list-row {
            grid-template-columns: 1fr;
        }

        .parent-list-head {
            display: none;
        }
    }
</style>

<div class="parent-list-page">
    <div class="parent-list-card">
        <div class="parent-list-title">My Quizzes</div>
        <div class="parent-list-subtitle">Assigned quizzes for all linked students.</div>

        <div id="parentQuizzesList" class="parent-list-grid"></div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const token = sessionStorage.getItem("bridgeAccessToken");
    const role = sessionStorage.getItem("bridgeUserRole");
    const parentQuizzesList = document.getElementById("parentQuizzesList");

    function renderParentQuizList(items) {
        if (!items.length) {
            parentQuizzesList.innerHTML = `<div class="parent-list-empty">No quizzes assigned yet.</div>`;
            return;
        }

        parentQuizzesList.innerHTML = `
            <div class="parent-list-row parent-list-head">
                <div>Quiz</div>
                <div>Student</div>
                <div>Due</div>
                <div>Status</div>
                <div>Action</div>
            </div>
            ${items.map((item) => `
                <div class="parent-list-row">
                    <div>
                        <div><strong>${item.title}</strong></div>
                    </div>
                    <div>${item.studentName}</div>
                    <div>${item.dueLabel || "-"}</div>
                    <div><span class="parent-list-badge">${item.isSubmitted ? (item.submissionStatus || "Submitted") : "Assigned"}</span></div>
                    <div>
                        ${item.isSubmitted
                            ? `<a class="parent-list-btn" href="@Url.Action("ParentQuizResults", "Home")">View result</a>`
                            : `<a class="parent-list-btn" href="@Url.Action("TakeQuiz", "Home")?studentId=${encodeURIComponent(item.studentId)}&assignmentId=${encodeURIComponent(item.assignmentId)}">Take quiz</a>`}
                    </div>
                </div>
            `).join("")}
        `;
    }

    async function loadParentQuizzes() {
        if (!token) {
            window.location.replace('@Url.Action("Login", "Home")');
            return;
        }

        if (role && role !== "Parent") {
            window.location.replace('@Url.Action("Teacher", "Home")');
            return;
        }

        const response = await fetch(`${backendBaseUrl}/parents/me/quizzes`, {
            headers: {
                Authorization: `Bearer ${token}`
            }
        });
        const data = await response.json().catch(() => []);

        if (!response.ok) {
            throw new Error(data?.message || "Unable to load quizzes.");
        }

        renderParentQuizList(Array.isArray(data) ? data : []);
    }

    loadParentQuizzes().catch((error) => {
        parentQuizzesList.innerHTML = `<div class="parent-list-empty">${error.message || "Unable to load quizzes."}</div>`;
    });
</script>
