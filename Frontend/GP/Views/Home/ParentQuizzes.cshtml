@{
    ViewData["Title"] = "My Quizzes";
}

<style>
    .parent-list-page {
        max-width: 1120px;
        margin: 0 auto;
        padding: 28px;
    }

    .parent-list-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        box-shadow: 0 10px 28px rgba(17,30,39,.06);
        padding: 24px;
    }

    .parent-list-title {
        font-size: 34px;
        font-weight: 800;
        color: #111E27;
        margin-bottom: 8px;
    }

    .parent-list-subtitle {
        color: #6b7280;
        margin-bottom: 18px;
    }

    .parent-list-toolbar {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .parent-list-filter,
    .parent-list-sort {
        min-width: 220px;
        border: 1px solid #dbe3f0;
        border-radius: 14px;
        padding: 10px 12px;
        font-size: 14px;
        background: #fff;
        color: #374151;
    }

    .parent-list-grid {
        display: grid;
        gap: 12px;
    }

    .parent-list-row {
        display: grid;
        grid-template-columns: 1.3fr .9fr 1.1fr .9fr .9fr auto;
        gap: 14px;
        align-items: center;
        border: 1px solid #eef2f7;
        border-radius: 18px;
        padding: 16px;
    }

    .parent-list-head {
        background: #f8fafc;
        font-weight: 800;
        color: #374151;
    }

    .parent-list-meta {
        color: #6b7280;
        font-size: 13px;
        margin-top: 4px;
    }

    .parent-list-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 8px 12px;
        font-size: 12px;
        font-weight: 700;
        background: #eef2ff;
        color: #46A3E5;
        width: fit-content;
    }

    .parent-list-btn {
        border: 1px solid #d1d5db;
        border-radius: 999px;
        padding: 9px 14px;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        color: #46A3E5;
        background: #fff;
        white-space: nowrap;
    }

    .parent-list-empty {
        color: #6b7280;
        text-align: center;
        padding: 28px;
    }

    @@media (max-width: 960px) {
        .parent-list-row {
            grid-template-columns: 1fr;
        }

        .parent-list-head {
            display: none;
        }
    }
</style>

<div class="parent-list-page">
    <div class="parent-list-card">
        <div class="parent-list-title">My Quizzes</div>
        <div class="parent-list-subtitle">Assigned quizzes for all linked students.</div>
        <div class="parent-list-toolbar">
            <select id="parentQuizzesSubjectFilter" class="parent-list-filter">
                <option value="all">All subjects</option>
            </select>
            <select id="parentQuizzesSort" class="parent-list-sort">
                <option value="due_asc">Due date: earliest first</option>
                <option value="due_desc">Due date: latest first</option>
                <option value="student_asc">Student name: A to Z</option>
                <option value="student_desc">Student name: Z to A</option>
                <option value="title_asc">Quiz title: A to Z</option>
                <option value="title_desc">Quiz title: Z to A</option>
                <option value="status_asc">Status: assigned first</option>
                <option value="status_desc">Status: submitted first</option>
            </select>
        </div>

        <div id="parentQuizzesList" class="parent-list-grid"></div>
    </div>
</div>

<script>
    const backendBaseUrl = "http://localhost:3000";
    const token = sessionStorage.getItem("bridgeAccessToken");
    const role = sessionStorage.getItem("bridgeUserRole");
    const parentQuizzesList = document.getElementById("parentQuizzesList");
    const parentQuizzesSort = document.getElementById("parentQuizzesSort");
    const parentQuizzesSubjectFilter = document.getElementById("parentQuizzesSubjectFilter");
    let parentQuizzesState = [];

    function quizDueTime(item) {
        return item?.dueDate ? new Date(item.dueDate).getTime() : Number.MAX_SAFE_INTEGER;
    }

    function compareText(left, right) {
        return String(left || "").localeCompare(String(right || ""));
    }

    function sortParentQuizzes(items) {
        const sortMode = parentQuizzesSort?.value || "due_asc";
        const sorted = [...items];

        sorted.sort((left, right) => {
            switch (sortMode) {
                case "due_desc":
                    return quizDueTime(right) - quizDueTime(left);
                case "student_asc":
                    return compareText(left.studentName, right.studentName);
                case "student_desc":
                    return compareText(right.studentName, left.studentName);
                case "title_asc":
                    return compareText(left.title, right.title);
                case "title_desc":
                    return compareText(right.title, left.title);
                case "status_asc":
                    return Number(Boolean(left.isSubmitted)) - Number(Boolean(right.isSubmitted));
                case "status_desc":
                    return Number(Boolean(right.isSubmitted)) - Number(Boolean(left.isSubmitted));
                case "due_asc":
                default:
                    return quizDueTime(left) - quizDueTime(right);
            }
        });

        return sorted;
    }

    function filterParentQuizzes(items) {
        const selectedSubject = parentQuizzesSubjectFilter?.value || "all";
        if (selectedSubject === "all") {
            return [...items];
        }

        return items.filter((item) => String(item.subjectId || "") === selectedSubject);
    }

    function renderParentQuizSubjectFilter(items) {
        if (!parentQuizzesSubjectFilter) return;

        const options = Array.from(
            new Map(
                items
                    .filter((item) => item.subjectId && item.subjectName)
                    .map((item) => [String(item.subjectId), item.subjectName])
            ).entries()
        );

        const currentValue = parentQuizzesSubjectFilter.value || "all";
        parentQuizzesSubjectFilter.innerHTML = `
            <option value="all">All subjects</option>
            ${options.map(([subjectId, subjectName]) => `<option value="${subjectId}">${subjectName}</option>`).join("")}
        `;

        if ([...parentQuizzesSubjectFilter.options].some((option) => option.value === currentValue)) {
            parentQuizzesSubjectFilter.value = currentValue;
        }
    }

    function renderParentQuizList(items) {
        if (!items.length) {
            parentQuizzesList.innerHTML = `<div class="parent-list-empty">No quizzes assigned yet.</div>`;
            return;
        }

        parentQuizzesList.innerHTML = `
            <div class="parent-list-row parent-list-head">
                <div>Quiz</div>
                <div>Subject</div>
                <div>Student</div>
                <div>Due</div>
                <div>Status</div>
                <div>Action</div>
            </div>
            ${items.map((item) => `
                <div class="parent-list-row">
                    <div>
                        <div><strong>${item.title}</strong></div>
                    </div>
                    <div>${item.subjectName || "-"}</div>
                    <div>${item.studentName}</div>
                    <div>${item.dueLabel || "-"}</div>
                    <div><span class="parent-list-badge">${item.isSubmitted ? (item.submissionStatus || "Submitted") : "Assigned"}</span></div>
                    <div>
                        ${item.isSubmitted
                            ? `<a class="parent-list-btn" href="@Url.Action("ParentQuizResults", "Home")">View result</a>`
                            : `<a class="parent-list-btn" href="@Url.Action("TakeQuiz", "Home")?studentId=${encodeURIComponent(item.studentId)}&assignmentId=${encodeURIComponent(item.assignmentId)}">Take quiz</a>`}
                    </div>
                </div>
            `).join("")}
        `;
    }

    async function loadParentQuizzes() {
        if (!token) {
            window.location.replace('@Url.Action("Login", "Home")');
            return;
        }

        if (role && role !== "Parent") {
            window.location.replace('@Url.Action("Teacher", "Home")');
            return;
        }

        const response = await fetch(`${backendBaseUrl}/parents/me/quizzes`, {
            headers: {
                Authorization: `Bearer ${token}`
            }
        });
        const data = await response.json().catch(() => []);

        if (!response.ok) {
            throw new Error(data?.message || "Unable to load quizzes.");
        }

        parentQuizzesState = Array.isArray(data) ? data : [];
        renderParentQuizSubjectFilter(parentQuizzesState);
        renderParentQuizList(sortParentQuizzes(filterParentQuizzes(parentQuizzesState)));
    }

    loadParentQuizzes().catch((error) => {
        parentQuizzesList.innerHTML = `<div class="parent-list-empty">${error.message || "Unable to load quizzes."}</div>`;
    });

    parentQuizzesSort?.addEventListener("change", () => {
        renderParentQuizList(sortParentQuizzes(filterParentQuizzes(parentQuizzesState)));
    });

    parentQuizzesSubjectFilter?.addEventListener("change", () => {
        renderParentQuizList(sortParentQuizzes(filterParentQuizzes(parentQuizzesState)));
    });
</script>
