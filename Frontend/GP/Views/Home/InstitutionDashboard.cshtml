@{
    ViewData["Title"] = "InstitutionDashboard";
}

<style>
    .institution-page { padding: 1.5rem 0 5rem; }

    /* Gradient hero header */
    .institution-hero {
        position: relative;
        overflow: hidden;
        padding: 1.9rem 2rem;
        border-radius: 1.6rem;
        background: linear-gradient(120deg, #C5AFF5 0%, #C5EFF9 52%, #FAE382 128%);
        box-shadow: 0 20px 48px rgba(60,64,140,.18);
    }
    .institution-hero::after {
        content: "";
        position: absolute;
        right: -3rem; top: -4rem;
        width: 14rem; height: 14rem;
        border-radius: 50%;
        background: rgba(255,255,255,.35);
        filter: blur(6px);
    }
    .institution-hero-badge {
        display: inline-flex; align-items: center; gap: .5rem;
        padding: .4rem .9rem; border-radius: 999px;
        background: rgba(255,255,255,.65); color: #5a458f;
        font-weight: 800; font-size: .85rem; margin-bottom: .7rem;
    }
    .institution-title { position: relative; margin: 0; font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 900; letter-spacing: -.03em; }
    .institution-hero .institution-title {
        background: none !important;
        color: #1B2440 !important;
        -webkit-text-fill-color: #1B2440 !important;
    }
    .institution-subtitle { position: relative; margin: 0.5rem 0 0; color: #3a4566; font-size: 1.05rem; font-weight: 600; }

    /* Metric cards — one brand colour each */
    .institution-metric-card {
        position: relative; overflow: hidden;
        padding: 1.4rem 1.4rem 1.5rem;
        border: 1px solid rgba(124,120,230,.16);
        border-radius: 1.4rem;
        background: #fff;
        box-shadow: 0 14px 32px rgba(60,64,140,.10);
        height: 100%;
        transition: transform .22s ease, box-shadow .22s ease;
    }
    .institution-metric-card::before {
        content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: .4rem;
    }
    .institution-metric-card:hover { transform: translateY(-4px); box-shadow: 0 22px 46px rgba(60,64,140,.16); }
    .institution-metric-icon {
        display: grid; place-items: center;
        width: 3.2rem; height: 3.2rem; border-radius: 1rem;
        font-size: 1.5rem; margin-bottom: .9rem;
    }
    .institution-metric-label { color: #6B6F8A; font-size: .95rem; font-weight: 600; }
    .institution-metric-value { margin-top: .35rem; font-size: 2.6rem; font-weight: 900; color: #1B2440; line-height: 1; }

    .metric-lavender::before { background: #8E89F0; }
    .metric-lavender .institution-metric-icon { background: #E8E7FF; color: #6B66D6; }
    .metric-sky::before { background: #4FB3E8; }
    .metric-sky .institution-metric-icon { background: #E5F5FE; color: #2A8FCB; }
    .metric-yellow::before { background: #EBC53F; }
    .metric-yellow .institution-metric-icon { background: #FFF4C2; color: #B58A00; }
    .metric-blue::before { background: #8B6FCB; }
    .metric-blue .institution-metric-icon { background: #E7DEFB; color: #7458B8; }

    .institution-panel {
        padding: 1.5rem;
        border: 1px solid rgba(124,120,230,.16);
        border-radius: 1.4rem;
        background: #fff;
        box-shadow: 0 14px 32px rgba(60,64,140,.10);
        height: 100%; overflow: hidden;
    }
    .institution-section-title {
        display: flex; align-items: center; gap: .6rem;
        margin: 0 0 1.1rem; padding-bottom: .85rem;
        font-size: 1.2rem; font-weight: 800; color: #1B2440;
        border-bottom: 2px solid rgba(124,120,230,.14);
    }
    .institution-section-title i {
        display: grid; place-items: center;
        width: 2.1rem; height: 2.1rem; border-radius: .7rem;
        background: var(--bridge-lavender, #C5AFF5); color: #5a458f; font-size: 1.05rem;
    }
    .institution-list { display: grid; gap: .85rem; }
    .institution-list-item {
        padding: .95rem 1rem; border: 1px solid rgba(124,120,230,.14);
        border-left: 4px solid #8E89F0;
        border-radius: .9rem; background: #faf9ff;
        transition: transform .18s ease, box-shadow .18s ease;
    }
    .institution-list-item:hover { transform: translateX(3px); box-shadow: 0 8px 20px rgba(60,64,140,.10); }
    .institution-list-title { font-weight: 700; color: #1B2440; }
    .institution-list-copy { margin-top: .25rem; color: #6B6F8A; font-size: .94rem; }
    .institution-table { display: grid; gap: .9rem; min-width: 0; }
    .institution-filter-row { display:flex; justify-content:flex-end; margin:-.35rem 0 1rem; }
    .institution-filter-select { min-width: 170px; padding:.7rem 1rem; border:1px solid rgba(124,120,230,.16); border-radius:.9rem; background:#fff; color:#1B2440; font-weight:600; }
    .institution-row, .institution-head { display: grid; grid-template-columns: minmax(9.5rem,1.6fr) minmax(7rem,1.15fr) minmax(3.6rem,.6fr) minmax(4.2rem,.65fr) minmax(4.2rem,.65fr) minmax(4.2rem,.75fr); gap: .9rem; align-items: center; padding: 1.15rem 1.15rem; border: 1px solid rgba(124,120,230,.14); border-radius: 1rem; background: #fff; }
    .institution-row { transition: background .18s ease, transform .18s ease; }
    .institution-row:hover { background: rgba(208,206,255,.22); transform: scale(1.005); }
    .institution-row > div, .institution-head > div { min-width: 0; overflow: hidden; text-overflow: ellipsis; }
    .institution-row .institution-list-copy { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .institution-head { color: #5a458f; font-weight: 800; font-size: .9rem; padding: 1rem 1.15rem; background: linear-gradient(135deg, rgba(197,175,245,.5), rgba(197,239,249,.5)); border: 0; }
    .institution-empty { color: #6b7280; }
    .institution-side-stack { display:grid; gap:1.5rem; }
    @@media (max-width: 1199.98px) { .institution-panel { height: auto; } }
    @@media (max-width: 991.98px) { .institution-head, .institution-row { grid-template-columns: 1fr; } .institution-head { display:none; } }
</style>

<div class="teacher-shell">
    <partial name="_InstitutionSidebar" />
    <div class="teacher-shell-content">
        <div class="container institution-page">
            <div class="institution-hero">
                <span class="institution-hero-badge"><i class="bi bi-buildings"></i> Admin Workspace</span>
                <h1 class="institution-title">Institution Dashboard</h1>
                <p class="institution-subtitle" id="institutionDashboardSubtitle">School-wide monitoring for teachers and progress.</p>
            </div>

            <div class="row g-4 mt-3">
                <div class="col-12 col-md-6 col-xl-3"><div class="institution-metric-card metric-lavender"><div class="institution-metric-icon"><i class="bi bi-person-workspace"></i></div><div class="institution-metric-label">Total Teachers</div><div class="institution-metric-value" id="totalTeachersValue">0</div></div></div>
                <div class="col-12 col-md-6 col-xl-3"><div class="institution-metric-card metric-sky"><div class="institution-metric-icon"><i class="bi bi-clipboard2-check"></i></div><div class="institution-metric-label">Teachers With Plans</div><div class="institution-metric-value" id="teachersWithPlansValue">0</div></div></div>
                <div class="col-12 col-md-6 col-xl-3"><div class="institution-metric-card metric-yellow"><div class="institution-metric-icon"><i class="bi bi-graph-up-arrow"></i></div><div class="institution-metric-label">Average School Score</div><div class="institution-metric-value" id="averageClassScoreValue">0%</div></div></div>
                <div class="col-12 col-md-6 col-xl-3"><div class="institution-metric-card metric-blue"><div class="institution-metric-icon"><i class="bi bi-hourglass-split"></i></div><div class="institution-metric-label">Behind Pace Classes</div><div class="institution-metric-value" id="behindPaceValue">0</div></div></div>
            </div>

            <div class="row g-4 mt-2">
                <div class="col-12 col-xl-7">
                    <div class="institution-panel">
                        <h2 class="institution-section-title"><i class="bi bi-people-fill"></i> Teacher Overview</h2>
                        <div class="institution-filter-row">
                            <select id="institutionOverviewSubjectFilter" class="institution-filter-select">
                                <option value="Arabic">Arabic</option>
                                <option value="Mathematics">Mathematics</option>
                            </select>
                        </div>
                        <div class="institution-head">
                            <div>Teacher</div><div>Grade / Subject</div><div>Students</div><div>Class Avg</div><div>Weak Students</div><div>Plan Progress</div>
                        </div>
                        <div id="institutionTeachersTable" class="institution-table"></div>
                        <div id="institutionTeachersEmpty" class="institution-empty d-none">No teachers are linked to this school yet.</div>
                    </div>
                </div>
                <div class="col-12 col-xl-5">
                    <div class="institution-side-stack">
                        <div class="institution-panel">
                            <h2 class="institution-section-title"><i class="bi bi-list-task"></i> Open Tasks</h2>
                            <div id="institutionOpenTasks" class="institution-list"></div>
                            <div id="institutionOpenTasksEmpty" class="institution-empty d-none">No open tasks right now.</div>
                        </div>
                        <div class="institution-panel">
                            <h2 class="institution-section-title"><i class="bi bi-bell-fill"></i> Recent Notifications</h2>
                            <div id="institutionNotifications" class="institution-list"></div>
                            <div id="institutionNotificationsEmpty" class="institution-empty d-none">No incoming notifications right now.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (() => {
        const backendBaseUrl = "http://localhost:3000";
        const token = sessionStorage.getItem("bridgeAccessToken");
        const role = sessionStorage.getItem("bridgeUserRole");

        if (role && role !== "Institution") {
            window.location.replace('@Url.Action("Teacher", "Home")');
            return;
        }

        if (!token) {
            window.location.replace('@Url.Action("Login", "Home")');
            return;
        }

        const totalTeachersValue = document.getElementById("totalTeachersValue");
        const teachersWithPlansValue = document.getElementById("teachersWithPlansValue");
        const averageClassScoreValue = document.getElementById("averageClassScoreValue");
        const behindPaceValue = document.getElementById("behindPaceValue");
        const institutionDashboardSubtitle = document.getElementById("institutionDashboardSubtitle");
        const institutionTeachersTable = document.getElementById("institutionTeachersTable");
        const institutionTeachersEmpty = document.getElementById("institutionTeachersEmpty");
        const institutionOpenTasks = document.getElementById("institutionOpenTasks");
        const institutionOpenTasksEmpty = document.getElementById("institutionOpenTasksEmpty");
        const institutionNotifications = document.getElementById("institutionNotifications");
        const institutionNotificationsEmpty = document.getElementById("institutionNotificationsEmpty");
        const institutionOverviewSubjectFilter = document.getElementById("institutionOverviewSubjectFilter");
        let dashboardTeachers = [];
        let teacherOverviewRows = [];

        function authHeaders() {
            return { Authorization: `Bearer ${token}` };
        }

        function renderTeachers(rows, selectedSubject = "Arabic") {
            institutionTeachersTable.innerHTML = "";
            const allRows = Array.isArray(rows) ? rows : [];
            const filteredRows = allRows.filter((row) => row.subjectName === selectedSubject);

            institutionTeachersEmpty.classList.toggle("d-none", filteredRows.length > 0);

            filteredRows.forEach((teacher) => {
                const row = document.createElement("div");
                row.className = "institution-row";
                row.innerHTML = `
                    <div><div class="institution-list-title">${teacher.fullName}</div><div class="institution-list-copy">${teacher.email}</div></div>
                    <div>${teacher.grade || "-"}${teacher.section ? ` / ${teacher.section}` : ""}<div class="institution-list-copy">${teacher.subjectName}${teacher.isRegisteredForSubject ? "" : " · Not registered"}</div></div>
                    <div>${teacher.studentCount ?? 0}</div>
                    <div>${teacher.classAverage ?? 0}%</div>
                    <div>${teacher.weakStudentCount ?? 0}</div>
                    <div>${teacher.hasGeneratedPlan ? `${teacher.progressPercentage ?? 0}%` : "Did not generate the plan"}</div>
                `;
                institutionTeachersTable.appendChild(row);
            });
        }

        function renderSubjectFilter(subjects) {
            const rows = Array.isArray(subjects) ? subjects : [];
            institutionOverviewSubjectFilter.innerHTML = `${rows
                .map((subject) => `<option value="${subject}">${subject}</option>`)
                .join("")}`;
            if (rows.length > 0) {
                institutionOverviewSubjectFilter.value = rows.includes("Arabic") ? "Arabic" : rows[0];
            }
        }

        function getTeacherName(teacherId) {
            return dashboardTeachers.find((teacher) => String(teacher.userId) === String(teacherId))?.fullName || teacherId;
        }

        function renderTeacherAudience(teacherIds) {
            if (!teacherIds?.length) {
                return "All teachers";
            }

            return teacherIds.map((teacherId) => getTeacherName(teacherId)).join(", ");
        }

        function renderList(container, emptyElement, items, titleSelector, copyBuilder) {
            container.innerHTML = "";
            const rows = Array.isArray(items) ? items : [];
            emptyElement.classList.toggle("d-none", rows.length > 0);

            rows.forEach((item) => {
                const element = document.createElement("div");
                element.className = "institution-list-item";
                element.innerHTML = `<div class="institution-list-title">${titleSelector(item)}</div><div class="institution-list-copy">${copyBuilder(item)}</div>`;
                container.appendChild(element);
            });
        }

        fetch(`${backendBaseUrl}/institutions/me/dashboard`, { headers: authHeaders() })
            .then(async (response) => {
                const data = await response.json().catch(() => null);
                if (!response.ok) {
                    throw new Error(data?.message || "Unable to load institution dashboard.");
                }
                return data;
            })
            .then((dashboard) => {
                totalTeachersValue.textContent = String(dashboard.totalTeachers ?? 0);
                teachersWithPlansValue.textContent = String(dashboard.teachersWithPlans ?? 0);
                averageClassScoreValue.textContent = `${dashboard.averageClassScore ?? 0}%`;
                behindPaceValue.textContent = String(dashboard.behindPaceClasses ?? 0);
                institutionDashboardSubtitle.textContent = `${dashboard.schoolName || "School"} at a glance.`;
                dashboardTeachers = Array.isArray(dashboard.teachers) ? dashboard.teachers : [];
                teacherOverviewRows = Array.isArray(dashboard.teacherOverviewRows) ? dashboard.teacherOverviewRows : [];
                renderSubjectFilter(dashboard.overviewSubjects);
                renderTeachers(teacherOverviewRows, institutionOverviewSubjectFilter.value || "Arabic");
                renderList(
                    institutionOpenTasks,
                    institutionOpenTasksEmpty,
                    dashboard.openTasks,
                    (item) => item.title,
                    (item) => `
                        <div>${item.description || "No description"}</div>
                        <div class="mt-1"><strong>Audience:</strong> ${renderTeacherAudience(item.assignedTeacherUserIds)}</div>
                    `,
                );
                renderList(
                    institutionNotifications,
                    institutionNotificationsEmpty,
                    dashboard.recentNotifications,
                    (item) => item.title,
                    (item) => `
                        <div>${item.message || "No message"}</div>
                        <div class="mt-1"><strong>Sender:</strong> ${getTeacherName(item.createdByUserId)}</div>
                    `,
                );

                institutionOverviewSubjectFilter.addEventListener("change", () => {
                    renderTeachers(teacherOverviewRows, institutionOverviewSubjectFilter.value || "Arabic");
                });
            })
            .catch((error) => {
                institutionDashboardSubtitle.textContent = error.message || "Unable to load school data.";
            });
    })();
</script>
