@{
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLowerInvariant();
    var hideVerificationBanner = currentAction is "verification" or "verifyotp" or "nextverification" or "afterverification";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GP</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GP.styles.css" asp-append-version="true" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    

</head>
<body class="bridge-polished-page">
    <div class="bridge-ambient-bg" aria-hidden="true"><span></span><span></span><span></span></div>
    <div class="bridge-cursor-dot" aria-hidden="true"></div>
    <nav class="navbar navbar-expand-lg bridge-navbar" style="height:5rem">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="#">
                <img src="~/img/logo.png" alt="BRIDGE" class="img-fluid" style="position: absolute;top: -7px;height: 5em;width: 7rem, left: 7rem;">
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-4">
                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Home" asp-action="About">About Us</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Contact">Contact Us</a>
                    </li>

                </ul>
                <div class="d-flex align-items-center ms-lg-4 pe-2 gap-2">
                    <a asp-controller="Home"
                       asp-action="Login"
                       id="mainLoginButton"
                       class="btn btn-info rounded-pill px-4 fw-semibold">
                        Login
                    </a>

                    <button type="button"
                            id="mainLogoutButton"
                            class="btn btn-outline-secondary rounded-pill px-4 fw-semibold d-none">
                        Logout
                    </button>
                </div>


                <a asp-action="Profile" asp-controller="Home" id="mainProfileButton" class="btn btn-info rounded-pill px-3 py-1 d-flex align-items-center gap-2">
                    <i class="bi bi-person-circle"></i>
                    Profile
                </a>
            </div>

        </div>
    </nav>
    <div id="verificationBanner" class="verification-banner @(hideVerificationBanner ? "d-none" : "")">
        <div class="container">
            <div class="verification-banner-inner">
                <div class="verification-banner-copy">
                    <i class="bi bi-exclamation-circle"></i>
                    <span>Your account is not verified yet. Verify it to avoid interruptions.</span>
                </div>
                <div class="verification-banner-actions">
                    <span id="verificationBannerStatus" class="verification-banner-status d-none"></span>
                    <a asp-controller="Home" asp-action="Verification" id="verificationBannerVerify" class="verification-banner-btn verification-banner-btn-primary">
                        Verify now
                    </a>
                    <button type="button" id="verificationBannerResend" class="verification-banner-btn">
                        Resend code
                    </button>
                </div>
            </div>
        </div>
    </div>
