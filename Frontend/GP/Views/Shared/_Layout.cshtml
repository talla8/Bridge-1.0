    </header> *@
    <div class="">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <footer class="py-4 bg-primary bg-opacity-10">
        <div class="container">
            <div class="row text-center text-md-start">

              
                <div class="col-12 col-md-4 mb-3 mb-md-0">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <a asp-controller="Home" asp-action="About" class="text-decoration-none text-secondary">About us</a>
                        </li>
                        <li>
                            <a asp-controller="Home" asp-action="Contact" class="text-decoration-none text-secondary">Contact us</a>
                        </li>
                    </ul>
                </div>

                <div class="col-12 col-md-4 mb-3 mb-md-0">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-secondary">Privacy Policy</a>
                        </li>
                    </ul>
                </div>

                <div class="col-12 col-md-4">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2 text-secondary fw-semibold">
                            Social Media accounts
                        </li>
                        <li>
                            <a href="#" class="text-decoration-none text-secondary me-3">Facebook</a>
                            <a href="#" class="text-decoration-none text-secondary">LinkedIn</a>
                        </li>
                    </ul>
                </div>

            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.19.3/dist/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jspdf-autotable@3.8.3/dist/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (() => {
            const role = sessionStorage.getItem("bridgeUserRole");
            const token = sessionStorage.getItem("bridgeAccessToken");
            const backendBaseUrl = "http://localhost:3000";
            const loginButton = document.getElementById("mainLoginButton");
            const logoutButton = document.getElementById("mainLogoutButton");
            const profileButton = document.getElementById("mainProfileButton");
            const verificationBanner = document.getElementById("verificationBanner");
            const suppressVerificationBanner = @hideVerificationBanner.ToString().ToLowerInvariant();
            const verificationBannerVerify = document.getElementById("verificationBannerVerify");
            const verificationBannerResend = document.getElementById("verificationBannerResend");
            const verificationBannerStatus = document.getElementById("verificationBannerStatus");

            if (token && loginButton) {
                loginButton.classList.add("d-none");
            }

            if (token && logoutButton) {
                logoutButton.classList.remove("d-none");
            }

            if (!token && profileButton) {
                profileButton.classList.add("d-none");
            }

            logoutButton?.addEventListener("click", () => {
                const keysToRemove = [
                    "bridgeAccessToken",
                    "bridgeUserRole",
                    "bridgeUserName",
                    "bridgeTeacherGrade",
                    "bridgeInstitutionSchoolName",
                    "bridgeInstitutionTeacherJoinCode",
                    "bridgeUserVerified",
                    "bridgeVerificationRole",
                    "bridgeTeacherSidebarOpen",
                    "bridgeInstitutionSidebarOpen",
                ];

                keysToRemove.forEach((key) => sessionStorage.removeItem(key));
                localStorage.removeItem("teacherSelectedSubject");
                window.location.replace('@Url.Action("Login", "Home")');
            });

            if (!profileButton) {
                return;
            }

            if (role === "Parent") {
                profileButton.href = '@Url.Action("ParentDashboard", "Home")';
            } else if (role === "Institution") {
                profileButton.href = '@Url.Action("InstitutionDashboard", "Home")';
            } else {
                profileButton.href = '@Url.Action("Profile", "Home")';
            }

            function showVerificationStatus(message, isError = false) {
                if (!verificationBannerStatus) {
                    return;
                }

                verificationBannerStatus.textContent = message;
                verificationBannerStatus.classList.remove("d-none");
                verificationBannerStatus.style.color = isError ? "#b91c1c" : "#7A6000";
            }

            if (verificationBannerVerify && role) {
                verificationBannerVerify.addEventListener("click", async (event) => {
                    sessionStorage.setItem("bridgeVerificationRole", role.toLowerCase());

                    if (!token) {
                        return;
                    }

                    event.preventDefault();
                    verificationBannerVerify.classList.add("disabled");
                    verificationBannerVerify.style.pointerEvents = "none";
                    showVerificationStatus("Sending code...");

                    try {
                        const response = await fetch(`${backendBaseUrl}/auth/resend-verification`, {
                            method: "POST",
                            headers: {
                                Authorization: `Bearer ${token}`
                            }
                        });
                        const data = await response.json().catch(() => null);

                        if (!response.ok) {
                            const message = Array.isArray(data?.message) ? data.message.join(", ") : data?.message;
                            throw new Error(message || "Unable to resend verification code.");
                        }

                        showVerificationStatus(data?.message || "Verification code sent.");
                    } catch (error) {
                        showVerificationStatus(error.message || "Unable to resend verification code.", true);
                    } finally {
                        verificationBannerVerify.classList.remove("disabled");
                        verificationBannerVerify.style.pointerEvents = "";
                        window.location.href = verificationBannerVerify.href;
                    }
                });
            }

            verificationBannerResend?.addEventListener("click", async () => {
                if (!token) {
                    return;
                }

                verificationBannerResend.disabled = true;
                showVerificationStatus("Sending code...");

                try {
                    const response = await fetch(`${backendBaseUrl}/auth/resend-verification`, {
                        method: "POST",
                        headers: {
                            Authorization: `Bearer ${token}`
                        }
                    });
                    const data = await response.json().catch(() => null);

                    if (!response.ok) {
                        const message = Array.isArray(data?.message) ? data.message.join(", ") : data?.message;
                        throw new Error(message || "Unable to resend verification code.");
                    }

                    showVerificationStatus(data?.message || "Verification code sent.");
                } catch (error) {
                    showVerificationStatus(error.message || "Unable to resend verification code.", true);
                } finally {
                    verificationBannerResend.disabled = false;
                }
            });

            if (!token || !verificationBanner || suppressVerificationBanner) {
                return;
            }

            fetch(`${backendBaseUrl}/auth/profile`, {
                headers: {
                    Authorization: `Bearer ${token}`
                }
            })
                .then((response) => response.ok ? response.json() : null)
                .then((profile) => {
                    if (!profile) {
                        return;
                    }

                    sessionStorage.setItem("bridgeUserRole", profile.roleId || role || "");
                    sessionStorage.setItem("bridgeUserVerified", profile.isVerified ? "true" : "false");

                    if (!profile.isVerified) {
                        verificationBanner.classList.add("show");
                    } else {
                        verificationBanner.classList.remove("show");
                    }
                })
                .catch(() => {
                    return;
                });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
